 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j DNAT --to-destination 192.168.1.10:3128
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth0 -p tcp -m tcp -d 192.168.1.10 --dport 3128 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 3128 -j SNAT --to-source 192.168.1.1
 #
 # Rule 35 (NAT)
 #
 echo "Rule 35 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.50 -j RETURN
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j DNAT --to-destination 192.168.1.50:3128
 #
 # Rule 36 (NAT)
 #
 echo "Rule 36 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth0 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A CHAIN -j CHAIN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j RETURN
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 192.168.1.1
 #
 # Rule 37 (NAT)
 #
 echo "Rule 37 (NAT)"
 #
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -j DNAT --to-destination 192.168.1.10:3128
 $IPTABLES -t nat -A POSTROUTING -o eth0 -p tcp -m tcp -s 192.168.1.0/24 -d 192.168.1.10 --dport 3128 -j SNAT --to-source 192.168.1.1
 #
 # Rule 38 (NAT)
 #
 echo "Rule 38 (NAT)"
 #
 # this is the "exception" rule
 # used in support req. originally
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.10 --dport 80 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.20 --dport 80 -j SNAT --to-source 22.22.22.22
 #
 # Rule 39 (NAT)
 #
 echo "Rule 39 (NAT)"
 #
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -j DNAT --to-destination 192.168.1.1:3128
 #
 # Rule 40 (NAT)
 #
 echo "Rule 40 (NAT)"
 #
 # "exception" rule in the pair
 # from a support req.
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.10 --dport 80 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.20 --dport 80 -j SNAT --to-source 22.22.22.22
 #
 # Rule 41 (NAT)
 #
 echo "Rule 41 (NAT)"
 #
 # testing transparent proxy
 # roules for a support req.
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A OUTPUT -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j DNAT --to-destination 192.168.1.1:3128
 #
 # Rule 42 (NAT)
 #
 echo "Rule 42 (NAT)"
 #
 # testing transparent proxy
 # roules for a support req.
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A OUTPUT -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j DNAT --to-destination 192.168.1.1:3128
 #
 # Rule 43 (NAT)
 #
 echo "Rule 43 (NAT)"
 #
 # testing transparent proxy
 # roules for a support req.
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j REDIRECT --to-ports 3128
 #
 # Rule 44 (NAT)
 #
 echo "Rule 44 (NAT)"
 #
 # "exception" rule in the pair
 # from a support req.
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.10 --dport 80 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.20 --dport 80 -j SNAT --to-source 22.22.22.22
 #
 # Rule 45 (NAT)
 #
 echo "Rule 45 (NAT)"
 #
 # testing transparent proxy
 # roules for a support req.
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A OUTPUT -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j DNAT --to-destination 192.168.1.50:3128

 # ================ Table 'filter', rule set Policy
 #
 # Rule 0 (eth1)
 #
 echo "Rule 0 (eth1)"
 #
 # Anti-spoofing rule
 $IPTABLES -N In_RULE_0 2>/dev/null
 $IPTABLES -A INPUT -i eth1 -s 192.168.1.1 -j In_RULE_0
 $IPTABLES -A INPUT -i eth1 -s 192.168.1.0/24 -j In_RULE_0
 $IPTABLES -A FORWARD -i eth1 -s 192.168.1.1 -j In_RULE_0
 $IPTABLES -A FORWARD -i eth1 -s 192.168.1.0/24 -j In_RULE_0
 $IPTABLES -A In_RULE_0 -j LOG --log-level debug --log-prefix "Iface: global RULE 0 -- DENY "
 $IPTABLES -A In_RULE_0 -j DROP
 #
 # Rule 1 (eth1)
 #
 echo "Rule 1 (eth1)"
 #
 # Anti-spoofing rule
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -o eth1 -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.1 -j RETURN
 $IPTABLES -N Out_RULE_1 2>/dev/null
 $IPTABLES -A CHAIN -j Out_RULE_1
 $IPTABLES -A Out_RULE_1 -j LOG --log-level debug --log-prefix "Iface: global RULE 1 -- DENY "
 $IPTABLES -A Out_RULE_1 -j DROP
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth1 -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -j Out_RULE_1
 #
 # Rule 2 ()
 #
 echo "Rule 2 ()"
 #
 # testing group in "interface"
 # this rule should be identical to rule 3
 $IPTABLES -N In_RULE_2 2>/dev/null
 $IPTABLES -A INPUT -i eth1 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_2
 $IPTABLES -A INPUT -i eth3 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_2
 $IPTABLES -A FORWARD -i eth1 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_2
 $IPTABLES -A FORWARD -i eth3 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_2
 $IPTABLES -A In_RULE_2 -j LOG --log-level debug --log-prefix "RULE 2 - DENY **"
 $IPTABLES -A In_RULE_2 -j DROP
 #
 # Rule 3 (eth1,eth3)
 #
 echo "Rule 3 (eth1,eth3)"
 #
 $IPTABLES -N In_RULE_3 2>/dev/null
 $IPTABLES -A INPUT -i eth1 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_3
 $IPTABLES -A INPUT -i eth3 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_3
 $IPTABLES -A FORWARD -i eth1 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_3
 $IPTABLES -A FORWARD -i eth3 -p udp -m udp -m multiport -s 192.168.1.0/24 --dports 68,67 -j In_RULE_3
 $IPTABLES -A In_RULE_3 -j LOG --log-level debug --log-prefix "RULE 3 - DENY **"
 $IPTABLES -A In_RULE_3 -j DROP
 #
 # Rule 4 (eth1,eth3)
 #
 echo "Rule 4 (eth1,eth3)"
 #
 # testing choice of chains in case when several
 # interfaces are used and rule matches 'any' or
 # broadcast
 $IPTABLES -A FORWARD -i eth1 -p udp -m udp -m multiport -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i eth3 -p udp -m udp -m multiport -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -o eth1 -p udp -m udp -m multiport -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -o eth3 -p udp -m udp -m multiport -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth1 -p udp -m udp -m multiport -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth3 -p udp -m udp -m multiport -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 #
 # Rule 5 (eth1,eth3)
 #
 echo "Rule 5 (eth1,eth3)"
 #
 $IPTABLES -A FORWARD -i eth1 -p udp -m udp -m multiport -s 0.0.0.0 -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i eth3 -p udp -m udp -m multiport -s 0.0.0.0 -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 #
 # Rule 6 (eth1,eth3)
 #
 echo "Rule 6 (eth1,eth3)"
 #
 $IPTABLES -A OUTPUT -o eth1 -p udp -m udp -m multiport -s 192.168.1.0/24 -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -o eth3 -p udp -m udp -m multiport -s 192.168.1.0/24 -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth1 -p udp -m udp -m multiport -s 192.168.1.0/24 -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth3 -p udp -m udp -m multiport -s 192.168.1.0/24 -d 255.255.255.255 --dports 68,67 -m state --state NEW -j ACCEPT
 #
 # Rule 7 (global)
 #
 echo "Rule 7 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -j CHAIN
 $IPTABLES -A INPUT -j CHAIN
 $IPTABLES -A FORWARD -j CHAIN
 $IPTABLES -A CHAIN -p tcp -m tcp --tcp-flags ALL SYN -j RETURN
 $IPTABLES -N RULE_7 2>/dev/null
 $IPTABLES -A CHAIN -j RULE_7
 $IPTABLES -A RULE_7 -j LOG --log-level debug --log-prefix "RULE 7 - DENY **"
 $IPTABLES -A RULE_7 -j DROP
 #
 # Rule 8 (global)
 #
 echo "Rule 8 (global)"
 #
 # block fragments
 $IPTABLES -N RULE_8 2>/dev/null
 $IPTABLES -A OUTPUT -p 0 -f -j RULE_8
 $IPTABLES -A INPUT -p 0 -f -j RULE_8
 $IPTABLES -A FORWARD -p 0 -f -j RULE_8
 $IPTABLES -A RULE_8 -j LOG --log-level debug --log-prefix "RULE 8 - DENY **"
 $IPTABLES -A RULE_8 -j DROP
 #
 # Rule 9 (global)
 #
 echo "Rule 9 (global)"
 #
 # sends TCP RST and makes custom record
 # in the log
 $IPTABLES -N RULE_9 2>/dev/null
 $IPTABLES -A OUTPUT -p tcp -m tcp --dport 113 -j RULE_9
 $IPTABLES -A INPUT -p tcp -m tcp --dport 113 -j RULE_9
 $IPTABLES -A FORWARD -p tcp -m tcp --dport 113 -j RULE_9
 $IPTABLES -A RULE_9 -j LOG --log-level debug --log-prefix "IDENT"
 $IPTABLES -A RULE_9 -j REJECT --reject-with tcp-reset
 #
 # Rule 10 (global)
 #
 echo "Rule 10 (global)"
 #
 $IPTABLES -N RULE_10 2>/dev/null
 $IPTABLES -A OUTPUT -p udp -m udp --dport 161 -j RULE_10
 $IPTABLES -A INPUT -p udp -m udp --dport 161 -j RULE_10
 $IPTABLES -A FORWARD -p udp -m udp --dport 161 -j RULE_10
 $IPTABLES -A RULE_10 -j LOG --log-level debug --log-prefix "RULE 10 - REJECT **"
 $IPTABLES -A RULE_10 -j REJECT --reject-with icmp-net-unreachable
 #
 # Rule 11 (global)
 #
 echo "Rule 11 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A OUTPUT -p udp -m udp -m iprange --dst-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p udp -m udp -m iprange --dst-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 12 (global)
 #
 echo "Rule 12 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A INPUT -p udp -m udp -m iprange --src-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p udp -m udp -m iprange --src-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 13 (global)
 #
 echo "Rule 13 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A FORWARD -p udp -m udp -m iprange --src-range 222.222.222.10-222.222.222.100 -m iprange --dst-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 14 (global)
 #
 echo "Rule 14 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A FORWARD -p udp -m udp -m iprange --src-range 192.168.1.10-192.168.1.100 -m iprange --dst-range 222.222.222.10-222.222.222.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 15 (global)
 #
 echo "Rule 15 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A OUTPUT -p udp -m udp -m iprange ! --dst-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -p udp -m udp -m iprange ! --dst-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p udp -m udp -m iprange ! --dst-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 16 (global)
 #
 echo "Rule 16 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A OUTPUT -p udp -m udp -m iprange ! --src-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -p udp -m udp -m iprange ! --src-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p udp -m udp -m iprange ! --src-range 192.168.1.10-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 17 (global)
 #
 echo "Rule 17 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p udp -m udp --dport 161 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p udp -m udp --dport 161 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p udp -m udp --dport 161 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.0 -j RETURN
 $IPTABLES -A CHAIN -m iprange --dst-range 192.168.1.10-192.168.1.100 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 18 (global)
 #
 echo "Rule 18 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p udp -m udp --dport 161 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p udp -m udp --dport 161 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p udp -m udp --dport 161 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0 -j RETURN
 $IPTABLES -A CHAIN -m iprange --src-range 192.168.1.10-192.168.1.100 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 19 (global)
 #
 echo "Rule 19 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 # also test for bug #2526173
 $IPTABLES -N RULE_19 2>/dev/null
 $IPTABLES -A INPUT -s 0.0.0.0 -j RULE_19
 $IPTABLES -A FORWARD -s 0.0.0.0 -j RULE_19
 $IPTABLES -A RULE_19 -j LOG --log-level debug --log-prefix "RULE 19 - DENY **"
 $IPTABLES -A RULE_19 -j DROP
 #
 # Rule 20 (global)
 #
 echo "Rule 20 (global)"
 #
 # using module iprange if
 # iptables version is >= 1.2.11
 $IPTABLES -A INPUT -p udp -m udp -m iprange --src-range 192.168.1.1-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -p udp -m udp -m iprange --src-range 192.168.1.1-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p udp -m udp -m iprange --src-range 192.168.1.1-192.168.1.100 --dport 161 -m state --state NEW -j ACCEPT
 #
 # Rule 21 (global)
 #
 echo "Rule 21 (global)"
 #
 $IPTABLES -N RULE_21 2>/dev/null
 $IPTABLES -A INPUT -p icmp -m icmp -s 192.168.2.0/24 -d 192.168.2.1 -m state --state NEW -j RULE_21
 $IPTABLES -A RULE_21 -j LOG --log-level debug --log-prefix "RULE 21 - ACCEPT **"
 $IPTABLES -A RULE_21 -j ACCEPT
 #
 # Rule 22 (global)
 #
 echo "Rule 22 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -d 211.11.11.11 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.10 -j ACCEPT
 $IPTABLES -A CHAIN -s 192.168.1.20 -j ACCEPT
 #
 # Rule 23 (global)
 #
 echo "Rule 23 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -s 211.11.11.11 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.10 -j ACCEPT
 $IPTABLES -A CHAIN -d 192.168.1.20 -j ACCEPT
 #
 # Rule 24 (global)
 #
 echo "Rule 24 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p tcp -m tcp -j CHAIN
 $IPTABLES -A INPUT -p tcp -m tcp -j CHAIN
 $IPTABLES -A FORWARD -p tcp -m tcp -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -A CHAIN -j REJECT --reject-with tcp-reset
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -j CHAIN
 $IPTABLES -A INPUT -j CHAIN
 $IPTABLES -A FORWARD -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -A CHAIN -j REJECT --reject-with icmp-net-unreachable
 #
 # Rule 25 (global)
 #
 echo "Rule 25 (global)"
 #
 $IPTABLES -A INPUT -s 192.168.1.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -s 192.168.2.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -s 192.168.1.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -s 192.168.2.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -s 192.168.1.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -s 192.168.2.0/24 -m state --state NEW -j ACCEPT
 #
 # Rule 26 (global)
 #
 echo "Rule 26 (global)"
 #
 $IPTABLES -N RULE_26 2>/dev/null
 $IPTABLES -A INPUT -s 192.168.1.0/24 -j RULE_26
 $IPTABLES -A OUTPUT -s 192.168.1.0/24 -j RULE_26
 $IPTABLES -A FORWARD -s 192.168.1.0/24 -j RULE_26
 $IPTABLES -A RULE_26 -j LOG --log-level debug --log-prefix "RULE 26 - DENY **"
 $IPTABLES -A RULE_26 -j DROP
 #
 # Rule 27 (global)
 #
 echo "Rule 27 (global)"
 #
 # host-fw2 has the same address as
 # one of the firewall's interfaces
 $IPTABLES -N RULE_27 2>/dev/null
 $IPTABLES -A OUTPUT -p tcp -m tcp -d 22.22.22.22 --dport 21 -m state --state NEW -m limit --limit 5/minute --limit-burst 10 -j RULE_27
 $IPTABLES -A FORWARD -p tcp -m tcp -d 22.22.22.22 --dport 21 -m state --state NEW -m limit --limit 5/minute --limit-burst 10 -j RULE_27
 $IPTABLES -A RULE_27 -j LOG --log-level debug --log-prefix "RULE 27 - ACCEPT **"
 $IPTABLES -A RULE_27 -j ACCEPT
 #
 # Rule 28 (global)
 #
 echo "Rule 28 (global)"
 #
 $IPTABLES -N RULE_28 2>/dev/null
 $IPTABLES -A OUTPUT -p tcp -m tcp -d 192.168.1.1 --dport 21 -m state --state NEW -j RULE_28
 $IPTABLES -A INPUT -p tcp -m tcp --dport 21 -m state --state NEW -j RULE_28
 $IPTABLES -A RULE_28 -j LOG --log-level debug --log-prefix "RULE 28 - ACCEPT **"
 $IPTABLES -A RULE_28 -j ACCEPT
 #
 # Rule 29 (global)
 #
 echo "Rule 29 (global)"
 #
 # 'catch all' rule
 $IPTABLES -N RULE_29 2>/dev/null
 $IPTABLES -A OUTPUT -j RULE_29
 $IPTABLES -A INPUT -j RULE_29
 $IPTABLES -A FORWARD -j RULE_29
 $IPTABLES -A RULE_29 -j LOG --log-level debug --log-prefix "RULE 29 - DENY **"
 $IPTABLES -A RULE_29 -j DROP
}

ip_forward() {
 :
 echo 1 > /proc/sys/net/ipv4/ip_forward
}

reset_all() {
 :
 command -v nft >/dev/null 2>&1 && nft flush ruleset
 reset_iptables_v4
}

block_action() {
 reset_all
}

stop_action() {
 reset_all
}

status_action() {
 # Full-flush mode: check if iptables has user-defined chains
 # (more than just the three built-in chains INPUT/FORWARD/OUTPUT).
 chains=$($IPTABLES -L -n 2>/dev/null | grep -c "^Chain ")
 [ "$chains" -gt 3 ] && {
 echo "Firewall is active"
 return 0
 }
 echo "Firewall is not configured"
 exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
 cmd="start"
}

case "$cmd" in
 start)
 log "Activating firewall script generated TIMESTAMP"
 check_tools

 check_run_time_address_table_files

 load_modules "nat "
 configure_interfaces
 verify_interfaces

 reset_all

 prolog_commands
 script_body || run_epilog_and_exit 1
 ip_forward

 epilog_commands
 ;;

 stop)
 stop_action
 RETVAL=$?
 ;;

 status)
 status_action
 RETVAL=$?
 ;;

 block)
 block_action
 RETVAL=$?
 ;;

 reload)
 $0 stop
 $0 start
 RETVAL=$?
 ;;

 interfaces)
 configure_interfaces
 RETVAL=$?
 ;;

 test_interfaces)
 FWBDEBUG="echo"
 configure_interfaces
 RETVAL=$?
 ;;

 *)
 echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
 RETVAL=1
 ;;

esac

exit $RETVAL
