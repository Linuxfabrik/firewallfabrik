#!/bin/sh
#
# MANAGED_HEADER
#
# TOOL VERSION
#
# Generated TIMESTAMP
#
# files: * firewall37.fw fwf.sh
#
# Compiled for iptables (any version)
#
# testing TAG and CLASSIFY rules

# normal script mode (not using iptables-restore)

# firewall37:mangle_rules:6: warning: Empty group or address table object 'DNS objects'
# firewall37:mangle_rules:6: warning: After removal of all empty groups rule element src becomes 'any'; dropping rule mangle_rules 6 (global) because option 'Ignore rules with empty groups' is in effect
# firewall37:mangle_rules:7: warning: Empty group or address table object 'empty Ogroup'
# firewall37:mangle_rules:7: warning: After removal of all empty groups rule element src becomes 'any'; dropping rule mangle_rules 7 (global) because option 'Ignore rules with empty groups' is in effect
# firewall37:mangle_rules:15: warning: Empty group or address table object 'DNS objects'
# firewall37:mangle_rules:15: warning: After removal of all empty groups rule element src becomes 'any'; dropping rule mangle_rules 15 (global) because option 'Ignore rules with empty groups' is in effect

FWBDEBUG=""
RETVAL=0

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

LSMOD="lsmod"
MODPROBE="modprobe"
IPTABLES="iptables"
IP6TABLES="ip6tables"
IPTABLES_RESTORE="iptables-restore"
IP6TABLES_RESTORE="ip6tables-restore"
IP="ip"
IFCONFIG="ifconfig"
VCONFIG="vconfig"
BRCTL="brctl"
IFENSLAVE="ifenslave"
IPSET="ipset"
LOGGER="logger"

log() {
 echo "$1"
 command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
 echo $1 | sed 's/\./_/'
}

getaddr_internal() {
 dev=$1
 name=$2
 af=$3
 L=$($IP $af addr show dev $dev | sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
 test -z "$L" && {
 eval "$name=''"
 return
 }
 eval "${name}_list=\"$L\""
}

getnet_internal() {
 dev=$1
 name=$2
 af=$3
 L=$($IP route list proto kernel | grep $dev | grep -v default | sed 's! .*$!!')
 test -z "$L" && {
 eval "$name=''"
 return
 }
 eval "${name}_list=\"$L\""
}

getaddr() {
 getaddr_internal $1 $2 "-4"
}

getaddr6() {
 getaddr_internal $1 $2 "-6"
}

getnet() {
 getnet_internal $1 $2 "-4"
}

getnet6() {
 getnet_internal $1 $2 "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
 NAME=$1
 $IP link show | grep ": $NAME" | while read L; do
 OIFS=$IFS
 IFS=" :"
 set $L
 IFS=$OIFS
 echo $2
 done
}

diff_intf() {
 func=$1
 list1=$2
 list2=$3
 cmd=$4
 for intf in $list1
 do
 echo $list2 | grep -q $intf || {
 # $vlan is absent in list 2
 $func $intf $cmd
 }
 done
}

find_program() {
 PGM=$1
 command -v $PGM >/dev/null 2>&1 || {
 echo "\"$PGM\" not found"
 exit 1
 }
}
check_tools() {
 find_program command
 find_program $IPTABLES
 find_program $MODPROBE
 find_program $IP
}
reset_iptables_v4() {
 local list

 $IPTABLES -P OUTPUT DROP
 $IPTABLES -P INPUT DROP
 $IPTABLES -P FORWARD DROP

 while read table; do
 list=$($IPTABLES -t $table -L -n)
 printf "%s" "$list" | while read c chain rest; do
 if test "X$c" = "XChain" ; then
 $IPTABLES -t $table -F $chain
 fi
 done
 $IPTABLES -t $table -X
 done < /proc/net/ip_tables_names
}

reset_iptables_v6() {
 local list

 $IP6TABLES -P OUTPUT DROP
 $IP6TABLES -P INPUT DROP
 $IP6TABLES -P FORWARD DROP

 while read table; do
 list=$($IP6TABLES -t $table -L -n)
 printf "%s" "$list" | while read c chain rest; do
 if test "X$c" = "XChain" ; then
 $IP6TABLES -t $table -F $chain
 fi
 done
 $IP6TABLES -t $table -X
 done < /proc/net/ip6_tables_names
}

P2P_INTERFACE_WARNING=""

missing_address() {
 address=$1
 cmd=$2

 oldIFS=$IFS
 IFS="@"
 set $address
 addr=$1
 interface=$2
 IFS=$oldIFS

 $IP addr show dev $interface | grep -q POINTOPOINT && {
 test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
 P2P_INTERFACE_WARNING="yes"
 return
 }

 test "$cmd" = "add" && {
 echo "# Adding ip address: $interface $addr"
 echo $addr | grep -q ':' && {
 $FWBDEBUG $IP addr $cmd $addr dev $interface
 } || {
 $FWBDEBUG $IP addr $cmd $addr broadcast + dev $interface
 }
 }

 test "$cmd" = "del" && {
 echo "# Removing ip address: $interface $addr"
 $FWBDEBUG $IP addr $cmd $addr dev $interface || exit 1
 }

 $FWBDEBUG $IP link set $interface up
}

list_addresses_by_scope() {
 interface=$1
 scope=$2
 ignore_list=$3
 $IP addr ls dev $interface | \
 awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
 'BEGIN {
 split(IGNORED,ignored_arr);
 for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
 }
 (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
 while read addr; do
 echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
 ignore_list=$2
 set $1
 interface=$1
 shift

 FWB_ADDRS=$(
 for addr in $*; do
 echo "${addr}@$interface"
 done | sort
 )

 CURRENT_ADDRS_ALL_SCOPES=""
 CURRENT_ADDRS_GLOBAL_SCOPE=""

 $IP link show dev $interface >/dev/null 2>&1 && {
 CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope $interface 'scope .*' "$ignore_list")
 CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope $interface 'scope global' "$ignore_list")
 } || {
 echo "# Interface $interface does not exist"
 # Stop the script if we are not in test mode
 test -z "$FWBDEBUG" && exit 1
 }

 diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
 diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
 $IP link show | sed 's/://g' | awk -v IGNORED="$*" \
 'BEGIN {
 split(IGNORED,ignored_arr);
 for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
 }
 (/state/ && !($2 in ignored_dict)) {print $2;}' | \
 while read intf; do
 echo "# Removing addresses not configured in fwbuilder from interface $intf"
 $FWBDEBUG $IP addr flush dev $intf scope global
 $FWBDEBUG $IP link set $intf down
 done
}

reset_fwf_chains_v4() {
 local prefix="$1"
 local table chain rulenum

 # For each table, remove FWF jump rules from built-in chains (in
 # reverse order to keep line numbers stable), then flush and delete
 # FWF's own chains. We do not check /proc/net/ip_tables_names
 # because it is absent on systems using the iptables-nft backend;
 # instead we query iptables directly and suppress errors.
 for table in filter nat mangle; do
 # Remove jump rules targeting our prefixed chains from built-in chains.
 for chain in INPUT FORWARD OUTPUT PREROUTING POSTROUTING; do
 $IPTABLES -t "$table" -L "$chain" -n --line-numbers 2>/dev/null \
 | grep "${prefix}_" | awk '{print $1}' | sort -rn \
 | while read rulenum; do
 $IPTABLES -t "$table" -D "$chain" "$rulenum" 2>/dev/null
 done
 done

 # Flush all our prefixed chains first, then delete them in a
 # second pass. A single pass fails when sub-chains (e.g.
 # fwf_C...) sort alphabetically before their parent chains
 # (fwf_INPUT) -- the delete would fail because the parent still
 # references the sub-chain.
 $IPTABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read chain; do
 $IPTABLES -t "$table" -F "$chain" 2>/dev/null
 done
 $IPTABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read chain; do
 $IPTABLES -t "$table" -X "$chain" 2>/dev/null
 done
 done
}

reset_fwf_chains_v6() {
 local prefix="$1"
 local table chain rulenum

 for table in filter nat mangle; do
 for chain in INPUT FORWARD OUTPUT PREROUTING POSTROUTING; do
 $IP6TABLES -t "$table" -L "$chain" -n --line-numbers 2>/dev/null \
 | grep "${prefix}_" | awk '{print $1}' | sort -rn \
 | while read rulenum; do
 $IP6TABLES -t "$table" -D "$chain" "$rulenum" 2>/dev/null
 done
 done

 $IP6TABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read chain; do
 $IP6TABLES -t "$table" -F "$chain" 2>/dev/null
 done
 $IP6TABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read chain; do
 $IP6TABLES -t "$table" -X "$chain" 2>/dev/null
 done
 done
}

setup_fwf_jumps_v4() {
 local prefix="$1"

 # Set built-in chain policies to DROP for security.
 $IPTABLES -P INPUT DROP
 $IPTABLES -P FORWARD DROP
 $IPTABLES -P OUTPUT DROP

 # Create our prefixed chains (ignore error if they already exist).
 $IPTABLES -N "${prefix}_INPUT" 2>/dev/null
 $IPTABLES -N "${prefix}_FORWARD" 2>/dev/null
 $IPTABLES -N "${prefix}_OUTPUT" 2>/dev/null

 # Insert jump rules at position 1 (top of chain).
 # Tools that start later (Docker, CrowdSec, fail2ban) will insert
 # their own rules at position 1, pushing ours down. Control the
 # evaluation order via systemd unit ordering.
 $IPTABLES -I INPUT 1 -j "${prefix}_INPUT"
 $IPTABLES -I FORWARD 1 -j "${prefix}_FORWARD"
 $IPTABLES -I OUTPUT 1 -j "${prefix}_OUTPUT"
}

setup_fwf_jumps_v6() {
 local prefix="$1"

 $IP6TABLES -P INPUT DROP
 $IP6TABLES -P FORWARD DROP
 $IP6TABLES -P OUTPUT DROP

 $IP6TABLES -N "${prefix}_INPUT" 2>/dev/null
 $IP6TABLES -N "${prefix}_FORWARD" 2>/dev/null
 $IP6TABLES -N "${prefix}_OUTPUT" 2>/dev/null

 $IP6TABLES -I INPUT 1 -j "${prefix}_INPUT"
 $IP6TABLES -I FORWARD 1 -j "${prefix}_FORWARD"
 $IP6TABLES -I OUTPUT 1 -j "${prefix}_OUTPUT"
}

check_file() {
 test -r "$2" || {
 echo "Can not find file $2 referenced by address table object $1"
 exit 1
 }
}

check_run_time_address_table_files() {
 :

}

load_modules() {
 :
 OPTS=$1
 MODULES_DIR="/lib/modules/`uname -r`/kernel/net/"
 MODULES=$(find $MODULES_DIR -name '*conntrack*' \! -name '*ipv6*'|sed -e 's/^.*\///' -e 's/\([^\.]\)\..*/\1/')
 echo $OPTS | grep -q nat && {
 MODULES="$MODULES $(find $MODULES_DIR -name '*nat*'|sed -e 's/^.*\///' -e 's/\([^\.]\)\..*/\1/')"
 }
 echo $OPTS | grep -q ipv6 && {
 MODULES="$MODULES $(find $MODULES_DIR -name nf_conntrack_ipv6|sed -e 's/^.*\///' -e 's/\([^\.]\)\..*/\1/')"
 }
 for module in $MODULES; do
 if $LSMOD | grep ${module} >/dev/null; then continue; fi
 $MODPROBE ${module} || exit 1
 done
}

verify_interfaces() {
 :

}

prolog_commands() {
 echo "Running prolog script"

}

epilog_commands() {
 echo "Running epilog script"

}

run_epilog_and_exit() {
 epilog_commands
 exit $1
}

configure_interfaces() {
 :
 # Configure interfaces
 update_addresses_of_interface "eth0 192.168.1.22/24" ""
 update_addresses_of_interface "eth1 22.22.23.22/24" ""
 update_addresses_of_interface "eth2 192.168.2.1/24" ""
}

script_body() {
 echo 30 > /proc/sys/net/ipv4/tcp_fin_timeout
 echo 1800 > /proc/sys/net/ipv4/tcp_keepalive_intvl

 # ================ IPv4

 # ================ Table 'filter', automatic rules
 # accept established sessions
 $IPTABLES -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
 $IPTABLES -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
 $IPTABLES -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT
 # ================ Table 'mangle', automatic rules
 $IPTABLES -t mangle -A PREROUTING -j CONNMARK --restore-mark
 $IPTABLES -t mangle -A OUTPUT -j CONNMARK --restore-mark

 # ================ Table 'nat', rule set NAT
 #
 # Rule 0 (NAT)
 #
 echo "Rule 0 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -s 22.22.23.22 -j ACCEPT
 $IPTABLES -t nat -A POSTROUTING -s 192.168.1.22 -j ACCEPT
 $IPTABLES -t nat -A POSTROUTING -s 192.168.2.1 -j ACCEPT
 $IPTABLES -t nat -A OUTPUT -j ACCEPT
 $IPTABLES -t nat -A POSTROUTING -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -t nat -A PREROUTING -s 192.168.1.0/24 -j ACCEPT

 # ================ Table 'mangle', rule set mymark
 #
 # Rule mymark 0 (global)
 #
 echo "Rule mymark 0 (global)"
 #
 $IPTABLES -t mangle -A OUTPUT -d 192.168.2.0/24 -m state --state NEW
 $IPTABLES -t mangle -A PREROUTING -d 192.168.2.0/24 -m state --state NEW
 #
 # Rule mymark 1 (global)
 #
 echo "Rule mymark 1 (global)"
 #
 $IPTABLES -t mangle -A OUTPUT -m state --state NEW
 $IPTABLES -t mangle -A PREROUTING -m state --state NEW
 # ================ Table 'mangle', rule set Policy
 #
 # Rule 0 (global)
 #
 echo "Rule 0 (global)"
 #
 $IPTABLES -t mangle -A OUTPUT -p 50 -m state --state NEW
 $IPTABLES -t mangle -A OUTPUT -p 51 -m state --state NEW
 $IPTABLES -t mangle -A PREROUTING -p 50 -m state --state NEW
 $IPTABLES -t mangle -A PREROUTING -p 51 -m state --state NEW
 #
 # Rule 3 (eth1)
 #
 echo "Rule 3 (eth1)"
 #
 $IPTABLES -t mangle -A OUTPUT -o eth1 -p 50 -m state --state NEW
 $IPTABLES -t mangle -A OUTPUT -o eth1 -p 51 -m state --state NEW
 #
 # Rule 5 (eth1)
 #
 echo "Rule 5 (eth1)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A OUTPUT -o eth1 -s 22.22.23.22 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A CHAIN -p 50
 $IPTABLES -t mangle -A CHAIN -p 51
 #
 # Rule 6 (eth1)
 #
 echo "Rule 6 (eth1)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A OUTPUT -o eth1 -s 22.22.23.22 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A CHAIN -p 50
 $IPTABLES -t mangle -A CHAIN -p 51
 #
 # Rule 8 (eth1)
 #
 echo "Rule 8 (eth1)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A OUTPUT -o eth1 -s 22.22.23.22 -j CHAIN
 $IPTABLES -t mangle -A CHAIN -p 50
 $IPTABLES -t mangle -A CHAIN -p 51
 #
 # Rule 9 (eth1)
 #
 echo "Rule 9 (eth1)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A OUTPUT -o eth1 -s 22.22.23.22 -j CHAIN
 $IPTABLES -t mangle -A CHAIN -p 50
 $IPTABLES -t mangle -A CHAIN -p 51
 #
 # Rule 10 (eth1)
 #
 echo "Rule 10 (eth1)"
 #
 $IPTABLES -t mangle -A OUTPUT -o eth1 -p 50
 $IPTABLES -t mangle -A OUTPUT -o eth1 -p 51
 #
 # Rule 11 (global)
 #
 echo "Rule 11 (global)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A OUTPUT -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A OUTPUT -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A PREROUTING -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A PREROUTING -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN
 #
 # Rule 12 (eth1)
 #
 echo "Rule 12 (eth1)"
 #
 $IPTABLES -t mangle -A PREROUTING -i eth1 -p 50 -m state --state NEW
 $IPTABLES -t mangle -A PREROUTING -i eth1 -p 51 -m state --state NEW
 $IPTABLES -t mangle -A POSTROUTING -o eth1 -p 50 -m state --state NEW
 $IPTABLES -t mangle -A POSTROUTING -o eth1 -p 51 -m state --state NEW
 #
 # Rule 15 (global)
 #
 echo "Rule 15 (global)"
 #
 # using CONNMARK
 $IPTABLES -t mangle -A OUTPUT -p 50 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A OUTPUT -p 51 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A PREROUTING -p 50 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A PREROUTING -p 51 -m state --state NEW -j CONNMARK
 #
 # Rule 17 (global)
 #
 echo "Rule 17 (global)"
 #
 # using CONNMARK
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A OUTPUT -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A OUTPUT -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A PREROUTING -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A PREROUTING -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -t mangle -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN
 $IPTABLES -t mangle -A CHAIN -j CONNMARK
 #
 # Rule 18 (eth1)
 #
 echo "Rule 18 (eth1)"
 #
 # using CONNMARK
 $IPTABLES -t mangle -A PREROUTING -i eth1 -p 50 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A PREROUTING -i eth1 -p 51 -m state --state NEW -j CONNMARK
 #
 # Rule 19 (eth1)
 #
 echo "Rule 19 (eth1)"
 #
 # using CONNMARK
 $IPTABLES -t mangle -A OUTPUT -o eth1 -p 50 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A OUTPUT -o eth1 -p 51 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A POSTROUTING -o eth1 -p 50 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A POSTROUTING -o eth1 -p 51 -m state --state NEW -j CONNMARK
 #
 # Rule 22 (global)
 #
 echo "Rule 22 (global)"
 #
 $IPTABLES -t mangle -A POSTROUTING -s 192.168.1.0/24
 #
 # Rule 24 (global)
 #
 echo "Rule 24 (global)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A POSTROUTING -j CHAIN
 $IPTABLES -t mangle -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN
 #
 # Rule 25 (global)
 #
 echo "Rule 25 (global)"
 #
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A POSTROUTING -j CHAIN
 $IPTABLES -t mangle -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN
 #
 # Rule 26 (eth1)
 #
 echo "Rule 26 (eth1)"
 #
 $IPTABLES -t mangle -A POSTROUTING -i eth1 -s 192.168.1.0/24
 $IPTABLES -t mangle -A POSTROUTING -o eth1 -s 192.168.1.0/24
 #
 # Rule 28 (eth1)
 #
 echo "Rule 28 (eth1)"
 #
 $IPTABLES -t mangle -A POSTROUTING -i ! eth1 -s 192.168.1.0/24
 $IPTABLES -t mangle -A POSTROUTING -o ! eth1 -s 192.168.1.0/24
 #
 # Rule 30 (global)
 #
 echo "Rule 30 (global)"
 #
 $IPTABLES -t mangle -A POSTROUTING -s 192.168.1.22
 #
 # Rule 31 (global)
 #
 echo "Rule 31 (global)"
 #
 # testing for bug #1618381
 # classify action is non-terminating
 # in this firewall object
 $IPTABLES -t mangle -A POSTROUTING -p icmp -m icmp --icmp-type 3
 #
 # Rule 32 (eth0)
 #
 echo "Rule 32 (eth0)"
 #
 # second rule for bug #1618381
 $IPTABLES -t mangle -A POSTROUTING -i eth0
 $IPTABLES -t mangle -A POSTROUTING -o eth0
 #
 # Rule 33 (global)
 #
 echo "Rule 33 (global)"
 #
 # testing for bug #1618381
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A POSTROUTING -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -t mangle -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN
 #
 # Rule 34 (global)
 #
 echo "Rule 34 (global)"
 #
 # testing for bug #1618381
 $IPTABLES -N CHAIN -t mangle 2>/dev/null
 $IPTABLES -t mangle -A POSTROUTING -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -t mangle -A POSTROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t mangle -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -t mangle -A CHAIN
 #
 # Rule 35 (eth0)
 #
 echo "Rule 35 (eth0)"
 #
 # bug #1618381
 # this rule uses multiport
 # and has to be split because
 # of that
 $IPTABLES -t mangle -A POSTROUTING -i eth0 -p tcp -m tcp --dport 10000:11000
 $IPTABLES -t mangle -A POSTROUTING -i eth0 -p tcp -m tcp -m multiport --dports 113,13,53,2105,21,70,80,443,6667,119,25,3128,22,23,540
 $IPTABLES -t mangle -A POSTROUTING -i eth0 -p udp -m udp -m multiport --dports 53,161
 $IPTABLES -t mangle -A POSTROUTING -o eth0 -p tcp -m tcp --dport 10000:11000
 $IPTABLES -t mangle -A POSTROUTING -o eth0 -p tcp -m tcp -m multiport --dports 113,13,53,2105,21,70,80,443,6667,119,25,3128,22,23,540
 $IPTABLES -t mangle -A POSTROUTING -o eth0 -p udp -m udp -m multiport --dports 53,161
 #
 # Rule 37 (global)
 #
 echo "Rule 37 (global)"
 #
 $IPTABLES -t mangle -A OUTPUT
 $IPTABLES -t mangle -A INPUT
 $IPTABLES -t mangle -A FORWARD
 # ================ Table 'mangle', rule set mangle_rules
 #
 # Rule mangle_rules 1 (global)
 #
 echo "Rule mangle_rules 1 (global)"
 #
 $IPTABLES -t mangle -A OUTPUT -p tcp -m tcp --dport 80 -m state --state NEW
 $IPTABLES -t mangle -A PREROUTING -p tcp -m tcp --dport 80 -m state --state NEW
 $IPTABLES -t mangle -A OUTPUT -p tcp -m tcp --dport 80 -m state --state NEW -j CONNMARK
 $IPTABLES -t mangle -A PREROUTING -p tcp -m tcp --dport 80 -m state --state NEW -j CONNMARK
 #
 # Rule mangle_rules 2 (global)
 #
 echo "Rule mangle_rules 2 (global)"
 #
 $IPTABLES -t mangle -A POSTROUTING

 # ================ Table 'filter', rule set mymark
 #
 # Rule mymark 0 (global)
 #
 echo "Rule mymark 0 (global)"
 #
 $IPTABLES -A OUTPUT -d 192.168.2.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -d 192.168.2.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -d 192.168.2.0/24 -m state --state NEW -j ACCEPT
 #
 # Rule mymark 1 (global)
 #
 echo "Rule mymark 1 (global)"
 #
 $IPTABLES -A OUTPUT -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -m state --state NEW -j ACCEPT
 # ================ Table 'filter', rule set Policy
 #
 # Rule 0 (global)
 #
 echo "Rule 0 (global)"
 #
 $IPTABLES -A OUTPUT -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -p 51 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -p 51 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p 51 -m state --state NEW -j ACCEPT
 #
 # Rule 1 (global)
 #
 echo "Rule 1 (global)"
 #
 $IPTABLES -N RULE_1 2>/dev/null
 $IPTABLES -A OUTPUT -p 50 -m state --state NEW -j RULE_1
 $IPTABLES -A OUTPUT -p 51 -m state --state NEW -j RULE_1
 $IPTABLES -A INPUT -p 50 -m state --state NEW -j RULE_1
 $IPTABLES -A INPUT -p 51 -m state --state NEW -j RULE_1
 $IPTABLES -A FORWARD -p 50 -m state --state NEW -j RULE_1
 $IPTABLES -A FORWARD -p 51 -m state --state NEW -j RULE_1
 $IPTABLES -A RULE_1 -j LOG --log-level info --log-prefix "RULE 1 -- ACCEPT "
 $IPTABLES -A RULE_1 -j ACCEPT
 #
 # Rule 2 (global)
 #
 echo "Rule 2 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -s 192.168.1.22 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -p 50 -j ACCEPT
 $IPTABLES -A CHAIN -p 51 -j ACCEPT
 #
 # Rule 3 (eth1)
 #
 echo "Rule 3 (eth1)"
 #
 $IPTABLES -A OUTPUT -o eth1 -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -o eth1 -p 51 -m state --state NEW -j ACCEPT
 #
 # Rule 4 (global)
 #
 echo "Rule 4 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -s 192.168.1.22 -m state --state NEW -j CHAIN
 $IPTABLES -N RULE_4 2>/dev/null
 $IPTABLES -A CHAIN -p 50 -j RULE_4
 $IPTABLES -A CHAIN -p 51 -j RULE_4
 $IPTABLES -A OUTPUT -p 50 -m state --state NEW -j RULE_4
 $IPTABLES -A OUTPUT -p 51 -m state --state NEW -j RULE_4
 $IPTABLES -A RULE_4 -j LOG --log-level info --log-prefix "RULE 4 -- ACCEPT "
 $IPTABLES -A RULE_4 -j ACCEPT
 #
 # Rule 5 (eth1)
 #
 echo "Rule 5 (eth1)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -o eth1 -s 22.22.23.22 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -p 50 -j ACCEPT
 $IPTABLES -A CHAIN -p 51 -j ACCEPT
 #
 # Rule 6 (eth1)
 #
 echo "Rule 6 (eth1)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -o eth1 -s 22.22.23.22 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -p 50 -j ACCEPT
 $IPTABLES -A CHAIN -p 51 -j ACCEPT
 #
 # Rule 8 (eth1)
 #
 echo "Rule 8 (eth1)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -o eth1 -s 22.22.23.22 -j CHAIN
 $IPTABLES -A CHAIN -p 50 -j ACCEPT
 $IPTABLES -A CHAIN -p 51 -j ACCEPT
 #
 # Rule 9 (eth1)
 #
 echo "Rule 9 (eth1)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -o eth1 -s 22.22.23.22 -j CHAIN
 $IPTABLES -A CHAIN -p 50 -j ACCEPT
 $IPTABLES -A CHAIN -p 51 -j ACCEPT
 #
 # Rule 10 (eth1)
 #
 echo "Rule 10 (eth1)"
 #
 $IPTABLES -A OUTPUT -o eth1 -p 50 -j ACCEPT
 $IPTABLES -A OUTPUT -o eth1 -p 51 -j ACCEPT
 #
 # Rule 11 (global)
 #
 echo "Rule 11 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -A OUTPUT -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -N RULE_11 2>/dev/null
 $IPTABLES -A CHAIN -j RULE_11
 $IPTABLES -A RULE_11 -j LOG --log-level info --log-prefix "RULE 11 -- ACCEPT "
 $IPTABLES -A RULE_11 -j ACCEPT
 #
 # Rule 12 (eth1)
 #
 echo "Rule 12 (eth1)"
 #
 $IPTABLES -A INPUT -i eth1 -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -i eth1 -p 51 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i eth1 -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i eth1 -p 51 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth1 -p 50 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth1 -p 51 -m state --state NEW -j ACCEPT
 #
 # Rule 16 (global)
 #
 echo "Rule 16 (global)"
 #
 # using CONNMARK
 $IPTABLES -N RULE_16 2>/dev/null
 $IPTABLES -A OUTPUT -p 50 -m state --state NEW -j RULE_16
 $IPTABLES -A OUTPUT -p 51 -m state --state NEW -j RULE_16
 $IPTABLES -A INPUT -p 50 -m state --state NEW -j RULE_16
 $IPTABLES -A INPUT -p 51 -m state --state NEW -j RULE_16
 $IPTABLES -A FORWARD -p 50 -m state --state NEW -j RULE_16
 $IPTABLES -A FORWARD -p 51 -m state --state NEW -j RULE_16
 $IPTABLES -A RULE_16 -j LOG --log-level info --log-prefix "RULE 16 -- ACCEPT "
 $IPTABLES -A RULE_16 -j ACCEPT
 #
 # Rule 17 (global)
 #
 echo "Rule 17 (global)"
 #
 # using CONNMARK
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -A OUTPUT -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p 50 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p 51 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -N RULE_17 2>/dev/null
 $IPTABLES -A CHAIN -j RULE_17
 $IPTABLES -A RULE_17 -j LOG --log-level info --log-prefix "RULE 17 -- ACCEPT "
 $IPTABLES -A RULE_17 -j ACCEPT
 #
 # Rule 20 (global)
 #
 echo "Rule 20 (global)"
 #
 # tag 0 matches packet that has not been marked yet.
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 21 (global)
 #
 echo "Rule 21 (global)"
 #
 $IPTABLES -A OUTPUT -p tcp -m tcp -d 192.168.2.10 --dport 80 -j QUEUE
 $IPTABLES -A FORWARD -p tcp -m tcp -d 192.168.2.10 --dport 80 -j QUEUE
 #
 # Rule 22 (global)
 #
 echo "Rule 22 (global)"
 #
 $IPTABLES -A INPUT -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A OUTPUT -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A FORWARD -s 192.168.1.0/24 -j ACCEPT
 #
 # Rule 23 (global)
 #
 echo "Rule 23 (global)"
 #
 $IPTABLES -N RULE_23 2>/dev/null
 $IPTABLES -A INPUT -s 192.168.1.0/24 -j RULE_23
 $IPTABLES -A OUTPUT -s 192.168.1.0/24 -j RULE_23
 $IPTABLES -A FORWARD -s 192.168.1.0/24 -j RULE_23
 $IPTABLES -A RULE_23 -j LOG --log-level info --log-prefix "RULE 23 -- ACCEPT "
 $IPTABLES -A RULE_23 -j ACCEPT
 #
 # Rule 24 (global)
 #
 echo "Rule 24 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -j CHAIN
 $IPTABLES -A INPUT -j CHAIN
 $IPTABLES -A FORWARD -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 25 (global)
 #
 echo "Rule 25 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -j CHAIN
 $IPTABLES -A INPUT -j CHAIN
 $IPTABLES -A FORWARD -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -N RULE_25 2>/dev/null
 $IPTABLES -A CHAIN -j RULE_25
 $IPTABLES -A RULE_25 -j LOG --log-level info --log-prefix "RULE 25 -- ACCEPT "
 $IPTABLES -A RULE_25 -j ACCEPT
 #
 # Rule 26 (eth1)
 #
 echo "Rule 26 (eth1)"
 #
 $IPTABLES -A INPUT -i eth1 -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A FORWARD -i eth1 -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A OUTPUT -o eth1 -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A FORWARD -o eth1 -s 192.168.1.0/24 -j ACCEPT
 #
 # Rule 27 (eth1)
 #
 echo "Rule 27 (eth1)"
 #
 $IPTABLES -N In_RULE_27 2>/dev/null
 $IPTABLES -A INPUT -i eth1 -s 192.168.1.0/24 -j In_RULE_27
 $IPTABLES -A FORWARD -i eth1 -s 192.168.1.0/24 -j In_RULE_27
 $IPTABLES -A In_RULE_27 -j LOG --log-level info --log-prefix "RULE 27 -- ACCEPT "
 $IPTABLES -A In_RULE_27 -j ACCEPT
 $IPTABLES -N Out_RULE_27 2>/dev/null
 $IPTABLES -A OUTPUT -o eth1 -s 192.168.1.0/24 -j Out_RULE_27
 $IPTABLES -A FORWARD -o eth1 -s 192.168.1.0/24 -j Out_RULE_27
 $IPTABLES -A Out_RULE_27 -j LOG --log-level info --log-prefix "RULE 27 -- ACCEPT "
 $IPTABLES -A Out_RULE_27 -j ACCEPT
 #
 # Rule 28 (eth1)
 #
 echo "Rule 28 (eth1)"
 #
 $IPTABLES -A INPUT -i ! eth1 -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A FORWARD -i ! eth1 -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A OUTPUT -o ! eth1 -s 192.168.1.0/24 -j ACCEPT
 $IPTABLES -A FORWARD -o ! eth1 -s 192.168.1.0/24 -j ACCEPT
 #
 # Rule 29 (eth1)
 #
 echo "Rule 29 (eth1)"
 #
 $IPTABLES -N In_RULE_29 2>/dev/null
 $IPTABLES -A INPUT -i ! eth1 -s 192.168.1.0/24 -j In_RULE_29
 $IPTABLES -A FORWARD -i ! eth1 -s 192.168.1.0/24 -j In_RULE_29
 $IPTABLES -A In_RULE_29 -j LOG --log-level info --log-prefix "RULE 29 -- ACCEPT "
 $IPTABLES -A In_RULE_29 -j ACCEPT
 $IPTABLES -N Out_RULE_29 2>/dev/null
 $IPTABLES -A OUTPUT -o ! eth1 -s 192.168.1.0/24 -j Out_RULE_29
 $IPTABLES -A FORWARD -o ! eth1 -s 192.168.1.0/24 -j Out_RULE_29
 $IPTABLES -A Out_RULE_29 -j LOG --log-level info --log-prefix "RULE 29 -- ACCEPT "
 $IPTABLES -A Out_RULE_29 -j ACCEPT
 #
 # Rule 31 (global)
 #
 echo "Rule 31 (global)"
 #
 # testing for bug #1618381
 # classify action is non-terminating
 # in this firewall object
 $IPTABLES -A OUTPUT -p icmp -m icmp --icmp-type 3 -j ACCEPT
 $IPTABLES -A INPUT -p icmp -m icmp --icmp-type 3 -j ACCEPT
 $IPTABLES -A FORWARD -p icmp -m icmp --icmp-type 3 -j ACCEPT
 #
 # Rule 32 (eth0)
 #
 echo "Rule 32 (eth0)"
 #
 # second rule for bug #1618381
 $IPTABLES -A INPUT -i eth0 -j ACCEPT
 $IPTABLES -A FORWARD -i eth0 -j ACCEPT
 $IPTABLES -A OUTPUT -o eth0 -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -j ACCEPT
 #
 # Rule 33 (global)
 #
 echo "Rule 33 (global)"
 #
 # testing for bug #1618381
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -A INPUT -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -A FORWARD -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 34 (global)
 #
 echo "Rule 34 (global)"
 #
 # testing for bug #1618381
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -A OUTPUT -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -A INPUT -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -A INPUT -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -A FORWARD -p icmp -m icmp --icmp-type 3 -j CHAIN
 $IPTABLES -A FORWARD -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.0/24 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 35 (eth0)
 #
 echo "Rule 35 (eth0)"
 #
 # bug #1618381
 # this rule uses multiport
 # and has to be split because
 # of that
 $IPTABLES -A INPUT -i eth0 -p tcp -m tcp --dport 10000:11000 -j ACCEPT
 $IPTABLES -A INPUT -i eth0 -p tcp -m tcp -m multiport --dports 113,13,53,2105,21,70,80,443,6667,119,25,3128,22,23,540 -j ACCEPT
 $IPTABLES -A INPUT -i eth0 -p udp -m udp -m multiport --dports 53,161 -j ACCEPT
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp --dport 10000:11000 -j ACCEPT
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp -m multiport --dports 113,13,53,2105,21,70,80,443,6667,119,25,3128,22,23,540 -j ACCEPT
 $IPTABLES -A FORWARD -i eth0 -p udp -m udp -m multiport --dports 53,161 -j ACCEPT
 $IPTABLES -A OUTPUT -o eth0 -p tcp -m tcp --dport 10000:11000 -j ACCEPT
 $IPTABLES -A OUTPUT -o eth0 -p tcp -m tcp -m multiport --dports 113,13,53,2105,21,70,80,443,6667,119,25,3128,22,23,540 -j ACCEPT
 $IPTABLES -A OUTPUT -o eth0 -p udp -m udp -m multiport --dports 53,161 -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp --dport 10000:11000 -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp -m multiport --dports 113,13,53,2105,21,70,80,443,6667,119,25,3128,22,23,540 -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p udp -m udp -m multiport --dports 53,161 -j ACCEPT
 #
 # Rule 36 (global)
 #
 echo "Rule 36 (global)"
 #
 $IPTABLES -A INPUT -s 192.168.1.0/24
 $IPTABLES -A OUTPUT -s 192.168.1.0/24
 $IPTABLES -A FORWARD -s 192.168.1.0/24
 #
 # Rule 37 (global)
 #
 echo "Rule 37 (global)"
 #
 $IPTABLES -N RULE_37 2>/dev/null
 $IPTABLES -A OUTPUT -j RULE_37
 $IPTABLES -A INPUT -j RULE_37
 $IPTABLES -A FORWARD -j RULE_37
 $IPTABLES -A RULE_37 -j LOG --log-level info --log-prefix "RULE 37 -- BRANCH "
 $IPTABLES -A RULE_37
 #
 # Rule 38 (global)
 #
 echo "Rule 38 (global)"
 #
 $IPTABLES -N RULE_38 2>/dev/null
 $IPTABLES -A OUTPUT -j RULE_38
 $IPTABLES -A INPUT -j RULE_38
 $IPTABLES -A FORWARD -j RULE_38
 $IPTABLES -A RULE_38 -j LOG --log-level info --log-prefix "RULE 38 -- DENY "
 $IPTABLES -A RULE_38 -j DROP
 # ================ Table 'filter', rule set mangle_rules
 #
 # Rule mangle_rules 0 (global)
 #
 echo "Rule mangle_rules 0 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule mangle_rules 1 (global)
 #
 echo "Rule mangle_rules 1 (global)"
 #
 $IPTABLES -A OUTPUT -p tcp -m tcp --dport 80 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -p tcp -m tcp --dport 80 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -p tcp -m tcp --dport 80 -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 2 (global)
 #
 echo "Rule mangle_rules 2 (global)"
 #
 $IPTABLES -A OUTPUT -j ACCEPT
 $IPTABLES -A INPUT -j ACCEPT
 $IPTABLES -A FORWARD -j ACCEPT
 #
 # Rule mangle_rules 4 (global)
 #
 echo "Rule mangle_rules 4 (global)"
 #
 $IPTABLES -A INPUT -s 157.112.176.24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -s 157.112.176.24 -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 5 (global)
 #
 echo "Rule mangle_rules 5 (global)"
 #
 $IPTABLES -A INPUT -s 6bone.net -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -s 6bone.net -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 8 (global)
 #
 echo "Rule mangle_rules 8 (global)"
 #
 $IPTABLES -A INPUT -s 192.168.1.22 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 9 (global)
 #
 echo "Rule mangle_rules 9 (global)"
 #
 $IPTABLES -A INPUT -s 22.22.23.22 -m state --state NEW -j ACCEPT
 $IPTABLES -A OUTPUT -s 22.22.23.22 -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 10 (global)
 #
 echo "Rule mangle_rules 10 (global)"
 #
 $IPTABLES -A OUTPUT -d 192.168.1.22 -m state --state NEW -j ACCEPT
 $IPTABLES -A INPUT -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 11 (global)
 #
 echo "Rule mangle_rules 11 (global)"
 #
 $IPTABLES -A INPUT -s ! 192.168.1.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i + -s ! 192.168.1.0/24 -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 12 (global)
 #
 echo "Rule mangle_rules 12 (global)"
 #
 $IPTABLES -A INPUT -s ! 1.1.1.1 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i + -s ! 1.1.1.1 -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 13 (global)
 #
 echo "Rule mangle_rules 13 (global)"
 #
 $IPTABLES -A INPUT -s ! 157.112.176.24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -i + -s ! 157.112.176.24 -m state --state NEW -j ACCEPT
 #
 # Rule mangle_rules 14 (global)
 #
 echo "Rule mangle_rules 14 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -i + -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 6bone.net -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
}

ip_forward() {
 :

}

reset_all() {
 :
 command -v nft >/dev/null 2>&1 && nft flush ruleset
 reset_iptables_v4
}

block_action() {
 reset_all
}

stop_action() {
 reset_all
}

status_action() {
 # Full-flush mode: check if iptables has user-defined chains
 # (more than just the three built-in chains INPUT/FORWARD/OUTPUT).
 chains=$($IPTABLES -L -n 2>/dev/null | grep -c "^Chain ")
 [ "$chains" -gt 3 ] && {
 echo "Firewall is active"
 return 0
 }
 echo "Firewall is not configured"
 exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
 cmd="start"
}

case "$cmd" in
 start)
 log "Activating firewall script generated TIMESTAMP"
 check_tools
 prolog_commands
 check_run_time_address_table_files

 load_modules "nat "
 configure_interfaces
 verify_interfaces

 reset_all


 script_body || run_epilog_and_exit 1
 ip_forward

 epilog_commands
 ;;

 stop)
 stop_action
 RETVAL=$?
 ;;

 status)
 status_action
 RETVAL=$?
 ;;

 block)
 block_action
 RETVAL=$?
 ;;

 reload)
 $0 stop
 $0 start
 RETVAL=$?
 ;;

 interfaces)
 configure_interfaces
 RETVAL=$?
 ;;

 test_interfaces)
 FWBDEBUG="echo"
 configure_interfaces
 RETVAL=$?
 ;;

 *)
 echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
 RETVAL=1
 ;;

esac

exit $RETVAL
