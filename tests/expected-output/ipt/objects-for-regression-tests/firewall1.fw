 echo "Rule 32 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.1.1 --dport 80 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.1 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 $IPTABLES -A OUTPUT -p tcp -m tcp --dport 80 -m state --state NEW -j ACCEPT
 #
 # Rule 33 (global)
 #
 echo "Rule 33 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.1.1 --dport 22 -m state --state NEW -j CHAIN
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.2.0/24 --dport 22 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.1 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -p tcp -m tcp --dport 22 -m state --state NEW -j CHAIN
 $IPTABLES -A OUTPUT -p tcp -m tcp -s 192.168.2.0/24 --dport 22 -m state --state NEW -j CHAIN
 $IPTABLES -A FORWARD -p tcp -m tcp -s 192.168.2.0/24 --dport 22 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 #
 # Rule 34 (global)
 #
 echo "Rule 34 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -p 1 -j CHAIN
 $IPTABLES -A INPUT -p 50 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -s 22.22.22.22 -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.1 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -p 1 -j CHAIN
 $IPTABLES -A FORWARD -p 50 -j CHAIN
 $IPTABLES -A CHAIN -s 22.22.22.22 -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.1 -j CHAIN
 $IPTABLES -A CHAIN -d 22.22.22.22 -j RETURN
 $IPTABLES -A CHAIN -d 192.168.1.1 -j RETURN
 $IPTABLES -N RULE_34 2>/dev/null
 $IPTABLES -A CHAIN -j RULE_34
 $IPTABLES -A RULE_34 -j LOG --log-level debug
 $IPTABLES -A RULE_34 -j DROP
 #
 # Rule 35 (global)
 #
 echo "Rule 35 (global)"
 #
 # double negation rule
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -j CHAIN
 $IPTABLES -A INPUT -j CHAIN
 $IPTABLES -A FORWARD -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -d 192.168.1.10 -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.20 -j CHAIN
 $IPTABLES -A CHAIN -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -p tcp -m tcp -m multiport --dports 3128,8080 -j CHAIN
 $IPTABLES -A CHAIN -j RETURN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -j CHAIN
 $IPTABLES -A CHAIN -j RETURN
 $IPTABLES -N RULE_35 2>/dev/null
 $IPTABLES -A CHAIN -j RULE_35
 $IPTABLES -A RULE_35 -j LOG --log-level debug
 $IPTABLES -A RULE_35 -j DROP
 #
 # Rule 36 (global)
 #
 echo "Rule 36 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 192.168.1.1 -j RETURN
 $IPTABLES -A CHAIN -d 192.168.2.1 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 $IPTABLES -A OUTPUT -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -m state --state NEW -j ACCEPT
 #
 # Rule 37 (global)
 #
 echo "Rule 37 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -d 192.168.1.0/24 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 192.168.1.1 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.2.1 -j RETURN
 $IPTABLES -A CHAIN -j ACCEPT
 $IPTABLES -A INPUT -d 192.168.1.0/24 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -d 192.168.1.0/24 -m state --state NEW -j ACCEPT
 #
 # Rule 38 (global)
 #
 echo "Rule 38 (global)"
 #
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.1.0/24 --dport 25 -m state --state NEW -m time --timestart 00:00 --timestop 23:59 --weekdays Sat -j ACCEPT
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.1.0/24 --dport 25 -m state --state NEW -m time --timestart 00:00 --timestop 23:59 --weekdays Sun -j ACCEPT
 $IPTABLES -A OUTPUT -p tcp -m tcp -s 192.168.1.0/24 --dport 25 -m state --state NEW -m time --timestart 00:00 --timestop 23:59 --weekdays Sat -j ACCEPT
 $IPTABLES -A OUTPUT -p tcp -m tcp -s 192.168.1.0/24 --dport 25 -m state --state NEW -m time --timestart 00:00 --timestop 23:59 --weekdays Sun -j ACCEPT
 $IPTABLES -A FORWARD -p tcp -m tcp -s 192.168.1.0/24 --dport 25 -m state --state NEW -m time --timestart 00:00 --timestop 23:59 --weekdays Sat -j ACCEPT
 $IPTABLES -A FORWARD -p tcp -m tcp -s 192.168.1.0/24 --dport 25 -m state --state NEW -m time --timestart 00:00 --timestop 23:59 --weekdays Sun -j ACCEPT
 #
 # Rule 39 (global)
 #
 echo "Rule 39 (global)"
 #
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -m state --state NEW -m time --timestart 09:00 --timestop 17:00 --weekdays Mon,Tue,Wed,Thu,Fri -j ACCEPT
 $IPTABLES -A OUTPUT -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -m state --state NEW -m time --timestart 09:00 --timestop 17:00 --weekdays Mon,Tue,Wed,Thu,Fri -j ACCEPT
 $IPTABLES -A FORWARD -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -m state --state NEW -m time --timestart 09:00 --timestop 17:00 --weekdays Mon,Tue,Wed,Thu,Fri -j ACCEPT
 #
 # Rule 40 (global)
 #
 echo "Rule 40 (global)"
 #
 $IPTABLES -A INPUT -p tcp -m tcp -s 192.168.1.1 -d ! 192.168.1.0/24 --dport 80 -j DROP
 $IPTABLES -A OUTPUT -p tcp -m tcp -d ! 192.168.1.0/24 --dport 80 -j DROP
 #
 # Rule 41 (global)
 #
 echo "Rule 41 (global)"
 #
 $IPTABLES -A OUTPUT -p tcp -m tcp -s ! 192.168.1.0/24 -d 192.168.1.1 --dport 80 -j DROP
 $IPTABLES -A INPUT -p tcp -m tcp -s ! 192.168.1.0/24 --dport 80 -j DROP
}

ip_forward() {
 :

}

reset_all() {
 :
 command -v nft >/dev/null 2>&1 && nft flush ruleset
 reset_iptables_v4
}

block_action() {
 reset_all
}

stop_action() {
 reset_all
}

status_action() {
 # Full-flush mode: check if iptables has user-defined chains
 # (more than just the three built-in chains INPUT/FORWARD/OUTPUT).
 chains=$($IPTABLES -L -n 2>/dev/null | grep -c "^Chain ")
 [ "$chains" -gt 3 ] && {
 echo "Firewall is active"
 return 0
 }
 echo "Firewall is not configured"
 exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
 cmd="start"
}

case "$cmd" in
 start)
 log "Activating firewall script generated TIMESTAMP"
 check_tools

 check_run_time_address_table_files

 load_modules "nat "
 configure_interfaces
 verify_interfaces
 prolog_commands
 reset_all


 script_body || run_epilog_and_exit 1
 ip_forward

 epilog_commands
 ;;

 stop)
 stop_action
 RETVAL=$?
 ;;

 status)
 status_action
 RETVAL=$?
 ;;

 block)
 block_action
 RETVAL=$?
 ;;

 reload)
 $0 stop
 $0 start
 RETVAL=$?
 ;;

 interfaces)
 configure_interfaces
 RETVAL=$?
 ;;

 test_interfaces)
 FWBDEBUG="echo"
 configure_interfaces
 RETVAL=$?
 ;;

 *)
 echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
 RETVAL=1
 ;;

esac

exit $RETVAL
