#!/bin/sh
# shellcheck disable=SC2034,SC2329
#
# MANAGED_HEADER
#
# TOOL VERSION
#
# Generated TIMESTAMP
#
# files: * firewall1.fw /etc/fw/firewall1.fw
#
# Compiled for iptables (any version)
#
# this object is used to test all kinds of negation in policy and NAT rules.
# Assume firewall is part of any is ON

# Rule 30 (global): Negation in time is not supported by this platform
# Rule 30 (global): Negation in time is not supported by this platform
# Rule 30 (global): Negation in time is not supported by this platform
# Rule 31 (global): Negation in time is not supported by this platform
# Rule 31 (global): Negation in time is not supported by this platform
# Rule 31 (global): Negation in time is not supported by this platform
# Rule 38 (global): Negation in time is not supported by this platform
# Rule 39 (global): Negation in time is not supported by this platform

FWBDEBUG=""
RETVAL=0

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

LSMOD="lsmod"
MODPROBE="modprobe"
IPTABLES="iptables"
IP6TABLES="ip6tables"
IPTABLES_RESTORE="iptables-restore"
IP6TABLES_RESTORE="ip6tables-restore"
IP="ip"
IFCONFIG="ifconfig"
VCONFIG="vconfig"
BRCTL="brctl"
IFENSLAVE="ifenslave"
IPSET="ipset"
LOGGER="logger"

log() {
 echo "$1"
 command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
 echo "$1" | sed 's/\./_/'
}

getaddr_internal() {
 dev=$1
 name=$2
 af=$3
 L=$("$IP" "$af" addr show dev "$dev" | sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
 test -z "$L" && {
 eval "$name=''"
 return
 }
 eval "${name}_list=\"$L\""
}

getnet_internal() {
 dev=$1
 name=$2
 af=$3
 L=$("$IP" route list proto kernel | grep "$dev" | grep -v default | sed 's! .*$!!')
 test -z "$L" && {
 eval "$name=''"
 return
 }
 eval "${name}_list=\"$L\""
}

getaddr() {
 getaddr_internal "$1" "$2" "-4"
}

getaddr6() {
 getaddr_internal "$1" "$2" "-6"
}

getnet() {
 getnet_internal "$1" "$2" "-4"
}

getnet6() {
 getnet_internal "$1" "$2" "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
 NAME=$1
 "$IP" link show | grep ": $NAME" | while read -r L; do
 OIFS=$IFS
 IFS=" :"
 # shellcheck disable=SC2086
 set -- $L
 IFS=$OIFS
 echo "$2"
 done
}

diff_intf() {
 func=$1
 list1=$2
 list2=$3
 cmd=$4
 for intf in $list1
 do
 echo "$list2" | grep -q "$intf" || {
 # $intf is absent in list 2
 "$func" "$intf" "$cmd"
 }
 done
}

find_program() {
 PGM=$1
 command -v "$PGM" >/dev/null 2>&1 || {
 echo "\"$PGM\" not found"
 exit 1
 }
}
check_tools() {
 find_program command
 find_program "$IPTABLES"
 find_program "$IP"
}
reset_iptables_v4() {
 $IPTABLES -P OUTPUT DROP
 $IPTABLES -P INPUT DROP
 $IPTABLES -P FORWARD DROP

 while read -r table; do
 list=$($IPTABLES -t "$table" -L -n)
 printf "%s" "$list" | while read -r c chain rest; do
 if test "$c" = "Chain" ; then
 $IPTABLES -t "$table" -F "$chain"
 fi
 done
 $IPTABLES -t "$table" -X
 done < /proc/net/ip_tables_names
}

reset_iptables_v6() {
 $IP6TABLES -P OUTPUT DROP
 $IP6TABLES -P INPUT DROP
 $IP6TABLES -P FORWARD DROP

 while read -r table; do
 list=$($IP6TABLES -t "$table" -L -n)
 printf "%s" "$list" | while read -r c chain rest; do
 if test "$c" = "Chain" ; then
 $IP6TABLES -t "$table" -F "$chain"
 fi
 done
 $IP6TABLES -t "$table" -X
 done < /proc/net/ip6_tables_names
}

P2P_INTERFACE_WARNING=""

missing_address() {
 address=$1
 cmd=$2

 oldIFS=$IFS
 IFS="@"
 # shellcheck disable=SC2086
 set -- $address
 addr=$1
 interface=$2
 IFS=$oldIFS

 "$IP" addr show dev "$interface" | grep -q POINTOPOINT && {
 test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
 P2P_INTERFACE_WARNING="yes"
 return
 }

 test "$cmd" = "add" && {
 echo "# Adding ip address: $interface $addr"
 if echo "$addr" | grep -q ':'; then
 $FWBDEBUG "$IP" addr "$cmd" "$addr" dev "$interface"
 else
 $FWBDEBUG "$IP" addr "$cmd" "$addr" broadcast + dev "$interface"
 fi
 }

 test "$cmd" = "del" && {
 echo "# Removing ip address: $interface $addr"
 $FWBDEBUG "$IP" addr "$cmd" "$addr" dev "$interface" || exit 1
 }

 $FWBDEBUG "$IP" link set "$interface" up
}

list_addresses_by_scope() {
 interface=$1
 scope=$2
 ignore_list=$3
 "$IP" addr ls dev "$interface" | \
 awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
 'BEGIN {
 split(IGNORED,ignored_arr);
 for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
 }
 (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
 while read -r addr; do
 echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
 ignore_list=$2
 # shellcheck disable=SC2086
 set -- $1
 interface=$1
 shift

 FWB_ADDRS=$(
 for addr in "$@"; do
 echo "${addr}@$interface"
 done | sort
 )

 CURRENT_ADDRS_ALL_SCOPES=""
 CURRENT_ADDRS_GLOBAL_SCOPE=""

 if "$IP" link show dev "$interface" >/dev/null 2>&1; then
 CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope "$interface" 'scope .*' "$ignore_list")
 CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope "$interface" 'scope global' "$ignore_list")
 else
 echo "# Interface $interface does not exist"
 # Stop the script if we are not in test mode
 test -z "$FWBDEBUG" && exit 1
 fi

 diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
 diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
 "$IP" link show | sed 's/://g' | awk -v IGNORED="$*" \
 'BEGIN {
 split(IGNORED,ignored_arr);
 for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
 }
 (/state/ && !($2 in ignored_dict)) {print $2;}' | \
 while read -r intf; do
 echo "# Removing addresses not configured in fwbuilder from interface $intf"
 $FWBDEBUG "$IP" addr flush dev "$intf" scope global
 $FWBDEBUG "$IP" link set "$intf" down
 done
}

reset_fwf_chains_v4() {
 prefix="$1"

 # For each table, remove FWF jump rules from built-in chains (in
 # reverse order to keep line numbers stable), then flush and delete
 # FWF's own chains. We do not check /proc/net/ip_tables_names
 # because it is absent on systems using the iptables-nft backend;
 # instead we query iptables directly and suppress errors.
 for table in filter nat mangle; do
 # Remove jump rules targeting our prefixed chains from built-in chains.
 for chain in INPUT FORWARD OUTPUT PREROUTING POSTROUTING; do
 $IPTABLES -t "$table" -L "$chain" -n --line-numbers 2>/dev/null \
 | grep "${prefix}_" | awk '{print $1}' | sort -rn \
 | while read -r rulenum; do
 $IPTABLES -t "$table" -D "$chain" "$rulenum" 2>/dev/null
 done
 done

 # Flush all our prefixed chains first, then delete them in a
 # second pass. A single pass fails when sub-chains (e.g.
 # fwf_C...) sort alphabetically before their parent chains
 # (fwf_INPUT) -- the delete would fail because the parent still
 # references the sub-chain.
 $IPTABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read -r chain; do
 $IPTABLES -t "$table" -F "$chain" 2>/dev/null
 done
 $IPTABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read -r chain; do
 $IPTABLES -t "$table" -X "$chain" 2>/dev/null
 done
 done
}

reset_fwf_chains_v6() {
 prefix="$1"

 for table in filter nat mangle; do
 for chain in INPUT FORWARD OUTPUT PREROUTING POSTROUTING; do
 $IP6TABLES -t "$table" -L "$chain" -n --line-numbers 2>/dev/null \
 | grep "${prefix}_" | awk '{print $1}' | sort -rn \
 | while read -r rulenum; do
 $IP6TABLES -t "$table" -D "$chain" "$rulenum" 2>/dev/null
 done
 done

 $IP6TABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read -r chain; do
 $IP6TABLES -t "$table" -F "$chain" 2>/dev/null
 done
 $IP6TABLES -t "$table" -L -n 2>/dev/null \
 | grep "^Chain ${prefix}_" | awk '{print $2}' \
 | while read -r chain; do
 $IP6TABLES -t "$table" -X "$chain" 2>/dev/null
 done
 done
}

setup_fwf_jumps_v4() {
 prefix="$1"

 # Set built-in chain policies to DROP for security.
 $IPTABLES -P INPUT DROP
 $IPTABLES -P FORWARD DROP
 $IPTABLES -P OUTPUT DROP

 # Create our prefixed chains (ignore error if they already exist).
 $IPTABLES -N "${prefix}_INPUT" 2>/dev/null
 $IPTABLES -N "${prefix}_FORWARD" 2>/dev/null
 $IPTABLES -N "${prefix}_OUTPUT" 2>/dev/null

 # Insert jump rules at position 1 (top of chain).
 # Tools that start later (Docker, CrowdSec, fail2ban) will insert
 # their own rules at position 1, pushing ours down. Control the
 # evaluation order via systemd unit ordering.
 $IPTABLES -I INPUT 1 -j "${prefix}_INPUT"
 $IPTABLES -I FORWARD 1 -j "${prefix}_FORWARD"
 $IPTABLES -I OUTPUT 1 -j "${prefix}_OUTPUT"
}

setup_fwf_jumps_v6() {
 prefix="$1"

 $IP6TABLES -P INPUT DROP
 $IP6TABLES -P FORWARD DROP
 $IP6TABLES -P OUTPUT DROP

 $IP6TABLES -N "${prefix}_INPUT" 2>/dev/null
 $IP6TABLES -N "${prefix}_FORWARD" 2>/dev/null
 $IP6TABLES -N "${prefix}_OUTPUT" 2>/dev/null

 $IP6TABLES -I INPUT 1 -j "${prefix}_INPUT"
 $IP6TABLES -I FORWARD 1 -j "${prefix}_FORWARD"
 $IP6TABLES -I OUTPUT 1 -j "${prefix}_OUTPUT"
}

check_file() {
 test -r "$2" || {
 echo "Can not find file $2 referenced by address table object $1"
 exit 1
 }
}

check_run_time_address_table_files() {
 :

}

load_modules() {
 :

}

verify_interfaces() {
 :

}

prolog_commands() {
 echo "Running prolog script"

}

epilog_commands() {
 echo "Running epilog script"

}

run_epilog_and_exit() {
 epilog_commands
 exit "$1"
}

configure_interfaces() {
 :
 # Configure interfaces
 update_addresses_of_interface "eth0 192.168.1.1/24" ""
 update_addresses_of_interface "eth1 22.22.22.22/24" ""
 update_addresses_of_interface "eth2 192.168.2.1/24" ""
 update_addresses_of_interface "eth3 22.22.23.23/24" ""
 update_addresses_of_interface "lo 127.0.0.1/8" ""
}

script_body() {
 echo 30 > /proc/sys/net/ipv4/tcp_fin_timeout
 echo 1800 > /proc/sys/net/ipv4/tcp_keepalive_intvl

 # ================ IPv4

 # ================ Table 'filter', automatic rules
 # accept established sessions
 $IPTABLES -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
 $IPTABLES -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
 $IPTABLES -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT
 # drop packets that do not match any valid state and log them
 $IPTABLES -N drop_invalid 2>/dev/null
 $IPTABLES -A OUTPUT -m state --state INVALID -j drop_invalid
 $IPTABLES -A INPUT -m state --state INVALID -j drop_invalid
 $IPTABLES -A FORWARD -m state --state INVALID -j drop_invalid
 $IPTABLES -A drop_invalid -j LOG --log-level debug --log-prefix "INVALID "
 $IPTABLES -A drop_invalid -j DROP

 # ================ Table 'nat', rule set NAT
 #
 # Rule 0 (NAT)
 #
 echo "Rule 0 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -s 192.168.1.0/24 -d 192.168.2.0/24 -j ACCEPT
 $IPTABLES -t nat -A PREROUTING -s 192.168.1.0/24 -d 192.168.2.0/24 -j ACCEPT
 #
 # Rule 1 (NAT)
 #
 echo "Rule 1 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth0 -s 192.168.1.10 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s 192.168.1.10 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth2 -s 192.168.1.10 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s 192.168.1.10 -j SNAT --to-source 22.22.22.23
 #
 # Rule 2 (NAT)
 #
 echo "Rule 2 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth0 -s ! 192.168.1.0/24 -d 200.200.200.200 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s ! 192.168.1.0/24 -d 200.200.200.200 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth2 -s ! 192.168.1.0/24 -d 200.200.200.200 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s ! 192.168.1.0/24 -d 200.200.200.200 -j SNAT --to-source 22.22.22.23
 #
 # Rule 3 (NAT)
 #
 echo "Rule 3 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth0 -p tcp -m tcp -s ! 192.168.1.0/24 -d 200.200.200.200 --dport 80 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s ! 192.168.1.0/24 -d 200.200.200.200 --dport 80 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth2 -p tcp -m tcp -s ! 192.168.1.0/24 -d 200.200.200.200 --dport 80 -j SNAT --to-source 22.22.22.23
 $IPTABLES -t nat -A POSTROUTING -o eth3 -p tcp -m tcp -s ! 192.168.1.0/24 -d 200.200.200.200 --dport 80 -j SNAT --to-source 22.22.22.23
 #
 # Rule 4 (NAT)
 #
 echo "Rule 4 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s 192.168.1.0/24 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s 192.168.1.0/24 -j SNAT --to-source 22.22.23.23
 $IPTABLES -t nat -A POSTROUTING -o eth2 -s 192.168.1.0/24 -j SNAT --to-source 192.168.2.1
 #
 # Rule 5 (NAT)
 #
 echo "Rule 5 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s 192.168.1.0/24 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s 192.168.1.0/24 -j SNAT --to-source 22.22.23.23
 #
 # Rule 6 (NAT)
 #
 echo "Rule 6 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s 192.168.1.0/24 -d ! 192.168.2.0/24 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s 192.168.1.0/24 -d ! 192.168.2.0/24 -j SNAT --to-source 22.22.23.23
 #
 # Rule 7 (NAT)
 #
 echo "Rule 7 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth1 -p tcp -m tcp -s 192.168.1.0/24 -d ! 192.168.2.0/24 --dport 80 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth3 -p tcp -m tcp -s 192.168.1.0/24 -d ! 192.168.2.0/24 --dport 80 -j SNAT --to-source 22.22.23.23
 #
 # Rule 8 (NAT)
 #
 echo "Rule 8 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s 192.168.1.0/24 -j CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s 192.168.1.0/24 -j CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth2 -s 192.168.1.0/24 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 192.168.2.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 22.22.23.23
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 192.168.1.1
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 192.168.2.1
 #
 # Rule 9 (NAT)
 #
 echo "Rule 9 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s 192.168.1.0/24 -j CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s 192.168.1.0/24 -j CHAIN
 $IPTABLES -t nat -A POSTROUTING -o eth2 -s 192.168.1.0/24 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 192.168.2.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 22.22.23.23
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 192.168.1.1
 $IPTABLES -t nat -A CHAIN -j SNAT --to-source 192.168.2.1
 #
 # Rule 10 (NAT)
 #
 echo "Rule 10 (NAT)"
 #
 $IPTABLES -t nat -A POSTROUTING -o eth1 -s ! 192.168.2.0/24 -j SNAT --to-source 22.22.22.22
 $IPTABLES -t nat -A POSTROUTING -o eth3 -s ! 192.168.2.0/24 -j SNAT --to-source 22.22.23.23
 $IPTABLES -t nat -A POSTROUTING -o eth0 -s ! 192.168.2.0/24 -j SNAT --to-source 192.168.1.1
 #
 # Rule 11 (NAT)
 #
 echo "Rule 11 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 22.22.22.22 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 22.22.23.23 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.1 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 192.168.2.1 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j REDIRECT --to-ports 3128
 #
 # Rule 12 (NAT)
 #
 echo "Rule 12 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -s 192.168.1.0/24 --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.1 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j REDIRECT --to-ports 3128
 #
 # Rule 13 (NAT)
 #
 echo "Rule 13 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -s 192.168.1.10 --dport 80 -j CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -s 192.168.1.20 --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 192.168.2.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j REDIRECT --to-ports 3128
 #
 # Rule 14 (NAT)
 #
 echo "Rule 14 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -d 192.168.1.0/24 --dport 80 -j CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -d 192.168.2.0/24 --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.20 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j REDIRECT --to-ports 3128
 #
 # Rule 15 (NAT)
 #
 echo "Rule 15 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -s 192.168.1.10 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j REDIRECT --to-ports 3128
 #
 # Rule 16 (NAT)
 #
 echo "Rule 16 (NAT)"
 #
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -d 22.22.22.23 --dport 4000:4010 -j DNAT --to-destination 192.168.1.10
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --sport 5000 -d 22.22.22.23 --dport 5000:5010 -j DNAT --to-destination 192.168.1.10
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --sport 9000 -d 22.22.22.23 -j DNAT --to-destination 192.168.1.10
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -m multiport -d 22.22.22.23 --dports 6667,3128 -j DNAT --to-destination 192.168.1.10
 #
 # Rule 17 (NAT)
 #
 echo "Rule 17 (NAT)"
 #
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -d 192.168.1.0/24 --dport 80 -j DNAT --to-destination :3128
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp -d 192.168.2.0/24 --dport 80 -j DNAT --to-destination :3128
 #
 # Rule 18 (NAT)
 #
 echo "Rule 18 (NAT)"
 #
 $IPTABLES -t nat -N CHAIN
 $IPTABLES -t nat -A PREROUTING -p tcp -m tcp --dport 80 -j CHAIN
 $IPTABLES -t nat -A CHAIN -d 192.168.1.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -d 192.168.2.0/24 -j RETURN
 $IPTABLES -t nat -A CHAIN -p tcp -m tcp --dport 80 -j DNAT --to-destination :3128

 # ================ Table 'filter', rule set GOOD_GUYS
 #
 # Rule GOOD_GUYS 0 (global)
 #
 echo "Rule GOOD_GUYS 0 (global)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A OUTPUT -j CHAIN
 $IPTABLES -A INPUT -j CHAIN
 $IPTABLES -A FORWARD -j CHAIN
 $IPTABLES -A CHAIN -s 1.1.1.0/24 -j RETURN
 $IPTABLES -A CHAIN -s 192.168.1.0/24 -j RETURN
 $IPTABLES -N GOOD_GUYS_0 2>/dev/null
 $IPTABLES -A CHAIN -j GOOD_GUYS_0
 $IPTABLES -A GOOD_GUYS_0 -j LOG --log-level debug
 $IPTABLES -A GOOD_GUYS_0 -j DROP
 # ================ Table 'filter', rule set Policy
 #
 # Rule 0 (eth0)
 #
 echo "Rule 0 (eth0)"
 #
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A INPUT -i eth0 -p 1 -j CHAIN
 $IPTABLES -A INPUT -i eth0 -p 50 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -s 22.22.22.22 -j CHAIN
