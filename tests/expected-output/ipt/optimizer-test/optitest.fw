script_body() {
 echo 0 > /proc/sys/net/ipv4/tcp_fin_timeout
 echo 0 > /proc/sys/net/ipv4/tcp_keepalive_intvl

 # ================ IPv4

 # ================ Table 'filter', automatic rules
 # accept established sessions
 $IPTABLES -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
 $IPTABLES -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
 $IPTABLES -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT

 # ================ Table 'filter', rule set Policy
 #
 # Rule 0 (eth0)
 #
 echo "Rule 0 (eth0)"
 #
 # Test 1 : Don't Optimize 1 dst
 $IPTABLES -A FORWARD -i eth0 -d 10.0.0.1 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -d 10.0.0.1 -m state --state NEW -j ACCEPT
 #
 # Rule 1 (eth0)
 #
 echo "Rule 1 (eth0)"
 #
 # Test 2 : Don't Optimize 1 service
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp --dport 80 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp --dport 80 -m state --state NEW -j ACCEPT
 #
 # Rule 2 (eth0)
 #
 echo "Rule 2 (eth0)"
 #
 # Test 3 : Don't Optimize 1 src & 1 dst
 $IPTABLES -A FORWARD -i eth0 -s 10.0.1.1 -d 10.0.0.1 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -s 10.0.1.1 -d 10.0.0.1 -m state --state NEW -j ACCEPT
 #
 # Rule 3 (eth0)
 #
 echo "Rule 3 (eth0)"
 #
 # Test 4 : Don't Optimize 1 src & 1 service
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp -s 10.0.1.1 --dport 80 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp -s 10.0.1.1 --dport 80 -m state --state NEW -j ACCEPT
 #
 # Rule 4 (eth0)
 #
 echo "Rule 4 (eth0)"
 #
 # Test 5 : Don't Optimize 1 dst & 1 service
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp -d 10.0.0.1 --dport 80 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp -d 10.0.0.1 --dport 80 -m state --state NEW -j ACCEPT
 #
 # Rule 5 (eth0)
 #
 echo "Rule 5 (eth0)"
 #
 # Test 6 : Don't Optimize 1 src, 1 dst & 1 service
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp -s 10.0.1.1 -d 10.0.0.1 --dport 80 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp -s 10.0.1.1 -d 10.0.0.1 --dport 80 -m state --state NEW -j ACCEPT
 #
 # Rule 6 (eth0)
 #
 echo "Rule 6 (eth0)"
 #
 # Test 7 : Optimize : src, dst, svc
 # Time should appear on the src rules in the FORWARD table
 # +Logging
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp --dport 21 -m state --state NEW -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A FORWARD -i eth0 -p udp -m udp --dport 873 -m state --state NEW -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -s 10.0.1.1 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A CHAIN -s 10.0.1.2 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -N In_RULE_6 2>/dev/null
 $IPTABLES -A CHAIN -d 10.0.0.1 -m time --timestart 00:00 --timestop 11:59 -j In_RULE_6
 $IPTABLES -A CHAIN -d 10.0.0.2 -m time --timestart 00:00 --timestop 11:59 -j In_RULE_6
 $IPTABLES -A In_RULE_6 -j LOG --log-level info --log-prefix "RULE 6 -- ACCEPT "
 $IPTABLES -A In_RULE_6 -j ACCEPT
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp --dport 21 -m state --state NEW -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A FORWARD -o eth0 -p udp -m udp --dport 873 -m state --state NEW -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -s 10.0.1.1 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A CHAIN -s 10.0.1.2 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -N Out_RULE_6 2>/dev/null
 $IPTABLES -A CHAIN -d 10.0.0.1 -m time --timestart 00:00 --timestop 11:59 -j Out_RULE_6
 $IPTABLES -A CHAIN -d 10.0.0.2 -m time --timestart 00:00 --timestop 11:59 -j Out_RULE_6
 $IPTABLES -A Out_RULE_6 -j LOG --log-level info --log-prefix "RULE 6 -- ACCEPT "
 $IPTABLES -A Out_RULE_6 -j ACCEPT
 #
 # Rule 7 (eth0)
 #
 echo "Rule 7 (eth0)"
 #
 # Test 7 : Optimize on service - dsts -> user chain
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp --dport 80 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.1 -j ACCEPT
 $IPTABLES -A CHAIN -d 10.0.0.2 -j ACCEPT
 $IPTABLES -A CHAIN -d 10.0.0.3 -j ACCEPT
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp --dport 80 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.1 -j ACCEPT
 $IPTABLES -A CHAIN -d 10.0.0.2 -j ACCEPT
 $IPTABLES -A CHAIN -d 10.0.0.3 -j ACCEPT
 #
 # Rule 8 (eth0)
 #
 echo "Rule 8 (eth0)"
 #
 # Test 8 : Optimize on service - srcs -> user chain
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp --dport 80 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 10.0.1.1 -j ACCEPT
 $IPTABLES -A CHAIN -s 10.0.1.2 -j ACCEPT
 $IPTABLES -A CHAIN -s 10.0.1.3 -j ACCEPT
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp --dport 80 -m state --state NEW -j CHAIN
 $IPTABLES -A CHAIN -s 10.0.1.1 -j ACCEPT
 $IPTABLES -A CHAIN -s 10.0.1.2 -j ACCEPT
 $IPTABLES -A CHAIN -s 10.0.1.3 -j ACCEPT
 #
 # Rule 9 (eth0)
 #
 echo "Rule 9 (eth0)"
 #
 # Test 9 : Optimize on service - srcs -> user chain
 # Dst to stay on rule in FORWARD table
 # + options TCP RST Reject Test
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp -d 10.0.0.1 --dport 80 -j CHAIN
 $IPTABLES -A CHAIN -s 10.0.1.1 -j REJECT --reject-with tcp-reset
 $IPTABLES -A CHAIN -s 10.0.1.2 -j REJECT --reject-with tcp-reset
 $IPTABLES -A CHAIN -s 10.0.1.3 -j REJECT --reject-with tcp-reset
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp -d 10.0.0.1 --dport 80 -j CHAIN
 $IPTABLES -A CHAIN -s 10.0.1.1 -j REJECT --reject-with tcp-reset
 $IPTABLES -A CHAIN -s 10.0.1.2 -j REJECT --reject-with tcp-reset
 $IPTABLES -A CHAIN -s 10.0.1.3 -j REJECT --reject-with tcp-reset
 #
 # Rule 10 (eth0)
 #
 echo "Rule 10 (eth0)"
 #
 # Test 10 : Optimize on src & dst, services -> user chain
 # + Logging
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -s 10.0.1.1 -d 10.0.0.1 -m state --state NEW -j CHAIN
 $IPTABLES -N In_RULE_10 2>/dev/null
 $IPTABLES -A CHAIN -p icmp -m icmp -j In_RULE_10
 $IPTABLES -A CHAIN -p tcp -m tcp --dport 80 -j In_RULE_10
 $IPTABLES -A CHAIN -p udp -m udp --dport 873 -j In_RULE_10
 $IPTABLES -A In_RULE_10 -j LOG --log-level info --log-prefix "RULE 10 -- ACCEPT "
 $IPTABLES -A In_RULE_10 -j ACCEPT
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth0 -s 10.0.1.1 -d 10.0.0.1 -m state --state NEW -j CHAIN
 $IPTABLES -N Out_RULE_10 2>/dev/null
 $IPTABLES -A CHAIN -p icmp -m icmp -j Out_RULE_10
 $IPTABLES -A CHAIN -p tcp -m tcp --dport 80 -j Out_RULE_10
 $IPTABLES -A CHAIN -p udp -m udp --dport 873 -j Out_RULE_10
 $IPTABLES -A Out_RULE_10 -j LOG --log-level info --log-prefix "RULE 10 -- ACCEPT "
 $IPTABLES -A Out_RULE_10 -j ACCEPT
 #
 # Rule 11 (eth0)
 #
 echo "Rule 11 (eth0)"
 #
 # Test 11 : Special case - with multiport we shouldn't
 # optimize here as all services are TCP and we have <15
 # of them
 # NOT OPTIMUM - We've split before multiport which re-merges multiple services of the same type
 # SOLUTION ?
 $IPTABLES -A FORWARD -i eth0 -p tcp -m tcp -m multiport -s 10.0.1.1 -d 10.0.0.1 --dports 21,80 -m state --state NEW -j ACCEPT
 $IPTABLES -A FORWARD -o eth0 -p tcp -m tcp -m multiport -s 10.0.1.1 -d 10.0.0.1 --dports 21,80 -m state --state NEW -j ACCEPT
 #
 # Rule 12 (eth0)
 #
 echo "Rule 12 (eth0)"
 #
 # Test 12 : Optimize : src, dst, svc
 # + options limit test
 # + logging
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -s 10.0.1.2 -m state --state NEW -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -d 10.0.0.1 -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.2 -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.3 -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -N In_RULE_12 2>/dev/null
 $IPTABLES -A CHAIN -p icmp -m icmp -m limit --limit 8/second --limit-burst 4 -j In_RULE_12
 $IPTABLES -A CHAIN -p tcp -m tcp --dport 21 -m limit --limit 8/second --limit-burst 4 -j In_RULE_12
 $IPTABLES -A CHAIN -p udp -m udp --dport 873 -m limit --limit 8/second --limit-burst 4 -j In_RULE_12
 $IPTABLES -A CHAIN -p 51 -m limit --limit 8/second --limit-burst 4 -j In_RULE_12
 $IPTABLES -A In_RULE_12 -j LOG --log-level info --log-prefix "RULE 12 -- ACCEPT "
 $IPTABLES -A In_RULE_12 -j ACCEPT
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -o eth0 -s 10.0.1.2 -m state --state NEW -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -d 10.0.0.1 -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.2 -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.3 -m limit --limit 8/second --limit-burst 4 -j CHAIN
 $IPTABLES -N Out_RULE_12 2>/dev/null
 $IPTABLES -A CHAIN -p icmp -m icmp -m limit --limit 8/second --limit-burst 4 -j Out_RULE_12
 $IPTABLES -A CHAIN -p tcp -m tcp --dport 21 -m limit --limit 8/second --limit-burst 4 -j Out_RULE_12
 $IPTABLES -A CHAIN -p udp -m udp --dport 873 -m limit --limit 8/second --limit-burst 4 -j Out_RULE_12
 $IPTABLES -A CHAIN -p 51 -m limit --limit 8/second --limit-burst 4 -j Out_RULE_12
 $IPTABLES -A Out_RULE_12 -j LOG --log-level info --log-prefix "RULE 12 -- ACCEPT "
 $IPTABLES -A Out_RULE_12 -j ACCEPT
 #
 # Rule 13 (eth0)
 #
 echo "Rule 13 (eth0)"
 #
 # Test 13 : Optimize : src, dst, svc
 # Time should appear on the src rules in the FORWARD table
 # +Logging
 # NOT OPTIMUM : Time appears in Logging
 # SOLUTION : Patch logging not to include time?
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A FORWARD -i eth0 -s 10.0.1.1 -m state --state NEW -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A FORWARD -i eth0 -s 10.0.1.2 -m state --state NEW -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -N CHAIN 2>/dev/null
 $IPTABLES -A CHAIN -d 10.0.0.1 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.2 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -A CHAIN -d 10.0.0.3 -m time --timestart 00:00 --timestop 11:59 -j CHAIN
 $IPTABLES -N In_RULE_13 2>/dev/null
 $IPTABLES -A CHAIN -p icmp -m icmp -m time --timestart 00:00 --timestop 11:59 -j In_RULE_13
 $IPTABLES -A CHAIN -p tcp -m tcp --dport 21 -m time --timestart 00:00 --timestop 11:59 -j In_RULE_13
