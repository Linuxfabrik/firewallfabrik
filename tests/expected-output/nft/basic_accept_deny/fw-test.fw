#!/bin/sh
#
#  This file is managed by FirewallFabrik - do not edit
#
#  FirewallFabrik fwf-nft VERSION
#
#  Generated TIMESTAMP
#
# files: * fw-test.fw fwf.sh
#

FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"

log() {
    echo "$1"
    command -v logger > /dev/null 2>&1 && logger -p info "$1"
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (global)
        #
        ip saddr 192.168.1.0/24 ip daddr { 192.168.1.1, 203.0.113.1 } tcp dport 22 ct state new accept
        #
        # Rule 1 (global)
        #
        ip daddr { 192.168.1.1, 203.0.113.1 } icmp type echo-request icmp code 0 ct state new accept
        #
        # Rule 2 (global)
        #
        ct state new drop
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 2 (global)
        #
        ct state new drop
        #
        # Rule 3 (global)
        #
        ip saddr 192.168.1.0/24 ip daddr 203.0.113.42 ct state new accept
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 3 (global)
        #
        ip saddr 192.168.1.0/24 ip daddr 203.0.113.42 ct state new accept
    }
}

NFT_RULES
}

ip_forward() {
    :

}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    flush_own_tables
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    flush_own_tables
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload]"
        ;;

esac

exit "$RETVAL"
