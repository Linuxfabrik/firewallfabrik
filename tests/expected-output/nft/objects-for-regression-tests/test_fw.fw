#!/bin/sh
#
#  This file is managed by FirewallFabrik - do not edit
#
#  FirewallFabrik fwf-nft VERSION
#
#  Generated TIMESTAMP
#
# files: * test_fw.fw /etc/test_fw.fw
#
#  This firewall has three interfaces. Eth0 faces outside and has a static routable address; eth1 faces inside; eth2 is connected to DMZ subnet.
#  Policy includes basic rules to permit unrestricted outbound access and anti-spoofing rules. Access to the firewall is permitted only from internal network and only using SSH. The firewall uses one of the machines on internal network for DNS. Internal network is configured with address 192.168.1.0/255.255.255.0, DMZ is 192.168.2.0/255.255.255.0. Since DMZ used private IP address, it needs NAT. There is a mail relay host located on DMZ (object 'server on dmz'). Policy rules permit SMTP connections to it from the Internet and allow this server to connect to a host on internal network 'internal server'. All other access from DMZ to internal net is denied. To provide access to the mail relay its private address is mapped to firewall's outside interface address by NAT rule #1.
#
# Rule 1: Branch action not yet supported by nftables compiler
# Rule 1: Branch action not yet supported by nftables compiler
# Rule 1: Branch action not yet supported by nftables compiler

FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"
IP="ip"
LOGGER="logger"

log() {
    echo "$1"
    command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
    echo $1 | sed 's/\./_/'
}

getaddr_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP $af addr show dev $dev |  sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getnet_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP route list proto kernel | grep $dev | grep -v default |  sed 's! .*$!!')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getaddr() {
    getaddr_internal $1 $2 "-4"
}

getaddr6() {
    getaddr_internal $1 $2 "-6"
}

getnet() {
    getnet_internal $1 $2 "-4"
}

getnet6() {
    getnet_internal $1 $2 "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
    NAME=$1
    $IP link show | grep ": $NAME" | while read L; do
        OIFS=$IFS
        IFS=" :"
        set $L
        IFS=$OIFS
        echo $2
    done
}

diff_intf() {
    func=$1
    list1=$2
    list2=$3
    cmd=$4
    for intf in $list1
    do
        echo $list2 | grep -q $intf || {
        # $vlan is absent in list 2
            $func $intf $cmd
        }
    done
}

P2P_INTERFACE_WARNING=""

missing_address() {
    address=$1
    cmd=$2

    oldIFS=$IFS
    IFS="@"
    set $address
    addr=$1
    interface=$2
    IFS=$oldIFS

    $IP addr show dev $interface | grep -q POINTOPOINT && {
        test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
        P2P_INTERFACE_WARNING="yes"
        return
    }

    test "$cmd" = "add" && {
      echo "# Adding ip address: $interface $addr"
      echo $addr | grep -q ':' && {
          $FWBDEBUG $IP addr $cmd $addr dev $interface
      } || {
          $FWBDEBUG $IP addr $cmd $addr broadcast + dev $interface
      }
    }

    test "$cmd" = "del" && {
      echo "# Removing ip address: $interface $addr"
      $FWBDEBUG $IP addr $cmd $addr dev $interface || exit 1
    }

    $FWBDEBUG $IP link set $interface up
}

list_addresses_by_scope() {
    interface=$1
    scope=$2
    ignore_list=$3
    $IP addr ls dev $interface | \
      awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
        while read addr; do
          echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
    ignore_list=$2
    set $1
    interface=$1
    shift

    FWB_ADDRS=$(
      for addr in $*; do
        echo "${addr}@$interface"
      done | sort
    )

    CURRENT_ADDRS_ALL_SCOPES=""
    CURRENT_ADDRS_GLOBAL_SCOPE=""

    $IP link show dev $interface >/dev/null 2>&1 && {
      CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope $interface 'scope .*' "$ignore_list")
      CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope $interface 'scope global' "$ignore_list")
    } || {
      echo "# Interface $interface does not exist"
      # Stop the script if we are not in test mode
      test -z "$FWBDEBUG" && exit 1
    }

    diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
    diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
    $IP link show | sed 's/://g' | awk -v IGNORED="$*" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/state/ && !($2 in ignored_dict)) {print $2;}' | \
         while read intf; do
            echo "# Removing addresses not configured in fwbuilder from interface $intf"
            $FWBDEBUG $IP addr flush dev $intf scope global
            $FWBDEBUG $IP link set $intf down
         done
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

verify_interfaces() {
    :
    echo "Verifying interfaces: eth0 eth1 eth2 lo"
    for i in eth0 eth1 eth2 lo ; do
        $IP link show "$i" > /dev/null 2>&1 || {
            log "Interface $i does not exist"
            exit 1
        }
    done
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

configure_interfaces() {
    :
    # See http://bugs.debian.org/cgi-bin/bugreport.cgi?bug=429689
    # this ensures that secondary ip address is "promoted" to primary
    # when primary address is deleted, instead of deleting both
    # primary and secondary addresses. It looks like this is only
    # available starting from Linux 2.6.16
    test -f /proc/sys/net/ipv4/conf/all/promote_secondaries && \
        echo 1 >  /proc/sys/net/ipv4/conf/all/promote_secondaries
    update_addresses_of_interface "eth0 192.0.2.1/24" ""
    update_addresses_of_interface "eth1 192.168.1.1/24 fe80::20c:29ff:fed2:cca1/64" ""
    update_addresses_of_interface "eth2 192.168.2.1/24" ""
    update_addresses_of_interface "lo 127.0.0.1/8" ""
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table inet fwf_filter {}
delete table inet fwf_filter
table ip fwf_nat {}
delete table ip fwf_nat

table inet fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip saddr { 192.0.2.1, 192.168.1.1, 192.168.2.1, 192.168.1.0/24, 192.168.2.0/24 } ct state new log prefix "RULE 0 -- DENY " level info drop
        #
        # Rule 1 (lo)
        #
        iif "lo" ct state new accept
        #
        # Rule 2 (global)
        #
        # SSH Access to firewall is permitted
        # only from internal network
        ip saddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 4 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        ct state new log prefix "RULE 4 -- DENY " level info drop
        #
        # Rule 5 (global)
        #
        # Quickly reject attempts to connect
        # to ident server to avoid SMTP delays
        tcp dport 113 reject
        #
        # Rule 8 (global)
        #
        # Mail relay needs DNS and can
        # connect to mail servers on the
        # Internet
        ip saddr 192.168.2.10 ip daddr != 192.168.1.0/24 tcp dport { 53, 25 } ct state new accept
        ip saddr 192.168.2.10 ip daddr != 192.168.1.0/24 udp dport 53 ct state new accept
        #
        # Rule 9 (global)
        #
        # All other access from DMZ to
        # internal  net is denied
        ip saddr 192.168.2.0/24 ip daddr 192.168.1.0/24 log prefix "RULE 9 -- DENY " level info drop
        #
        # Rule 10 (global)
        #
        # This permits access from internal net
        # to the Internet and DMZ
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 11 (global)
        #
        log prefix "RULE 11 -- DENY " level info drop
        #
        # Rule Policy_OSPF 0 (eth1)
        #
        iifname "eth1" ip6 saddr fe80::/10 ip6 daddr { fe80::/10, ff00::/8 } accept
        #
        # Rule 0 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip6 saddr fe80::20c:29ff:fed2:cca1 ct state new log prefix "RULE 0 -- DENY " level info drop
        #
        # Rule 1 (lo)
        #
        iif "lo" ct state new accept
        #
        # Rule 4 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        ct state new log prefix "RULE 4 -- DENY " level info drop
        #
        # Rule 5 (global)
        #
        # Quickly reject attempts to connect
        # to ident server to avoid SMTP delays
        tcp dport 113 reject
        #
        # Rule 11 (global)
        #
        log prefix "RULE 11 -- DENY " level info drop
        #
        # Rule Policy_v6 1 (global)
        #
        # # Rule 1: Branch action not yet supported by nftables compiler
        meta l4proto 89
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip saddr { 192.0.2.1, 192.168.1.1, 192.168.2.1, 192.168.1.0/24, 192.168.2.0/24 } ct state new log prefix "RULE 0 -- DENY " level info drop
        #
        # Rule 5 (global)
        #
        # Quickly reject attempts to connect
        # to ident server to avoid SMTP delays
        tcp dport 113 reject
        #
        # Rule 6 (global)
        #
        # Mail relay on DMZ can accept
        # connections from hosts on the
        # Internet
        ip daddr 192.168.2.10 tcp dport 25 ct state new accept
        #
        # Rule 7 (global)
        #
        # this rule permits a mail relay
        # located on DMZ to connect
        # to internal mail server
        ip saddr 192.168.2.10 ip daddr 192.168.1.10 tcp dport 25 ct state new accept
        #
        # Rule 8 (global)
        #
        # Mail relay needs DNS and can
        # connect to mail servers on the
        # Internet
        ip saddr 192.168.2.10 ip daddr != 192.168.1.0/24 tcp dport { 53, 25 } ct state new accept
        ip saddr 192.168.2.10 ip daddr != 192.168.1.0/24 udp dport 53 ct state new accept
        #
        # Rule 9 (global)
        #
        # All other access from DMZ to
        # internal  net is denied
        ip saddr 192.168.2.0/24 ip daddr 192.168.1.0/24 log prefix "RULE 9 -- DENY " level info drop
        #
        # Rule 10 (global)
        #
        # This permits access from internal net
        # to the Internet and DMZ
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 11 (global)
        #
        log prefix "RULE 11 -- DENY " level info drop
        #
        # Rule Policy_OSPF 0 (eth1)
        #
        iifname "eth1" ip6 saddr fe80::/10 ip6 daddr { fe80::/10, ff00::/8 } accept
        oifname "eth1" ip6 saddr fe80::/10 ip6 daddr { fe80::/10, ff00::/8 } accept
        #
        # Rule Policy_OSPF 1 (eth1)
        #
        oifname "eth1" ip6 saddr fe80::/10 ip6 daddr ff00::/8 accept
        #
        # Rule 0 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip6 saddr fe80::20c:29ff:fed2:cca1 ct state new log prefix "RULE 0 -- DENY " level info drop
        #
        # Rule 5 (global)
        #
        # Quickly reject attempts to connect
        # to ident server to avoid SMTP delays
        tcp dport 113 reject
        #
        # Rule 6 (global)
        #
        # Mail relay on DMZ can accept
        # connections from hosts on the
        # Internet
        tcp dport 25 ct state new accept
        #
        # Rule 11 (global)
        #
        log prefix "RULE 11 -- DENY " level info drop
        #
        # Rule Policy_v6 0 (eth1)
        #
        oifname "eth1" ip6 saddr fe80::/10 ip6 daddr ff00::/8 accept
        #
        # Rule Policy_v6 1 (global)
        #
        # # Rule 1: Branch action not yet supported by nftables compiler
        meta l4proto 89
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 1 (lo)
        #
        oif "lo" ct state new accept
        #
        # Rule 3 (global)
        #
        # Firewall uses one of the machines
        # on internal network for DNS
        ip daddr 192.168.1.10 meta l4proto { tcp, udp } th dport 53 ct state new accept
        #
        # Rule 4 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        ip daddr { 192.0.2.1, 192.168.1.1, 192.168.2.1 } ct state new log prefix "RULE 4 -- DENY " level info drop
        #
        # Rule 5 (global)
        #
        # Quickly reject attempts to connect
        # to ident server to avoid SMTP delays
        tcp dport 113 reject
        #
        # Rule 6 (global)
        #
        # Mail relay on DMZ can accept
        # connections from hosts on the
        # Internet
        ip daddr 192.168.2.10 tcp dport 25 ct state new accept
        #
        # Rule 9 (global)
        #
        # All other access from DMZ to
        # internal  net is denied
        ip saddr 192.168.2.0/24 ip daddr 192.168.1.0/24 log prefix "RULE 9 -- DENY " level info drop
        #
        # Rule 10 (global)
        #
        # This permits access from internal net
        # to the Internet and DMZ
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 11 (global)
        #
        log prefix "RULE 11 -- DENY " level info drop
        #
        # Rule Policy_OSPF 0 (eth1)
        #
        oifname "eth1" ip6 saddr fe80::/10 ip6 daddr { fe80::/10, ff00::/8 } accept
        #
        # Rule Policy_OSPF 1 (eth1)
        #
        oifname "eth1" ip6 saddr fe80::/10 ip6 daddr ff00::/8 accept
        #
        # Rule 1 (lo)
        #
        oif "lo" ct state new accept
        #
        # Rule 3 (global)
        #
        # Firewall uses one of the machines
        # on internal network for DNS
        meta l4proto { tcp, udp } th dport 53 ct state new accept
        #
        # Rule 4 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        ip6 daddr fe80::20c:29ff:fed2:cca1 ct state new log prefix "RULE 4 -- DENY " level info drop
        #
        # Rule 5 (global)
        #
        # Quickly reject attempts to connect
        # to ident server to avoid SMTP delays
        tcp dport 113 reject
        #
        # Rule 6 (global)
        #
        # Mail relay on DMZ can accept
        # connections from hosts on the
        # Internet
        tcp dport 25 ct state new accept
        #
        # Rule 11 (global)
        #
        log prefix "RULE 11 -- DENY " level info drop
        #
        # Rule Policy_v6 0 (eth1)
        #
        oifname "eth1" ip6 saddr fe80::/10 ip6 daddr ff00::/8 accept
        #
        # Rule Policy_v6 1 (global)
        #
        # # Rule 1: Branch action not yet supported by nftables compiler
        meta l4proto 89
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        ip saddr 192.168.2.0/24 ip daddr 192.168.1.0/24 accept
        #
        # Rule 2 (NAT)
        #
        ip daddr 192.0.2.1 dnat to 192.168.2.10
        #
        # Rule 2 (NAT)
        #
        ip6 daddr 192.0.2.1 dnat to 192.168.2.10
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        # no need to translate
        # between DMZ and
        # internal net
        ip saddr 192.168.2.0/24 ip daddr 192.168.1.0/24 accept
        #
        # Rule 1 (NAT)
        #
        # Translate source address
        # for outgoing connections
        oifname "eth0" ip saddr 192.168.1.0/24 snat to 192.0.2.1
        oifname "eth0" ip saddr 192.168.2.0/24 snat to 192.0.2.1
    }
}

NFT_RULES
}

ip_forward() {
    :
    echo 1 > /proc/sys/net/ipv4/ip_forward
}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        configure_interfaces
        verify_interfaces
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
