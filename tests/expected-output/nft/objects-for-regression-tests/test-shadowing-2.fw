#!/bin/sh
#
#  This file is managed by FirewallFabrik - do not edit
#
#  FirewallFabrik fwf-nft VERSION
#
#  Generated TIMESTAMP
#
# files: * test-shadowing-2.fw fwf.sh
#
#  testing shadowing detection
#  compiler runs with -xt flag
#  firewall is NOT assumed to be part of any
#
# Rule 2 shadows Rule 3 below it
# Rule 4 shadows Rule 5 below it

FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"
IP="ip"
LOGGER="logger"

log() {
    echo "$1"
    command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
    echo "$1" | sed 's/\./_/'
}

getaddr_internal() {
    dev=$1
    name=$2
    af=$3
    L=$("$IP" "$af" addr show dev "$dev" | sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getnet_internal() {
    dev=$1
    name=$2
    af=$3
    L=$("$IP" route list proto kernel | grep "$dev" | grep -v default | sed 's! .*$!!')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getaddr() {
    getaddr_internal "$1" "$2" "-4"
}

getaddr6() {
    getaddr_internal "$1" "$2" "-6"
}

getnet() {
    getnet_internal "$1" "$2" "-4"
}

getnet6() {
    getnet_internal "$1" "$2" "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
    NAME=$1
    "$IP" link show | grep ": $NAME" | while read -r L; do
        OIFS=$IFS
        IFS=" :"
        # shellcheck disable=SC2086
        set -- $L
        IFS=$OIFS
        echo "$2"
    done
}

diff_intf() {
    func=$1
    list1=$2
    list2=$3
    cmd=$4
    for intf in $list1
    do
        echo "$list2" | grep -q "$intf" || {
        # $intf is absent in list 2
            "$func" "$intf" "$cmd"
        }
    done
}

P2P_INTERFACE_WARNING=""

missing_address() {
    address=$1
    cmd=$2

    oldIFS=$IFS
    IFS="@"
    # shellcheck disable=SC2086
    set -- $address
    addr=$1
    interface=$2
    IFS=$oldIFS

    "$IP" addr show dev "$interface" | grep -q POINTOPOINT && {
        test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
        P2P_INTERFACE_WARNING="yes"
        return
    }

    test "$cmd" = "add" && {
      echo "# Adding ip address: $interface $addr"
      if echo "$addr" | grep -q ':'; then
          $FWBDEBUG "$IP" addr "$cmd" "$addr" dev "$interface"
      else
          $FWBDEBUG "$IP" addr "$cmd" "$addr" broadcast + dev "$interface"
      fi
    }

    test "$cmd" = "del" && {
      echo "# Removing ip address: $interface $addr"
      $FWBDEBUG "$IP" addr "$cmd" "$addr" dev "$interface" || exit 1
    }

    $FWBDEBUG "$IP" link set "$interface" up
}

list_addresses_by_scope() {
    interface=$1
    scope=$2
    ignore_list=$3
    "$IP" addr ls dev "$interface" | \
      awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
        while read -r addr; do
          echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
    ignore_list=$2
    # shellcheck disable=SC2086
    set -- $1
    interface=$1
    shift

    FWB_ADDRS=$(
      for addr in "$@"; do
        echo "${addr}@$interface"
      done | sort
    )

    CURRENT_ADDRS_ALL_SCOPES=""
    CURRENT_ADDRS_GLOBAL_SCOPE=""

    if "$IP" link show dev "$interface" >/dev/null 2>&1; then
      CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope "$interface" 'scope .*' "$ignore_list")
      CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope "$interface" 'scope global' "$ignore_list")
    else
      echo "# Interface $interface does not exist"
      # Stop the script if we are not in test mode
      test -z "$FWBDEBUG" && exit 1
    fi

    diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
    diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
    "$IP" link show | sed 's/://g' | awk -v IGNORED="$*" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/state/ && !($2 in ignored_dict)) {print $2;}' | \
         while read -r intf; do
            echo "# Removing addresses not configured in fwbuilder from interface $intf"
            $FWBDEBUG "$IP" addr flush dev "$intf" scope global
            $FWBDEBUG "$IP" link set "$intf" down
         done
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

verify_interfaces() {
    :
    echo "Verifying interfaces: eth0 eth1 eth2"
    for i in eth0 eth1 eth2 ; do
        $IP link show "$i" > /dev/null 2>&1 || {
            log "Interface $i does not exist"
            exit 1
        }
    done
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

configure_interfaces() {
    :
    update_addresses_of_interface "eth0 22.22.22.22/24" ""
    update_addresses_of_interface "eth1 192.168.1.1/24" ""
    update_addresses_of_interface "eth2 192.168.2.1/24" ""
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 2 (global)
        #
        # firewall is part
        # of any for this rule
        tcp dport 80 ct state new accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        # shades rule below
        oifname "eth0" ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 1 (eth0)
        #
        oifname "eth0" ip saddr 192.168.1.10 drop
        #
        # Rule 2 (global)
        #
        # firewall is part
        # of any for this rule
        tcp dport 80 ct state new accept
        #
        # Rule 4 (global)
        #
        # this rule should shadow rule below it because
        # it uses IPService object with protocol 0
        meta l4proto 0 ct state new accept
        #
        # Rule 5 (global)
        #
        ip saddr 192.168.1.0/24 tcp dport 6667 drop
        #
        # Rule 6 (global)
        #
        log prefix "RULE 6 -- DENY " level info drop
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        # shades rule below
        oifname "eth0" ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 2 (global)
        #
        # firewall is part
        # of any for this rule
        tcp dport 80 ct state new accept
        #
        # Rule 3 (global)
        #
        tcp dport 80 drop
        #
        # Rule 5 (global)
        #
        ip saddr 192.168.1.0/24 tcp dport 6667 drop
    }
}

NFT_RULES
}

ip_forward() {
    :
    echo 1 > /proc/sys/net/ipv4/ip_forward
}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        configure_interfaces
        verify_interfaces
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
