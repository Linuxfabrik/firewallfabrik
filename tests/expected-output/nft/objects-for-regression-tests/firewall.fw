        #
        ip saddr { 211.11.11.11, 211.22.22.22 } ip daddr 192.168.1.10 ct state new meta hour "00:00"-"23:59" meta day { "Saturday" } log prefix "CUSTOM LOGGING" level debug accept
        ip saddr { 211.11.11.11, 211.22.22.22 } ip daddr 192.168.1.10 ct state new meta hour "00:00"-"23:59" meta day { "Sunday" } log prefix "CUSTOM LOGGING" level debug accept
        ip saddr { 211.11.11.11, 211.22.22.22 } ip daddr 192.168.1.10 ct state new meta hour "18:00"-"23:59" log prefix "CUSTOM LOGGING" level debug accept
        ip saddr { 211.11.11.11, 211.22.22.22 } ip daddr 192.168.1.10 ct state new meta hour "01:01"-"02:02" meta day { "Sunday", "Monday" } log prefix "CUSTOM LOGGING" level debug accept
        #
