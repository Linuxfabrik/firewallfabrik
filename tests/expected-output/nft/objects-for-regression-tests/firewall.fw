        #
        # keep FORWARD chain
        # because it is needed for anti-spoofing rules
        iifname "eth1" ip saddr 222.222.222.222 udp dport 53 ct state new accept
        #
        # Rule 9 (eth1)
        #
        iifname "eth1" ip saddr 192.168.1.10 udp dport 53 ct state new accept
        oifname "eth1" ip saddr 192.168.1.10 udp dport 53 ct state new accept
        #
        # Rule 11 (eth0)
        #
        # code should go into INPUT chain with
        # address in destination for comparison
        iifname "eth0" ip daddr 192.168.1.255 udp dport 53 log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 12 (eth0)
        #
        iifname "eth0" tcp dport 80 ct state new accept
        #
        # Rule 18 (global)
        #
        # OUTPUT + FORWARD
        ip daddr 1.1.1.1 accept
        #
        # Rule 19 (global)
        #
        # INPUT + FORWARD
        ip saddr 1.1.1.1 accept
        #
        # Rule 22 (global)
        #
        meta l4proto icmp log prefix "CUSTOM LOGGING" level debug drop
