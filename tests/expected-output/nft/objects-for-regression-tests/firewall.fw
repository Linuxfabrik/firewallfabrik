# Rule 26 (global): Custom service 'test-custom-2' is not configured for 'nftables'
# Rule 26 (global): Service type CustomService not yet supported by nftables compiler
        log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 28 (global)
        #
        # both src and dst have multiple interfaces
        ip saddr { 33.33.33.33, 172.16.1.1, 192.168.100.1 } ip daddr { 33.33.33.33, 172.16.1.1, 192.168.100.1 } ct state new accept
        #
        # Rule 29 (global)
        #
        ip saddr 192.168.1.10 ip daddr 192.168.1.10 ct state new accept
        #
        # Rule 31 (global)
        #
        ip daddr 192.168.1.10 ct state new accept
        #
        # Rule 33 (global)
        #
        ip saddr 00:10:4b:de:e9:70 ip daddr 200.200.200.200 ct state new accept
        #
