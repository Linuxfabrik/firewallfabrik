        #
        ip saddr { 211.11.11.11, 211.22.22.22 } ip daddr { 192.168.1.10, 192.168.1.20 } tcp dport { 113, 13, 53, 2105, 21, 70, 80, 443, 143, 993, 6667, 6667, 543, 544, 389, 98, 3306, 2049, 119, 110, 5432, 515, 26000, 512, 513, 514, 4321, 25, 465, 1080, 3128, 22, 111, 23, 10000-11000, 540, 7100 } ct state new accept
        #
