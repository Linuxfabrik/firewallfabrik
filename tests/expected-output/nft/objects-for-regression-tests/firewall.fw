FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"
IP="ip"
LOGGER="logger"

log() {
    echo "$1"
    command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
    echo $1 | sed 's/\./_/'
}

getaddr_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP $af addr show dev $dev |  sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getnet_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP route list proto kernel | grep $dev | grep -v default |  sed 's! .*$!!')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getaddr() {
    getaddr_internal $1 $2 "-4"
}

getaddr6() {
    getaddr_internal $1 $2 "-6"
}

getnet() {
    getnet_internal $1 $2 "-4"
}

getnet6() {
    getnet_internal $1 $2 "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
    NAME=$1
    $IP link show | grep ": $NAME" | while read L; do
        OIFS=$IFS
        IFS=" :"
        set $L
        IFS=$OIFS
        echo $2
    done
}

diff_intf() {
    func=$1
    list1=$2
    list2=$3
    cmd=$4
    for intf in $list1
    do
        echo $list2 | grep -q $intf || {
        # $vlan is absent in list 2
            $func $intf $cmd
        }
    done
}

P2P_INTERFACE_WARNING=""

missing_address() {
    address=$1
    cmd=$2

    oldIFS=$IFS
    IFS="@"
    set $address
    addr=$1
    interface=$2
    IFS=$oldIFS

    $IP addr show dev $interface | grep -q POINTOPOINT && {
        test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
        P2P_INTERFACE_WARNING="yes"
        return
    }

    test "$cmd" = "add" && {
      echo "# Adding ip address: $interface $addr"
      echo $addr | grep -q ':' && {
          $FWBDEBUG $IP addr $cmd $addr dev $interface
      } || {
          $FWBDEBUG $IP addr $cmd $addr broadcast + dev $interface
      }
    }

    test "$cmd" = "del" && {
      echo "# Removing ip address: $interface $addr"
      $FWBDEBUG $IP addr $cmd $addr dev $interface || exit 1
    }

    $FWBDEBUG $IP link set $interface up
}

list_addresses_by_scope() {
    interface=$1
    scope=$2
    ignore_list=$3
    $IP addr ls dev $interface | \
      awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
        while read addr; do
          echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
    ignore_list=$2
    set $1
    interface=$1
    shift

    FWB_ADDRS=$(
      for addr in $*; do
        echo "${addr}@$interface"
      done | sort
    )

    CURRENT_ADDRS_ALL_SCOPES=""
    CURRENT_ADDRS_GLOBAL_SCOPE=""

    $IP link show dev $interface >/dev/null 2>&1 && {
      CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope $interface 'scope .*' "$ignore_list")
      CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope $interface 'scope global' "$ignore_list")
    } || {
      echo "# Interface $interface does not exist"
      # Stop the script if we are not in test mode
      test -z "$FWBDEBUG" && exit 1
    }

    diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
    diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
    $IP link show | sed 's/://g' | awk -v IGNORED="$*" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/state/ && !($2 in ignored_dict)) {print $2;}' | \
         while read intf; do
            echo "# Removing addresses not configured in fwbuilder from interface $intf"
            $FWBDEBUG $IP addr flush dev $intf scope global
            $FWBDEBUG $IP link set $intf down
         done
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

verify_interfaces() {
    :
    echo "Verifying interfaces: eth0 eth1"
    for i in eth0 eth1 ; do
        $IP link show "$i" > /dev/null 2>&1 || {
            log "Interface $i does not exist"
            exit 1
        }
    done
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

configure_interfaces() {
    :
    update_addresses_of_interface "eth0 192.168.1.1/24" ""
    update_addresses_of_interface "eth1 222.222.222.222/24" ""
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter
table ip fwf_nat {}
delete table ip fwf_nat

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        ct state invalid log prefix "INVALID " drop
        tcp flags != syn ct state new drop
        #
        # Rule 0 (eth1)
        #
        # Automatically generated rule blocking short fragments
        iifname "eth1" meta l4proto 0 log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 2 (eth1)
        #
        # Automatically generated anti-spoofing rule
        iifname "eth1" ip saddr { 192.168.1.1, 222.222.222.222, 192.168.1.0/24 } log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 3 (eth1)
        #
        iifname "eth1" udp dport 53 ct state new accept
        #
        # Rule 4 (eth1)
        #
        # rule in FORWARD chain with
        # -o eth1 and dest address of the firewall
        # is pretty much impossible
        iifname "eth1" ip daddr 222.222.222.222 udp dport 53 ct state new accept
        #
        # Rule 7 (eth1)
        #
        iifname "eth1" ip saddr { 192.168.1.1, 222.222.222.222 } udp dport 53 ct state new accept
        #
        # Rule 8 (eth1)
        #
        # keep FORWARD chain
        # because it is needed for anti-spoofing rules
        iifname "eth1" ip saddr 222.222.222.222 udp dport 53 ct state new accept
        #
        # Rule 9 (eth1)
        #
        iifname "eth1" ip saddr 192.168.1.10 udp dport 53 ct state new accept
        #
        # Rule 10 (eth0)
        #
        iifname "eth0" ip saddr 192.168.1.0/24 udp dport 53 ct state new accept
        #
        # Rule 12 (eth0)
        #
        iifname "eth0" tcp dport 80 ct state new accept
        #
        # Rule 13 (eth0,eth1)
        #
        # reject using connlimit
        iifname "eth0" drop
        iifname "eth1" drop
        #
        # Rule 15 (eth0,eth1)
        #
        iifname "eth0" ct state new accept
        iifname "eth1" ct state new accept
        #
        # Rule 17 (global)
        #
        # INTPUT with "-i +"
        # "-i +" is redundant if chain is INPUT,
        # optimization removes it
        ip saddr 1.1.1.1 accept
        #
        # Rule 22 (global)
        #
        meta l4proto icmp log prefix "CUSTOM LOGGING" level debug drop
        log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 23 (global)
        #
        meta l4proto 0 drop
        #
        # Rule 25 (global)
        #
        meta l4proto 0 ip dscp AF4 drop
        #
        # Rule 26 (global)
        #
        # # Rule 26 (global): Custom service 'test-custom-1' is not configured for 'nftables'
# Rule 26 (global): Custom service 'test-custom-2' is not configured for 'nftables'
# Rule 26 (global): Service type CustomService not yet supported by nftables compiler
        log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 28 (global)
        #
        # both src and dst have multiple interfaces
        ip saddr { 192.168.1.1, 222.222.222.222 } ip daddr { 192.168.1.1, 222.222.222.222 } ct state new accept
        ip saddr { 33.33.33.33, 172.16.1.1, 192.168.100.1 } ct state new accept
        #
        # Rule 30 (global)
        #
        ip saddr 192.168.1.10 ct state new accept
        #
        # Rule 32 (global)
        #
        ip saddr 00:10:4b:de:e9:70 ct state new accept
        #
        # Rule 34 (global)
        #
        ip saddr 192.168.1.15 ct state new accept
        #
        # Rule 35 (global)
        #
        ip saddr aa:bb:cc:dd:ee:ff ct state new accept
        #
        # Rule 40 (global)
        #
        ip saddr 192.168.1.10 tcp dport 80 ct state new accept
        #
        # Rule 46 (global)
        #
        # # Rule 46 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 46 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr 192.168.1.0/24 ct state new accept
        # # Rule 46 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 46 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr 192.168.1.0/24 icmp type destination-unreachable ct state new accept
        #
        # Rule 49 (global)
        #
        # group "special combined srv"
        # has couple of UDP services,
        # plus "ALL UDP" service, which has
        # empty ports specs. This is special
        # case for multiport.
        ip saddr 192.168.1.0/24 udp dport { 68, 67 } ct state new accept
        #
        # Rule 51 (global)
        #
        ip saddr { 192.168.1.1, 222.222.222.222 } ip daddr { 192.168.1.1, 222.222.222.222 } ct state new log prefix "CUSTOM LOGGING" level debug accept
        #
        # Rule 52 (global)
        #
        ip saddr { 192.168.1.1, 222.222.222.222 } ip daddr { 192.168.1.1, 222.222.222.222 } udp dport 161 ct state new accept
        #
        # Rule 53 (global)
        #
        # Automatically generated 'masquerading' rule
        ip saddr { 192.168.1.1, 222.222.222.222, 192.168.1.0/24 } ct state new accept
        #
        # Rule 54 (global)
        #
        # similar to a standard 'masquerading'
        # rule, but not so permissive as it does
        # not allow access to the firewall
        ip saddr 192.168.1.0/24 ip daddr != { 192.168.1.1, 222.222.222.222 } ct state new accept
        #
        # Rule 56 (global)
        #
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ip daddr { 192.168.1.0/24, 192.168.2.0/24 } tcp dport { 113, 10000-11000 } ct state new accept
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ip daddr { 192.168.1.0/24, 192.168.2.0/24 } udp dport { 53, 161 } ct state new accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        ct state invalid log prefix "INVALID " drop
        tcp flags != syn ct state new drop
        #
        # Rule 0 (eth1)
        #
        # Automatically generated rule blocking short fragments
        iifname "eth1" meta l4proto 0 log prefix "CUSTOM LOGGING" level debug drop
        #
