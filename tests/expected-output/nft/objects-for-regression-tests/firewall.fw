        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ip daddr { 192.168.1.0/24, 192.168.2.0/24 } udp dport { 53, 161 } ct state new accept
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        ct state invalid log prefix "INVALID " drop
        tcp flags != syn ct state new drop
        #
        # Rule 3 (eth1)
        #
        oifname "eth1" ip daddr { 192.168.1.1, 222.222.222.222 } udp dport 53 ct state new accept
        #
