        oifname "eth1" ip saddr 222.222.222.222 udp dport 53 ct state new accept
        #
        # Rule 10 (eth0)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr { 192.168.1.1, 222.222.222.222 } udp dport 53 ct state new accept
        #
        # Rule 16 (global)
        #
        # OUTPUT
        ip daddr 1.1.1.1 accept
        #
        # Rule 22 (global)
        #
        meta l4proto icmp log prefix "CUSTOM LOGGING" level debug drop
        log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 23 (global)
        #
        meta l4proto 0 drop
        #
        # Rule 25 (global)
        #
        meta l4proto 0 ip dscp AF4 drop
        #
        # Rule 26 (global)
        #
        # # Rule 26 (global): Custom service 'test-custom-1' is not configured for 'nftables'
# Rule 26 (global): Custom service 'test-custom-2' is not configured for 'nftables'
# Rule 26 (global): Service type CustomService not yet supported by nftables compiler
        log prefix "CUSTOM LOGGING" level debug drop
        #
        # Rule 28 (global)
        #
        # both src and dst have multiple interfaces
        ip saddr { 192.168.1.1, 222.222.222.222 } ip daddr { 192.168.1.1, 222.222.222.222 } ct state new accept
        ip daddr { 33.33.33.33, 172.16.1.1, 192.168.100.1 } ct state new accept
        #
        # Rule 44 (global)
        #
        ip daddr 192.168.1.10 tcp sport 1024-65535 tcp dport 80 ct state new accept
        #
        # Rule 45 (global)
        #
        # Rule #20 test: from Rock
        ip daddr 192.168.1.10 tcp dport { 53, 3128, 80 } ct state new accept
        #
        # Rule 46 (global)
        #
        # # Rule 46 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 46 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr 192.168.1.0/24 ct state new accept
        # # Rule 46 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 46 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr 192.168.1.0/24 icmp type destination-unreachable ct state new accept
        #
        # Rule 47 (global)
        #
        # # Rule 47 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 47 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr 192.168.1.11-192.168.1.15 ct state new accept
        # # Rule 47 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 47 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr 192.168.1.11-192.168.1.15 tcp dport { 113, 80, 443, 143, 25, 22, 540 } ct state new accept
        #
        # Rule 48 (global)
        #
        # # Rule 48 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 48 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr { 192.168.1.11, 192.168.1.12, 192.168.1.13, 192.168.1.14, 192.168.1.15 } ct state new accept
        # # Rule 48 (global): Custom service 'talk' is not configured for 'nftables'
# Rule 48 (global): Service type CustomService not yet supported by nftables compiler
        ip daddr { 192.168.1.11, 192.168.1.12, 192.168.1.13, 192.168.1.14, 192.168.1.15 } tcp dport { 113, 80, 443, 143, 25, 22, 540 } ct state new accept
        #
        # Rule 50 (global)
        #
        # another test case for multiport: this rule
        # has 16 TCP services and should be split onto
        # two rules. If both rules use "-m multiport", then
        # rule with a single service should use "--dports".
        # It may be acceptable to not use multiport
        # in the rule with a single service at all.
        ip saddr 192.168.1.0/24 ip daddr 192.168.1.11-192.168.1.15 tcp dport { 113, 13, 53, 2105, 21, 70, 80, 443, 6667, 119, 25, 3128, 22, 23, 10000-11000, 540 } ct state new log prefix "CUSTOM LOGGING" level debug accept
        #
        # Rule 51 (global)
        #
        ip saddr { 192.168.1.1, 222.222.222.222 } ip daddr { 192.168.1.1, 222.222.222.222 } ct state new log prefix "CUSTOM LOGGING" level debug accept
        #
        # Rule 52 (global)
        #
        ip saddr { 192.168.1.1, 222.222.222.222 } ip daddr { 192.168.1.1, 222.222.222.222 } udp dport 161 ct state new accept
        ip daddr 200.200.200.200 udp dport 161 ct state new accept
        #
        # Rule 53 (global)
        #
        # Automatically generated 'masquerading' rule
        ct state new accept
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 55 (global)
        #
        ip saddr 192.168.1.0/24 ip daddr != 33.33.33.0/24 ct state new accept
        #
        # Rule 56 (global)
        #
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ip daddr { 192.168.1.0/24, 192.168.2.0/24 } tcp dport { 113, 10000-11000 } ct state new accept
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ip daddr { 192.168.1.0/24, 192.168.2.0/24 } udp dport { 53, 161 } ct state new accept
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        #
        # Rule 6 (NAT)
        #
        ip daddr 222.222.222.222 tcp dport 25 dnat to 192.168.1.10:25
        ip daddr 192.168.1.1 tcp dport 25 dnat to 192.168.1.10:25
        #
        # Rule 7 (NAT)
        #
        ip daddr 222.222.222.222 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 192.168.1.1 meta l4proto icmp dnat to 192.168.1.10
        #
        # Rule 8 (NAT)
        #
        ip daddr 222.222.222.222 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 192.168.1.1 meta l4proto icmp dnat to 192.168.1.10
        #
        # Rule 9 (NAT)
        #
        ip daddr 222.222.222.222 tcp sport 1000-1010 dnat to 192.168.1.10
        ip daddr 192.168.1.1 tcp sport 1000-1010 dnat to 192.168.1.10
        #
        # Rule 12 (NAT)
        #
        ip saddr 00:10:4b:de:e9:70 ip daddr 222.222.222.40 tcp dport 25 dnat to 192.168.1.10
        #
        # Rule 13 (NAT)
        #
        ip saddr 192.168.1.15 ip daddr 222.222.222.40 tcp dport 25 dnat to 192.168.1.10
        #
        # Rule 14 (NAT)
        #
        # hsould match mac and ip addresses
        ip saddr 192.168.1.10 ip daddr 222.222.222.222 tcp dport 80 dnat to 192.168.1.10
        ip saddr 192.168.1.10 ip daddr 192.168.1.1 tcp dport 80 dnat to 192.168.1.10
        ip saddr 00:10:4b:de:e9:70 ip daddr 222.222.222.222 tcp dport 80 dnat to 192.168.1.10
        ip saddr 00:10:4b:de:e9:70 ip daddr 192.168.1.1 tcp dport 80 dnat to 192.168.1.10
        ip saddr 00:10:4b:de:e9:71 ip daddr 222.222.222.222 tcp dport 80 dnat to 192.168.1.10
        ip saddr 00:10:4b:de:e9:71 ip daddr 192.168.1.1 tcp dport 80 dnat to 192.168.1.10
        ip daddr 222.222.222.222 tcp dport 80 dnat to 192.168.1.10
        ip daddr 192.168.1.1 tcp dport 80 dnat to 192.168.1.10
        #
        # Rule 15 (NAT)
        #
        # ensure generated rules match different mac addresses
        ip saddr 192.168.1.10 ip daddr 222.222.222.222 tcp dport 80 dnat to 192.168.1.10
        ip saddr 192.168.1.10 ip daddr 192.168.1.1 tcp dport 80 dnat to 192.168.1.10
        ip saddr 192.168.1.15 ip daddr 222.222.222.222 tcp dport 80 dnat to 192.168.1.10
        ip saddr 192.168.1.15 ip daddr 192.168.1.1 tcp dport 80 dnat to 192.168.1.10
        #
        # Rule 17 (NAT)
        #
        ip daddr 222.222.222.222 tcp sport 1024-65535 tcp dport 80 dnat to 192.168.1.10:80
        ip daddr 192.168.1.1 tcp sport 1024-65535 tcp dport 80 dnat to 192.168.1.10:80
        #
        # Rule 18 (NAT)
        #
        ip daddr 222.222.222.222 tcp sport 53 dnat to 192.168.1.10
        ip daddr 192.168.1.1 tcp sport 53 dnat to 192.168.1.10
        #
        # Rule 19 (NAT)
        #
        ip daddr 222.222.222.222 tcp dport 4000-4010 dnat to 192.168.1.10:4000-4010
        ip daddr 192.168.1.1 tcp dport 4000-4010 dnat to 192.168.1.10:4000-4010
        #
        # Rule 23 (NAT)
        #
        # should use multiport
        # and account for
        # no more than 15 ports
        # per rule
        ip daddr 222.222.222.222 tcp dport { 113, 13, 53, 2105, 21, 70, 80, 443, 143, 993, 6667, 6667, 543, 544, 389, 98, 3306, 2049, 119, 110, 5432, 515, 26000, 512, 513, 514, 4321, 25, 465, 1080, 3128, 22, 111, 23, 10000-11000, 540, 7100 } dnat to 192.168.1.10
        #
        # Rule 24 (NAT)
        #
        # should use multiport
        # and account for
        # no more than 15 ports
        # per rule
        ip daddr 222.222.222.222 tcp dport { 113, 13, 53, 2105, 21, 70, 80, 443, 143, 993, 6667, 6667, 543, 544, 389, 98, 3306, 2049, 119, 110, 5432, 515, 26000, 512, 513, 514, 4321, 25, 465, 1080, 3128, 22, 111, 23, 10000-11000, 540, 7100 } dnat to 192.168.1.10
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 222.222.222.222
        #
        # Rule 1 (NAT)
        #
        ip saddr 192.168.1.0/24 snat to 222.222.222.0/24
        #
        # Rule 2 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.10-192.168.1.100 snat to 222.222.222.10-222.222.222.100
        oifname "eth0" ip saddr 192.168.1.10-192.168.1.100 snat to 222.222.222.10-222.222.222.100
        #
        # Rule 4 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr 192.168.1.20 tcp dport 80 snat to 192.168.1.1
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 192.168.1.20 tcp dport 80 snat to 192.168.1.1
        #
        # Rule 5 (NAT)
        #
        oifname "eth1" ip daddr 22.22.22.23 tcp dport { 3128, 4000-4010 } snat to 192.168.1.10
        oifname "eth0" ip daddr 22.22.22.23 tcp dport { 3128, 4000-4010 } snat to 192.168.1.10
        #
        # Rule 10 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.10 tcp sport 1000-1010 snat to 222.222.222.222:1000-1010
        oifname "eth0" ip saddr 192.168.1.10 tcp sport 1000-1010 snat to 192.168.1.1:1000-1010
        #
        # Rule 11 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.10 tcp dport 25 snat to 222.222.222.222
        #
        # Rule 16 (NAT)
        #
        # should match mac and ip addresses
        oifname "eth1" ip saddr 192.168.1.10 ip daddr ! 223.223.223.223 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip saddr 192.168.1.10 ip daddr ! 61.150.47.112 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip saddr 00:10:4b:de:e9:70 ip daddr ! 223.223.223.223 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip saddr 00:10:4b:de:e9:70 ip daddr ! 61.150.47.112 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip saddr 00:10:4b:de:e9:71 ip daddr ! 223.223.223.223 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip saddr 00:10:4b:de:e9:71 ip daddr ! 61.150.47.112 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip daddr ! 223.223.223.223 tcp dport 80 snat to 222.222.222.222
        oifname "eth1" ip daddr ! 61.150.47.112 tcp dport 80 snat to 222.222.222.222
        #
        # Rule 20 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.10 tcp dport 4000-4010 snat to 222.222.222.222
        oifname "eth0" ip saddr 192.168.1.10 tcp dport 4000-4010 snat to 192.168.1.1
        #
        # Rule 21 (NAT)
        #
        ip saddr 192.168.1.10 tcp dport 3128 accept
        #
        # Rule 22 (NAT)
        #
        ip saddr 222.222.222.222 tcp dport 3128 accept
    }
}

NFT_RULES
}

ip_forward() {
    :
    echo 1 > /proc/sys/net/ipv4/ip_forward
}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        configure_interfaces
        verify_interfaces
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
