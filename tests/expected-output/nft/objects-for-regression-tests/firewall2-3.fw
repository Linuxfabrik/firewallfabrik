        #
        # Rule 17 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 119 dnat to 192.168.1.10
        #
        # Rule 19 (NAT)
        #
        ip daddr 22.22.23.24 dnat to 192.168.1.20
        #
        # Rule 22 (NAT)
        #
        # NETMAP
        ip daddr 22.22.22.0/24 dnat to 192.168.1.0/24
        #
        # Rule 23 (NAT)
        #
        ip daddr 192.168.1.1 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 22.22.22.22 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 22.22.23.23 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 192.168.2.1 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        #
        # Rule 24 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 80 dnat to 192.168.1.10
        ip daddr 22.22.23.23 tcp dport 80 dnat to 192.168.1.10
        #
        # Rule 25 (NAT)
        #
        ip daddr 22.22.22.23 tcp dport 80 dnat to 192.168.1.10:25
        #
        # Rule 27 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.10-192.168.1.100
        #
        # Rule 28 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.11
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.12
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.13
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.14
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.15
        #
        # Rule 29 (NAT)
        #
        # transparent proxy rule
        ip saddr 192.168.1.0/24 ip daddr ! 22.22.22.23 dnat to 192.168.2.10
        #
        # Rule 32 (NAT)
        #
        ip daddr 192.168.1.10 tcp dport 80 dnat to 192.168.1.10:8080
        #
        # Rule 34 (NAT)
        #
        ip saddr ! 192.168.1.10 tcp dport 80 dnat to 192.168.1.10:3128
        #
        # Rule 35 (NAT)
        #
        ip saddr ! 192.168.1.10 ip daddr ! 192.168.1.50 tcp dport 80 dnat to 192.168.1.50:3128
        ip saddr ! 192.168.1.20 ip daddr ! 192.168.1.50 tcp dport 80 dnat to 192.168.1.50:3128
        #
        # Rule 37 (NAT)
        #
        ip saddr 192.168.1.0/24 tcp dport 80 dnat to 192.168.1.10:3128
        #
        # Rule 39 (NAT)
        #
        ip saddr 192.168.1.0/24 tcp dport 80 dnat to 192.168.1.1:3128
        #
        # Rule 41 (NAT)
        #
        # testing transparent proxy
        # roules for a support req.
        ip saddr ! 192.168.1.10 tcp dport 80 dnat to 192.168.1.1:3128
        ip saddr ! 192.168.1.20 tcp dport 80 dnat to 192.168.1.1:3128
        #
        # Rule 42 (NAT)
        #
        # testing transparent proxy
        # roules for a support req.
        ip saddr ! 192.168.1.10 tcp dport 80 dnat to 192.168.1.1:3128
        ip saddr ! 192.168.1.20 tcp dport 80 dnat to 192.168.1.1:3128
        #
        # Rule 43 (NAT)
        #
        # testing transparent proxy
        # roules for a support req.
        ip saddr ! 192.168.1.10 tcp dport 80 redirect to :3128
        ip saddr ! 192.168.1.20 tcp dport 80 redirect to :3128
        #
        # Rule 45 (NAT)
        #
        # testing transparent proxy
        # roules for a support req.
        ip saddr ! 192.168.1.10 tcp dport 80 dnat to 192.168.1.50:3128
        ip saddr ! 192.168.1.20 tcp dport 80 dnat to 192.168.1.50:3128
    }

    chain output {
        type nat hook output priority dstnat;
        ip daddr 192.168.2.10 accept
        ip daddr 192.168.2.11 accept
        ip daddr 22.22.22.23 meta l4proto 88 dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto 50 dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 tcp dport { 80, 119 } dnat to 192.168.1.10
        #
        # Rule 12 (NAT)
        #
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 meta l4proto icmp dnat to 192.168.1.10
        ip daddr 22.22.22.23 tcp dport { 80, 119 } dnat to 192.168.1.10
        #
        # Rule 13 (NAT)
        #
        ip saddr 22.22.23.23 ip daddr 22.22.22.23 tcp dport { 80, 119 } dnat to 192.168.1.10
        #
        # Rule 14 (NAT)
        #
        ip daddr 22.22.22.23 tcp dport { 80, 119 } dnat to 192.168.1.10
        ip daddr 22.22.22.23 tcp dport { 80, 119 } dnat to 192.168.1.10
        ip daddr 22.22.22.22 tcp dport 119 dnat to 192.168.1.10
        ip daddr 22.22.23.24 dnat to 192.168.1.20
        ip daddr 192.168.1.1 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 22.22.22.22 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 22.22.23.23 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 192.168.2.1 tcp dport 10000-11000 dnat to 192.168.1.10:10000-11000
        ip daddr 22.22.22.22 tcp dport 80 dnat to 192.168.1.10
        ip daddr 22.22.23.23 tcp dport 80 dnat to 192.168.1.10
        ip daddr 22.22.22.23 tcp dport 80 dnat to 192.168.1.10:25
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.10-192.168.1.100
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.11
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.12
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.13
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.14
        ip daddr 22.22.22.22 tcp dport 8080 dnat to 192.168.1.15
        ip daddr 192.168.1.10 tcp dport 80 dnat to 192.168.1.10:8080
        tcp dport 80 dnat to 192.168.1.10:3128
        ip daddr ! 192.168.1.50 tcp dport 80 dnat to 192.168.1.50:3128
        tcp dport 80 dnat to 192.168.1.1:3128
        tcp dport 80 dnat to 192.168.1.1:3128
        tcp dport 80 dnat to 192.168.1.50:3128
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 snat to 192.168.2.1
        #
        # Rule 1 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 tcp dport 80 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 tcp dport 80 snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 tcp dport 80 snat to 192.168.2.1
        #
        # Rule 2 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto 88 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto 88 snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto 88 snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto 50 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto 50 snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto 50 snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 meta l4proto icmp snat to 192.168.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 tcp dport 80 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 tcp dport 80 snat to 22.22.23.23
        oifname "eth2" ip saddr 192.168.1.0/24 tcp dport 80 snat to 192.168.2.1
        #
        # Rule 3 (NAT)
        #
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.23.23
        #
        # Rule 4 (NAT)
        #
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.25.50
        #
        # Rule 5 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 snat to 22.22.25.50
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 22.22.25.50
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.25.50
        oifname "eth2" ip saddr 192.168.1.0/24 snat to 22.22.25.50
        #
        # Rule 6 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth1" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth3" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth2" ip saddr 192.168.1.10 snat to 22.22.22.23
        #
        # Rule 7 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth1" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth3" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth2" ip saddr 192.168.1.10 snat to 22.22.22.23
        #
        # Rule 8 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 snat to 192.168.1.1
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 snat to 192.168.1.1
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 snat to 192.168.1.1
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 snat to 192.168.1.1
        #
        # Rule 9 (NAT)
        #
        ip saddr 192.168.1.1 ip daddr 192.168.2.10 accept
        ip saddr 192.168.1.1 ip daddr 192.168.2.11 accept
        ip saddr 192.168.1.10 ip daddr 192.168.2.10 accept
        ip saddr 192.168.1.10 ip daddr 192.168.2.11 accept
        ip saddr 192.168.1.20 ip daddr 192.168.2.10 accept
        ip saddr 192.168.1.20 ip daddr 192.168.2.11 accept
        #
        # Rule 10 (NAT)
        #
        ip saddr 192.168.1.10 ip daddr ! 192.168.2.10 accept
        ip saddr 192.168.1.10 ip daddr ! 192.168.2.11 accept
        ip saddr 192.168.1.20 ip daddr ! 192.168.2.10 accept
        ip saddr 192.168.1.20 ip daddr ! 192.168.2.11 accept
        #
        # Rule 18 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.20 snat to 22.22.23.24
        oifname "eth1" ip saddr 192.168.1.20 snat to 22.22.23.24
        oifname "eth3" ip saddr 192.168.1.20 snat to 22.22.23.24
        oifname "eth2" ip saddr 192.168.1.20 snat to 22.22.23.24
        #
        # Rule 20 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 snat to 22.22.22.100-22.22.22.110
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 22.22.22.100-22.22.22.110
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.22.100-22.22.22.110
        oifname "eth2" ip saddr 192.168.1.0/24 snat to 22.22.22.100-22.22.22.110
        #
        # Rule 21 (NAT)
        #
        # NETMAP
        ip saddr 192.168.1.0/24 snat to 22.22.22.0/24
        oifname "eth0" ip daddr 192.168.1.10 tcp dport 80 snat to 192.168.1.1
        #
        # Rule 26 (NAT)
        #
        ip daddr 192.168.1.1 tcp dport { 80, 443 } accept
        ip daddr 22.22.22.22 tcp dport { 80, 443 } accept
        ip daddr 22.22.23.23 tcp dport { 80, 443 } accept
        ip daddr 192.168.2.1 tcp dport { 80, 443 } accept
        #
        # Rule 31 (NAT)
        #
        tcp dport 80 accept
        #
        # Rule 33 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.10 tcp dport 80 snat to 22.22.22.22
        oifname "eth0" ip saddr ! 192.168.1.10 ip daddr 192.168.1.10 tcp dport 80 snat to 192.168.1.1
        #
        # Rule 36 (NAT)
        #
        oifname "eth0" ip saddr ! 192.168.1.10 tcp dport 80 snat to 192.168.1.1
        oifname "eth0" ip saddr ! 192.168.1.20 tcp dport 80 snat to 192.168.1.1
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 tcp dport 80 snat to 192.168.1.1
        #
        # Rule 38 (NAT)
        #
        # this is the "exception" rule
        # used in support req. originally
        oifname "eth1" ip saddr 192.168.1.10 tcp dport 80 snat to 22.22.22.22
        oifname "eth1" ip saddr 192.168.1.20 tcp dport 80 snat to 22.22.22.22
        #
        # Rule 40 (NAT)
        #
        # "exception" rule in the pair
        # from a support req.
        oifname "eth1" ip saddr 192.168.1.10 tcp dport 80 snat to 22.22.22.22
        oifname "eth1" ip saddr 192.168.1.20 tcp dport 80 snat to 22.22.22.22
        #
        # Rule 44 (NAT)
        #
        # "exception" rule in the pair
        # from a support req.
        oifname "eth1" ip saddr 192.168.1.10 tcp dport 80 snat to 22.22.22.22
        oifname "eth1" ip saddr 192.168.1.20 tcp dport 80 snat to 22.22.22.22
    }
}

NFT_RULES
}

ip_forward() {
    :
    echo 1 > /proc/sys/net/ipv4/ip_forward
}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        configure_interfaces
        stop_action
        prolog_commands
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
