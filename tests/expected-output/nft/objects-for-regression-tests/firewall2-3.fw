# Unsupported NAT rule
# Unsupported NAT rule
# Rule 31 (NAT): No chain assignment for NAT rule type: None

FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"
IP="ip"
LOGGER="logger"

log() {
    echo "$1"
    command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
    echo $1 | sed 's/\./_/'
}

getaddr_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP $af addr show dev $dev |  sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getnet_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP route list proto kernel | grep $dev | grep -v default |  sed 's! .*$!!')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getaddr() {
    getaddr_internal $1 $2 "-4"
}

getaddr6() {
    getaddr_internal $1 $2 "-6"
}

getnet() {
    getnet_internal $1 $2 "-4"
}

getnet6() {
    getnet_internal $1 $2 "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
    NAME=$1
    $IP link show | grep ": $NAME" | while read L; do
        OIFS=$IFS
        IFS=" :"
        set $L
        IFS=$OIFS
        echo $2
    done
}

diff_intf() {
    func=$1
    list1=$2
    list2=$3
    cmd=$4
    for intf in $list1
    do
        echo $list2 | grep -q $intf || {
        # $vlan is absent in list 2
            $func $intf $cmd
        }
    done
}

P2P_INTERFACE_WARNING=""

missing_address() {
    address=$1
    cmd=$2

    oldIFS=$IFS
    IFS="@"
    set $address
    addr=$1
    interface=$2
    IFS=$oldIFS

    $IP addr show dev $interface | grep -q POINTOPOINT && {
        test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
        P2P_INTERFACE_WARNING="yes"
        return
    }

    test "$cmd" = "add" && {
      echo "# Adding ip address: $interface $addr"
      echo $addr | grep -q ':' && {
          $FWBDEBUG $IP addr $cmd $addr dev $interface
      } || {
          $FWBDEBUG $IP addr $cmd $addr broadcast + dev $interface
      }
    }

    test "$cmd" = "del" && {
      echo "# Removing ip address: $interface $addr"
      $FWBDEBUG $IP addr $cmd $addr dev $interface || exit 1
    }

    $FWBDEBUG $IP link set $interface up
}

list_addresses_by_scope() {
    interface=$1
    scope=$2
    ignore_list=$3
    $IP addr ls dev $interface | \
      awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
        while read addr; do
          echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
    ignore_list=$2
    set $1
    interface=$1
    shift

    FWB_ADDRS=$(
      for addr in $*; do
        echo "${addr}@$interface"
      done | sort
    )

    CURRENT_ADDRS_ALL_SCOPES=""
    CURRENT_ADDRS_GLOBAL_SCOPE=""

    $IP link show dev $interface >/dev/null 2>&1 && {
      CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope $interface 'scope .*' "$ignore_list")
      CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope $interface 'scope global' "$ignore_list")
    } || {
      echo "# Interface $interface does not exist"
      # Stop the script if we are not in test mode
      test -z "$FWBDEBUG" && exit 1
    }

    diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
    diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
    $IP link show | sed 's/://g' | awk -v IGNORED="$*" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/state/ && !($2 in ignored_dict)) {print $2;}' | \
         while read intf; do
            echo "# Removing addresses not configured in fwbuilder from interface $intf"
            $FWBDEBUG $IP addr flush dev $intf scope global
            $FWBDEBUG $IP link set $intf down
         done
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

configure_interfaces() {
    :
    # See http://bugs.debian.org/cgi-bin/bugreport.cgi?bug=429689
    # this ensures that secondary ip address is "promoted" to primary
    # when primary address is deleted, instead of deleting both
    # primary and secondary addresses. It looks like this is only
    # available starting from Linux 2.6.16
    test -f /proc/sys/net/ipv4/conf/all/promote_secondaries && \
        echo 1 >  /proc/sys/net/ipv4/conf/all/promote_secondaries
    update_addresses_of_interface "eth0 192.168.1.1/24" ""
    update_addresses_of_interface "eth1 22.22.22.22/24" ""
    update_addresses_of_interface "eth2 192.168.2.1/24 192.168.2.40/24" ""
    update_addresses_of_interface "eth3 22.22.23.23/24 22.22.25.50/24" ""
    update_addresses_of_interface "lo 127.0.0.1/8" ""
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter
table ip fwf_nat {}
delete table ip fwf_nat

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        ct state invalid log prefix "INVALID " drop
        tcp flags != syn ct state new drop
        #
        # Rule 0 (eth1)
        #
        # Anti-spoofing rule
        iifname "eth1" ip saddr { 22.22.22.22, 22.22.23.23, 22.22.25.50, 192.168.1.1, 192.168.2.1, 192.168.2.40, 192.168.1.0/24 } log prefix "Iface: eth1 RULE 0 -- DENY **" level debug drop
        #
        # Rule 2 ()
        #
        # testing group in "interface"
        # this rule should be identical to rule 3
        iifname "eth1" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 2 - DENY **" level debug drop
        iifname "eth3" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 2 - DENY **" level debug drop
        #
        # Rule 3 (eth1,eth3)
        #
        iifname "eth1" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 3 - DENY **" level debug drop
        iifname "eth3" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 3 - DENY **" level debug drop
        #
        # Rule 7 (global)
        #
        meta l4proto tcp log prefix "RULE 7 - DENY **" level debug drop
        #
        # Rule 8 (global)
        #
        # block fragments
        meta l4proto 0 log prefix "RULE 8 - DENY **" level debug drop
        #
        # Rule 9 (global)
        #
        # sends TCP RST and makes custom record
        # in the log
        tcp dport 113 log prefix "IDENT" level debug reject with tcp reset
        #
        # Rule 10 (global)
        #
        udp dport 161 log prefix "RULE 10 - REJECT **" level debug reject with tcp reset
        #
        # Rule 11 (global)
        #
        ip saddr 192.168.2.0/24 ip daddr 192.168.2.1 meta l4proto icmp ct state new log prefix "RULE 11 - ACCEPT **" level debug accept
        #
        # Rule 14 (global)
        #
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } reject with icmp net-unreachable
        #
        # Rule 15 (global)
        #
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ct state new accept
        #
        # Rule 16 (global)
        #
        ip saddr 192.168.1.0/24 log prefix "RULE 16 - DENY **" level debug drop
        #
        # Rule 18 (global)
        #
        tcp dport 21 ct state new log prefix "RULE 18 - ACCEPT **" level debug accept
        #
        # Rule 19 (global)
        #
        # 'catch all' rule
        log prefix "RULE 19 - DENY **" level debug drop
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        ct state invalid log prefix "INVALID " drop
        tcp flags != syn ct state new drop
        #
        # Rule 0 (eth1)
        #
        # Anti-spoofing rule
        iifname "eth1" ip saddr { 22.22.22.22, 22.22.23.23, 22.22.25.50, 192.168.1.1, 192.168.2.1, 192.168.2.40, 192.168.1.0/24 } log prefix "Iface: eth1 RULE 0 -- DENY **" level debug drop
        #
        # Rule 1 (eth1)
        #
        # Anti-spoofing rule
        oifname "eth1" ip saddr != 192.168.1.0/24 log prefix "Iface: eth1 RULE 1 -- DENY **" level debug drop
        #
        # Rule 2 ()
        #
        # testing group in "interface"
        # this rule should be identical to rule 3
        iifname "eth1" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 2 - DENY **" level debug drop
        iifname "eth3" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 2 - DENY **" level debug drop
        #
        # Rule 3 (eth1,eth3)
        #
        iifname "eth1" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 3 - DENY **" level debug drop
        iifname "eth3" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log prefix "RULE 3 - DENY **" level debug drop
        #
        # Rule 4 (eth1,eth3)
        #
        # testing choice of chains in case when several
        # interfaces are used and rule matches 'any' or
        # broadcast
        iifname "eth1" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        iifname "eth3" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth1" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth3" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 5 (eth1,eth3)
        #
        iifname "eth1" ip saddr 0.0.0.0 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        iifname "eth3" ip saddr 0.0.0.0 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 6 (eth1,eth3)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 7 (global)
        #
        meta l4proto tcp log prefix "RULE 7 - DENY **" level debug drop
        #
        # Rule 8 (global)
        #
        # block fragments
        meta l4proto 0 log prefix "RULE 8 - DENY **" level debug drop
        #
        # Rule 9 (global)
        #
        # sends TCP RST and makes custom record
        # in the log
        tcp dport 113 log prefix "IDENT" level debug reject with tcp reset
        #
        # Rule 10 (global)
        #
        udp dport 161 log prefix "RULE 10 - REJECT **" level debug reject with tcp reset
        #
        # Rule 12 (global)
        #
        ip saddr { 192.168.1.10, 192.168.1.20 } ip daddr 211.11.11.11 ct state new accept
        #
        # Rule 13 (global)
        #
        ip saddr 211.11.11.11 ip daddr { 192.168.1.10, 192.168.1.20 } ct state new accept
        #
        # Rule 14 (global)
        #
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } reject with icmp net-unreachable
        #
        # Rule 15 (global)
        #
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ct state new accept
        #
        # Rule 16 (global)
        #
        ip saddr 192.168.1.0/24 log prefix "RULE 16 - DENY **" level debug drop
        #
        # Rule 17 (global)
        #
        # host-fw2 has the same address as
        #         one of the firewall's interfaces
        ip daddr 22.22.22.22 tcp dport 21 ct state new log prefix "RULE 17 - ACCEPT **" level debug accept
        #
        # Rule 19 (global)
        #
        # 'catch all' rule
        log prefix "RULE 19 - DENY **" level debug drop
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        ct state invalid log prefix "INVALID " drop
        tcp flags != syn ct state new drop
        #
        # Rule 1 (eth1)
        #
        # Anti-spoofing rule
        oifname "eth1" ip saddr != { 22.22.22.22, 22.22.23.23, 22.22.25.50, 192.168.1.1, 192.168.2.1, 192.168.2.40, 192.168.1.0/24 } log prefix "Iface: eth1 RULE 1 -- DENY **" level debug drop
        #
        # Rule 4 (eth1,eth3)
        #
        # testing choice of chains in case when several
        # interfaces are used and rule matches 'any' or
        # broadcast
        oifname "eth1" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth3" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 6 (eth1,eth3)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 7 (global)
        #
        meta l4proto tcp log prefix "RULE 7 - DENY **" level debug drop
        #
        # Rule 8 (global)
        #
        # block fragments
        meta l4proto 0 log prefix "RULE 8 - DENY **" level debug drop
        #
        # Rule 9 (global)
        #
        # sends TCP RST and makes custom record
        # in the log
        tcp dport 113 log prefix "IDENT" level debug reject with tcp reset
        #
        # Rule 10 (global)
        #
        udp dport 161 log prefix "RULE 10 - REJECT **" level debug reject with tcp reset
        #
        # Rule 14 (global)
        #
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } reject with icmp net-unreachable
        #
        # Rule 15 (global)
        #
        ip saddr { 192.168.1.0/24, 192.168.2.0/24 } ct state new accept
        #
        # Rule 16 (global)
        #
        ip saddr 192.168.1.0/24 log prefix "RULE 16 - DENY **" level debug drop
        #
        # Rule 17 (global)
        #
        # host-fw2 has the same address as
        #         one of the firewall's interfaces
        ip daddr 22.22.22.22 tcp dport 21 ct state new log prefix "RULE 17 - ACCEPT **" level debug accept
        #
        # Rule 18 (global)
        #
        ip daddr { 22.22.22.22, 22.22.23.23, 22.22.25.50, 192.168.1.1, 192.168.2.1, 192.168.2.40 } tcp dport 21 ct state new log prefix "RULE 18 - ACCEPT **" level debug accept
        #
        # Rule 19 (global)
        #
        # 'catch all' rule
        log prefix "RULE 19 - DENY **" level debug drop
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        ip saddr 192.168.1.10 ip daddr 192.168.2.10 accept
        ip saddr 192.168.1.10 ip daddr 192.168.2.11 accept
        ip saddr 192.168.1.20 ip daddr 192.168.2.10 accept
        ip saddr 192.168.1.20 ip daddr 192.168.2.11 accept
        ip saddr 192.168.1.10 ip daddr ! 192.168.2.10 accept
        ip saddr 192.168.1.10 ip daddr ! 192.168.2.11 accept
