        #
        meta l4proto 50 ct state new log prefix "RULE 4 -- ACCEPT " level info accept
        meta l4proto 51 ct state new log prefix "RULE 4 -- ACCEPT " level info accept
        #
        # Rule 5 (eth1)
        #
        oifname "eth1" ip saddr 22.22.23.22 meta l4proto 50 ct state new accept
        oifname "eth1" ip saddr 22.22.23.22 meta l4proto 51 ct state new accept
        #
        # Rule 8 (eth1)
        #
        oifname "eth1" ip saddr 22.22.23.22 meta l4proto 50 accept
        oifname "eth1" ip saddr 22.22.23.22 meta l4proto 51 accept
        #
        # Rule 10 (eth1)
        #
        oifname "eth1" meta l4proto 50 accept
        oifname "eth1" meta l4proto 51 accept
        #
        # Rule 11 (global)
        #
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } meta l4proto 50 ct state new log prefix "RULE 11 -- ACCEPT " level info accept
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } meta l4proto 51 ct state new log prefix "RULE 11 -- ACCEPT " level info accept
        #
        # Rule 16 (global)
        #
        # using CONNMARK
        meta l4proto 50 ct state new log prefix "RULE 16 -- ACCEPT " level info accept
        meta l4proto 51 ct state new log prefix "RULE 16 -- ACCEPT " level info accept
        #
        # Rule 17 (global)
        #
        # using CONNMARK
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } meta l4proto 50 ct state new log prefix "RULE 17 -- ACCEPT " level info accept
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } meta l4proto 51 ct state new log prefix "RULE 17 -- ACCEPT " level info accept
        #
        # Rule 20 (global)
        #
        # tag 0 matches packet that has not been marked yet.
        # # Rule 20 (global): Service type TagService not yet supported by nftables compiler
        ct state new accept
        #
        # Rule 21 (global)
        #
        # # Rule 21 (global): Pipe action not yet supported by nftables compiler
        ip daddr 192.168.2.10 tcp dport 80
        #
        # Rule 22 (global)
        #
        ip saddr 192.168.1.0/24 accept
        #
        # Rule 23 (global)
        #
        ip saddr 192.168.1.0/24 log prefix "RULE 23 -- ACCEPT " level info accept
        #
        # Rule 24 (global)
        #
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } accept
        #
        # Rule 25 (global)
        #
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } log prefix "RULE 25 -- ACCEPT " level info accept
        #
        # Rule 26 (eth1)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 accept
        #
        # Rule 27 (eth1)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 log prefix "RULE 27 -- ACCEPT " level info accept
        #
        # Rule 29 (eth1)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 log prefix "RULE 29 -- ACCEPT " level info accept
        #
        # Rule 30 (global)
        #
        #
        # Rule 31 (global)
        #
        # testing for bug #1618381
        # classify action is non-terminating
        # in this firewall object
        icmp type destination-unreachable accept
        #
        # Rule 32 (eth0)
        #
        # second rule for bug #1618381
        oifname "eth0" accept
        #
        # Rule 33 (global)
        #
        # testing for bug #1618381
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } icmp type destination-unreachable accept
        #
        # Rule 34 (global)
        #
        # testing for bug #1618381
        ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } tcp dport 80 accept
        #
        # Rule 35 (eth0)
        #
        # bug #1618381
        # this rule uses multiport
        # and has to be split because
        # of that
        oifname "eth0" tcp dport { 113, 13, 53, 2105, 21, 70, 80, 443, 6667, 119, 25, 3128, 22, 23, 10000-11000, 540 } accept
        oifname "eth0" udp dport { 53, 161 } accept
        #
        # Rule 36 (global)
        #
        ip saddr 192.168.1.0/24
        #
        # Rule 37 (global)
        #
        # # Rule 37 (global): Branch action not yet supported by nftables compiler
        log prefix "RULE 37 -- BRANCH " level info
        #
        # Rule 38 (global)
        #
        log prefix "RULE 38 -- DENY " level info drop
        #
        # Rule mangle_rules 0 (global)
        #
        # # Rule 0: Service type TagService not yet supported by nftables compiler
        ct state new accept
        #
        # Rule mangle_rules 1 (global)
        #
        tcp dport 80 ct state new accept
        #
        # Rule mangle_rules 2 (global)
        #
        # # Rule 2: Service type TagService not yet supported by nftables compiler
        accept
        #
        # Rule mangle_rules 8 (global)
        #
        # # Rule 8: Service type TagService not yet supported by nftables compiler
        ct state new accept
        #
        # Rule mangle_rules 9 (global)
        #
        # # Rule 9: Service type TagService not yet supported by nftables compiler
        ip saddr 22.22.23.22 ct state new accept
        #
        # Rule mangle_rules 10 (global)
        #
        # # Rule 10: Service type TagService not yet supported by nftables compiler
        ip daddr { 22.22.23.22, 192.168.1.22, 192.168.2.1 } ct state new accept
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        ip saddr 192.168.1.0/24 accept
    }

    chain output {
        type nat hook output priority dstnat;
        accept
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        ip saddr 192.168.1.22 accept
        ip saddr 192.168.1.0/24 accept
    }
}

NFT_RULES
}

ip_forward() {
    :

}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        configure_interfaces
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
