FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"
IP="ip"
LOGGER="logger"

log() {
    echo "$1"
    command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
    echo $1 | sed 's/\./_/'
}

getaddr_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP $af addr show dev $dev |  sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getnet_internal() {
    dev=$1
    name=$2
    af=$3
    L=$($IP route list proto kernel | grep $dev | grep -v default |  sed 's! .*$!!')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getaddr() {
    getaddr_internal $1 $2 "-4"
}

getaddr6() {
    getaddr_internal $1 $2 "-6"
}

getnet() {
    getnet_internal $1 $2 "-4"
}

getnet6() {
    getnet_internal $1 $2 "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
    NAME=$1
    $IP link show | grep ": $NAME" | while read L; do
        OIFS=$IFS
        IFS=" :"
        set $L
        IFS=$OIFS
        echo $2
    done
}

diff_intf() {
    func=$1
    list1=$2
    list2=$3
    cmd=$4
    for intf in $list1
    do
        echo $list2 | grep -q $intf || {
        # $vlan is absent in list 2
            $func $intf $cmd
        }
    done
}

P2P_INTERFACE_WARNING=""

missing_address() {
    address=$1
    cmd=$2

    oldIFS=$IFS
    IFS="@"
    set $address
    addr=$1
    interface=$2
    IFS=$oldIFS

    $IP addr show dev $interface | grep -q POINTOPOINT && {
        test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
        P2P_INTERFACE_WARNING="yes"
        return
    }

    test "$cmd" = "add" && {
      echo "# Adding ip address: $interface $addr"
      echo $addr | grep -q ':' && {
          $FWBDEBUG $IP addr $cmd $addr dev $interface
      } || {
          $FWBDEBUG $IP addr $cmd $addr broadcast + dev $interface
      }
    }

    test "$cmd" = "del" && {
      echo "# Removing ip address: $interface $addr"
      $FWBDEBUG $IP addr $cmd $addr dev $interface || exit 1
    }

    $FWBDEBUG $IP link set $interface up
}

list_addresses_by_scope() {
    interface=$1
    scope=$2
    ignore_list=$3
    $IP addr ls dev $interface | \
      awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
        while read addr; do
          echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
    ignore_list=$2
    set $1
    interface=$1
    shift

    FWB_ADDRS=$(
      for addr in $*; do
        echo "${addr}@$interface"
      done | sort
    )

    CURRENT_ADDRS_ALL_SCOPES=""
    CURRENT_ADDRS_GLOBAL_SCOPE=""

    $IP link show dev $interface >/dev/null 2>&1 && {
      CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope $interface 'scope .*' "$ignore_list")
      CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope $interface 'scope global' "$ignore_list")
    } || {
      echo "# Interface $interface does not exist"
      # Stop the script if we are not in test mode
      test -z "$FWBDEBUG" && exit 1
    }

    diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
    diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
    $IP link show | sed 's/://g' | awk -v IGNORED="$*" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/state/ && !($2 in ignored_dict)) {print $2;}' | \
         while read intf; do
            echo "# Removing addresses not configured in fwbuilder from interface $intf"
            $FWBDEBUG $IP addr flush dev $intf scope global
            $FWBDEBUG $IP link set $intf down
         done
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

configure_interfaces() {
    :
    update_addresses_of_interface "eth0 22.22.22.22/24" ""
    update_addresses_of_interface "eth1 22.22.23.22/24" ""
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter
table ip fwf_nat {}
delete table ip fwf_nat

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 1 (global)
        #
        log prefix "RULE 1 -- DENY " level info drop
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (global)
        #
        ip daddr 22.22.22.23 tcp dport 8080 ct state new accept
        #
        # Rule 1 (global)
        #
        log prefix "RULE 1 -- DENY " level info drop
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (global)
        #
        ip daddr 22.22.22.23 tcp dport 8080 ct state new accept
        #
        # Rule 1 (global)
        #
        log prefix "RULE 1 -- DENY " level info drop
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        #
        # Rule 4 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 80 redirect to :8080
        ip daddr 22.22.23.22 tcp dport 80 redirect to :8080
        #
        # Rule 5 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 80 dnat to 22.22.22.22:8080
        ip daddr 22.22.23.22 tcp dport 80 dnat to 22.22.22.22:8080
        #
        # Rule 10 (NAT)
        #
        tcp dport 80 redirect to :8080
        #
        # Rule 11 (NAT)
        #
        # SDNAT
        ip daddr 192.0.2.1 tcp dport 22 dnat to 192.168.1.10
        #
        # Rule 12 (NAT)
        #
        # SDNAT with source port
        ip daddr 192.0.2.1 udp sport 123 dnat to 192.168.1.10
        #
        # Rule 13 (NAT)
        #
        # SDNAT with dest port
        ip saddr 192.168.1.0/24 udp dport 53 dnat to 192.168.1.10:1053
        #
        # Rule 14 (NAT)
        #
        # SDNAT
        # translate src and dst addresses
        # and src and dst ports
        ip saddr 192.168.1.0/24 udp sport 1024-65535 udp dport 53 dnat to 192.168.1.10:1053
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        ip daddr 22.22.22.23 tcp dport 80 accept
        #
        # Rule 1 (NAT)
        #
        ip daddr 22.22.23.22 tcp dport 80 accept
        #
        # Rule 2 (NAT)
        #
        ip daddr 22.22.23.22 tcp dport 80 accept
        #
        # Rule 3 (NAT)
        #
        ip daddr 22.22.22.22 tcp dport 80 accept
        ip daddr 22.22.23.22 tcp dport 80 accept
        #
        # Rule 6 (NAT)
        #
        tcp dport 80 accept
        #
        # Rule 7 (NAT)
        #
        # port-only translation
        udp sport 6767 accept
        #
        # Rule 8 (NAT)
        #
        oifname "eth0" udp sport 6767 snat to 22.22.22.22:67
        oifname "eth1" udp sport 6767 snat to 22.22.23.22:67
        #
        # Rule 9 (NAT)
        #
        # port-only translation
        tcp dport 80 accept
        oifname "eth0" ip daddr 192.168.1.10 tcp dport 22 snat to 192.0.2.1
        oifname "eth1" ip daddr 192.168.1.10 tcp dport 22 snat to 192.0.2.1
        oifname "eth0" ip daddr 192.168.1.10 udp sport 123 snat to 192.0.2.1:5050
        oifname "eth1" ip daddr 192.168.1.10 udp sport 123 snat to 192.0.2.1:5050
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 udp dport 53 snat to 192.0.2.1
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 udp dport 53 snat to 192.0.2.1
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 udp sport 1024-65535 udp dport 53 snat to 192.0.2.1:32767-65535
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr 192.168.1.10 udp sport 1024-65535 udp dport 53 snat to 192.0.2.1:32767-65535
        #
        # Rule 15 (NAT)
        #
        ip saddr 192.168.1.0/24 udp dport 53 accept
    }
}

NFT_RULES
}

ip_forward() {
    :

}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        configure_interfaces
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
