        iifname "eth2" ip saddr != { 192.168.1.0/24, 192.168.2.0/24 } log level debug drop
        #
        # Rule 10 (eth1,eth3)
        #
        iifname "eth1" ip saddr != { 22.22.23.128/25, 33.33.33.0/24 } ct state new accept
        iifname "eth3" ip saddr != { 22.22.23.128/25, 33.33.33.0/24 } ct state new accept
        #
