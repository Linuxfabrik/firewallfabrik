        ip saddr 192.168.2.0/24 ip daddr != { 22.22.22.22, 22.22.23.23, 192.168.1.1, 192.168.2.1 } tcp dport 22 ct state new accept
        ip saddr 192.168.2.0/24 ip daddr != 192.168.1.0/24 tcp dport 22 ct state new accept
