        #
        ip saddr 192.168.1.0/24 tcp dport 25 ct state new meta hour "00:00"-"23:59" meta day { "Saturday" } accept
        ip saddr 192.168.1.0/24 tcp dport 25 ct state new meta hour "00:00"-"23:59" meta day { "Sunday" } accept
        #
        # Rule 39 (global)
        #
        ip saddr 192.168.1.0/24 tcp dport 80 ct state new meta hour "09:00"-"17:00" meta day { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" } accept
        #
        # Rule 40 (global)
        #
        ip daddr != 192.168.1.0/24 tcp dport 80 drop
        #
        # Rule 41 (global)
        #
        ip saddr != 192.168.1.0/24 ip daddr { 22.22.22.22, 22.22.23.23, 192.168.1.1, 192.168.2.1 } tcp dport 80 drop
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        ip saddr 192.168.1.0/24 ip daddr 192.168.2.0/24 accept
        #
        # Rule 11 (NAT)
        #
        ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.1 tcp dport 80 redirect to :3128
        ip saddr 192.168.1.0/24 ip daddr ! 22.22.22.22 tcp dport 80 redirect to :3128
        ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.1 tcp dport 80 redirect to :3128
        ip saddr 192.168.1.0/24 ip daddr ! 22.22.23.23 tcp dport 80 redirect to :3128
        #
        # Rule 12 (NAT)
        #
        ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.1 tcp dport 80 redirect to :3128
        #
        # Rule 13 (NAT)
        #
        ip saddr 192.168.1.10 ip daddr ! 192.168.1.0/24 tcp dport 80 redirect to :3128
        ip saddr 192.168.1.10 ip daddr ! 192.168.2.0/24 tcp dport 80 redirect to :3128
        ip saddr 192.168.1.20 ip daddr ! 192.168.1.0/24 tcp dport 80 redirect to :3128
        ip saddr 192.168.1.20 ip daddr ! 192.168.2.0/24 tcp dport 80 redirect to :3128
        #
        # Rule 14 (NAT)
        #
        ip saddr ! 192.168.1.10 ip daddr 192.168.1.0/24 tcp dport 80 redirect to :3128
        ip saddr ! 192.168.1.10 ip daddr 192.168.2.0/24 tcp dport 80 redirect to :3128
        ip saddr ! 192.168.1.20 ip daddr 192.168.1.0/24 tcp dport 80 redirect to :3128
        ip saddr ! 192.168.1.20 ip daddr 192.168.2.0/24 tcp dport 80 redirect to :3128
        #
        # Rule 15 (NAT)
        #
        ip saddr ! 192.168.1.10 tcp dport 80 redirect to :3128
        #
        # Rule 16 (NAT)
        #
        ip daddr 22.22.22.23 tcp dport { 6667, 3128, 4000-4010, 5000-5010 } dnat to 192.168.1.10
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        ip saddr 192.168.1.0/24 ip daddr 192.168.2.0/24 accept
        #
        # Rule 1 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth1" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth2" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth3" ip saddr 192.168.1.10 snat to 22.22.22.23
        #
        # Rule 2 (NAT)
        #
        oifname "eth0" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 snat to 22.22.22.23
        oifname "eth1" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 snat to 22.22.22.23
        oifname "eth2" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 snat to 22.22.22.23
        oifname "eth3" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 snat to 22.22.22.23
        #
        # Rule 3 (NAT)
        #
        oifname "eth0" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 tcp dport 80 snat to 22.22.22.23
        oifname "eth1" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 tcp dport 80 snat to 22.22.22.23
        oifname "eth2" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 tcp dport 80 snat to 22.22.22.23
        oifname "eth3" ip saddr ! 192.168.1.0/24 ip daddr 200.200.200.200 tcp dport 80 snat to 22.22.22.23
        #
        # Rule 4 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 22.22.22.22
        oifname "eth2" ip saddr 192.168.1.0/24 snat to 192.168.2.1
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.23.23
        #
        # Rule 5 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 snat to 22.22.23.23
        #
        # Rule 6 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 22.22.23.23
        #
        # Rule 7 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 tcp dport 80 snat to 22.22.22.22
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 tcp dport 80 snat to 22.22.23.23
        #
        # Rule 8 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.0/24 snat to 22.22.22.22
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.0/24 snat to 192.168.2.1
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.0/24 snat to 22.22.23.23
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 22.22.22.22
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 192.168.2.1
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 22.22.23.23
        #
        # Rule 9 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.0/24 snat to 22.22.22.22
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.0/24 snat to 192.168.2.1
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr ! 192.168.1.0/24 snat to 22.22.23.23
        oifname "eth1" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 22.22.22.22
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 192.168.2.1
        oifname "eth3" ip saddr 192.168.1.0/24 ip daddr ! 192.168.2.0/24 snat to 22.22.23.23
        #
        # Rule 10 (NAT)
        #
        oifname "eth0" ip saddr ! 192.168.2.0/24 snat to 192.168.1.1
        oifname "eth1" ip saddr ! 192.168.2.0/24 snat to 22.22.22.22
        oifname "eth3" ip saddr ! 192.168.2.0/24 snat to 22.22.23.23
        #
        # Rule 17 (NAT)
        #
        ip daddr 192.168.1.0/24 tcp dport 80 accept
        ip daddr 192.168.1.0/24 tcp dport 80 accept
        ip daddr 192.168.2.0/24 tcp dport 80 accept
        ip daddr 192.168.2.0/24 tcp dport 80 accept
        #
        # Rule 18 (NAT)
        #
        ip daddr ! 192.168.1.0/24 tcp dport 80 accept
        ip daddr ! 192.168.1.0/24 tcp dport 80 accept
        ip daddr ! 192.168.2.0/24 tcp dport 80 accept
        ip daddr ! 192.168.2.0/24 tcp dport 80 accept
    }
}

NFT_RULES
}

ip_forward() {
    :

}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        configure_interfaces
        prolog_commands
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
