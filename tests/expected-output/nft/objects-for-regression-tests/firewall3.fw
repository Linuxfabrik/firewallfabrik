#!/bin/sh
#
#  This file is managed by FirewallFabrik - do not edit
#
#  FirewallFabrik fwf-nft VERSION
#
#  Generated TIMESTAMP
#
# files: * firewall3.fw /etc/fw/fwf.sh
#
#  this object is used to test negation in policy rules with "Assume firewall is part of 'Any'" turned OFF
#

FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"
IP="ip"
LOGGER="logger"

log() {
    echo "$1"
    command -v "$LOGGER" >/dev/null 2>&1 && $LOGGER -p info "$1"
}

getInterfaceVarName() {
    echo "$1" | sed 's/\./_/'
}

getaddr_internal() {
    dev=$1
    name=$2
    af=$3
    L=$("$IP" "$af" addr show dev "$dev" | sed -n '/inet/{s!.*inet6* !!;s!/.*!!p}' | sed 's/peer.*//')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getnet_internal() {
    dev=$1
    name=$2
    af=$3
    L=$("$IP" route list proto kernel | grep "$dev" | grep -v default | sed 's! .*$!!')
    test -z "$L" && {
        eval "$name=''"
        return
    }
    eval "${name}_list=\"$L\""
}

getaddr() {
    getaddr_internal "$1" "$2" "-4"
}

getaddr6() {
    getaddr_internal "$1" "$2" "-6"
}

getnet() {
    getnet_internal "$1" "$2" "-4"
}

getnet6() {
    getnet_internal "$1" "$2" "-6"
}

# function getinterfaces is used to process wildcard interfaces
getinterfaces() {
    NAME=$1
    "$IP" link show | grep ": $NAME" | while read -r L; do
        OIFS=$IFS
        IFS=" :"
        # shellcheck disable=SC2086
        set -- $L
        IFS=$OIFS
        echo "$2"
    done
}

diff_intf() {
    func=$1
    list1=$2
    list2=$3
    cmd=$4
    for intf in $list1
    do
        echo "$list2" | grep -q "$intf" || {
        # $intf is absent in list 2
            "$func" "$intf" "$cmd"
        }
    done
}

P2P_INTERFACE_WARNING=""

missing_address() {
    address=$1
    cmd=$2

    oldIFS=$IFS
    IFS="@"
    # shellcheck disable=SC2086
    set -- $address
    addr=$1
    interface=$2
    IFS=$oldIFS

    "$IP" addr show dev "$interface" | grep -q POINTOPOINT && {
        test -z "$P2P_INTERFACE_WARNING" && echo "Warning: Can not update address of interface $interface. fwbuilder can not manage addresses of point-to-point interfaces yet"
        P2P_INTERFACE_WARNING="yes"
        return
    }

    test "$cmd" = "add" && {
      echo "# Adding ip address: $interface $addr"
      if echo "$addr" | grep -q ':'; then
          $FWBDEBUG "$IP" addr "$cmd" "$addr" dev "$interface"
      else
          $FWBDEBUG "$IP" addr "$cmd" "$addr" broadcast + dev "$interface"
      fi
    }

    test "$cmd" = "del" && {
      echo "# Removing ip address: $interface $addr"
      $FWBDEBUG "$IP" addr "$cmd" "$addr" dev "$interface" || exit 1
    }

    $FWBDEBUG "$IP" link set "$interface" up
}

list_addresses_by_scope() {
    interface=$1
    scope=$2
    ignore_list=$3
    "$IP" addr ls dev "$interface" | \
      awk -v IGNORED="$ignore_list" -v SCOPE="$scope" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/inet |inet6 / && $0 ~ SCOPE && !($2 in ignored_dict)) {print $2;}' | \
        while read -r addr; do
          echo "${addr}@$interface"
	done | sort
}

update_addresses_of_interface() {
    ignore_list=$2
    # shellcheck disable=SC2086
    set -- $1
    interface=$1
    shift

    FWB_ADDRS=$(
      for addr in "$@"; do
        echo "${addr}@$interface"
      done | sort
    )

    CURRENT_ADDRS_ALL_SCOPES=""
    CURRENT_ADDRS_GLOBAL_SCOPE=""

    if "$IP" link show dev "$interface" >/dev/null 2>&1; then
      CURRENT_ADDRS_ALL_SCOPES=$(list_addresses_by_scope "$interface" 'scope .*' "$ignore_list")
      CURRENT_ADDRS_GLOBAL_SCOPE=$(list_addresses_by_scope "$interface" 'scope global' "$ignore_list")
    else
      echo "# Interface $interface does not exist"
      # Stop the script if we are not in test mode
      test -z "$FWBDEBUG" && exit 1
    fi

    diff_intf missing_address "$FWB_ADDRS" "$CURRENT_ADDRS_ALL_SCOPES" add
    diff_intf missing_address "$CURRENT_ADDRS_GLOBAL_SCOPE" "$FWB_ADDRS" del
}

clear_addresses_except_known_interfaces() {
    "$IP" link show | sed 's/://g' | awk -v IGNORED="$*" \
        'BEGIN {
           split(IGNORED,ignored_arr);
           for (a in ignored_arr) {ignored_dict[ignored_arr[a]]=1;}
         }
         (/state/ && !($2 in ignored_dict)) {print $2;}' | \
         while read -r intf; do
            echo "# Removing addresses not configured in fwbuilder from interface $intf"
            $FWBDEBUG "$IP" addr flush dev "$intf" scope global
            $FWBDEBUG "$IP" link set "$intf" down
         done
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

configure_interfaces() {
    :
    update_addresses_of_interface "eth0 192.168.1.1/24" ""
    update_addresses_of_interface "eth1 22.22.22.22/24" ""
    update_addresses_of_interface "eth2 192.168.2.1/24" ""
    update_addresses_of_interface "lo 127.0.0.1/8" ""
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter
table ip fwf_nat {}
delete table ip fwf_nat

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        #
        # Rule 0 (lo)
        #
        iif "lo" ct state new accept
        #
        # Rule 13 (global)
        #
        tcp dport 22 ct state new accept
        #
        # Rule 17 (global)
        #
        ip daddr != { 192.168.1.1, 192.168.2.1 } ct state new accept
        #
        # Rule 21 (global)
        #
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 22 (global)
        #
        ip saddr 192.168.1.0/24 ip daddr != { 22.22.22.22, 192.168.1.1, 192.168.2.1 } tcp dport 22 ct state new accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        #
        # Rule 1 (eth1)
        #
        iifname "eth1" meta l4proto 0 log level debug drop
        #
        # Rule 2 (eth0)
        #
        iifname "eth0" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log level debug drop
        #
        # Rule 3 (eth0,eth2)
        #
        iifname "eth2" ip saddr 192.168.1.0/24 udp dport { 68, 67 } log level debug drop
        #
        # Rule 4 (eth0)
        #
        # testing choice of chains in case when several interfaces
        # are used and rule matches on any or broadcast
        iifname "eth0" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth0" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 5 (eth0,eth2)
        #
        # testing choice of chains in case when several interfaces
        # are used and rule matches on any or broadcast
        iifname "eth2" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        oifname "eth2" ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 6 (eth0)
        #
        iifname "eth0" ip saddr 0.0.0.0 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 7 (eth0,eth2)
        #
        iifname "eth2" ip saddr 0.0.0.0 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 8 (eth0)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 9 (eth0,eth2)
        #
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 10 (eth1)
        #
        # Anti-spoofing rule
        iifname "eth1" ip saddr { 22.22.22.22, 192.168.1.1, 192.168.2.1, 192.168.1.0/24 } log level debug drop
        #
        # Rule 11 (eth1)
        #
        # Anti-spoofing rule
        oifname "eth1" ip saddr != 192.168.1.0/24 log level debug drop
        #
        # Rule 12 (global)
        #
        # hostF has the same IP address as firewal.
        ip daddr 192.168.1.1 icmp type echo-request icmp code 0 ct state new log level debug accept
        #
        # Rule 14 (global)
        #
        # testing negation in the policy rule
        ip saddr != { 192.168.1.10, 192.168.1.20 } icmp type destination-unreachable log level debug drop
        #
        # Rule 15 (global)
        #
        ip daddr != 33.33.33.0/24 ct state new accept
        #
        # Rule 16 (global)
        #
        ip daddr != { 33.33.33.0/24, 222.222.222.0/24 } ct state new accept
        #
        # Rule 17 (global)
        #
        ct state new accept
        #
        # Rule 18 (global)
        #
        # testing negation in service field
        ip daddr { 192.168.1.10, 192.168.1.20 } tcp dport != { 25, 22 } log level debug drop
        #
        # Rule 19 (global)
        #
        # 'masquerading' rule
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 20 (global)
        #
        # 'catch all' rule
        log level debug drop
        #
        # Rule 21 (global)
        #
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 22 (global)
        #
        ip saddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 23 (eth0,eth1,eth2)
        #
        # this rule should go only to the FORWARD
        # chain but should have "-i eth" clause
        iifname "eth0" ct state new accept
        iifname "eth1" ct state new accept
        iifname "eth2" ct state new accept
    }

    chain output {
        type filter hook output priority filter; policy drop;
        #
        # Rule 0 (lo)
        #
        oif "lo" ct state new accept
        #
        # Rule 8 (eth0)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 9 (eth0,eth2)
        #
        oifname "eth2" ip saddr 192.168.1.0/24 ip daddr 255.255.255.255-255.255.255.255 udp dport { 68, 67 } ct state new accept
        #
        # Rule 11 (eth1)
        #
        # Anti-spoofing rule
        oifname "eth1" ip saddr != { 22.22.22.22, 192.168.1.1, 192.168.2.1, 192.168.1.0/24 } log level debug drop
        #
        # Rule 19 (global)
        #
        # 'masquerading' rule
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 21 (global)
        #
        ip saddr != { 22.22.22.22, 192.168.1.1, 192.168.2.1 } ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 22 (global)
        #
        ip saddr 192.168.1.0/24 tcp dport 22 ct state new accept
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        oifname "eth1" ip saddr 192.168.1.0/24 snat to 22.22.22.22
        oifname "eth2" ip saddr 192.168.1.0/24 snat to 192.168.2.1
        #
        # Rule 1 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth1" ip saddr 192.168.1.10 snat to 22.22.22.23
        oifname "eth2" ip saddr 192.168.1.10 snat to 22.22.22.23
    }
}

NFT_RULES
}

ip_forward() {
    :

}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet fwf_filter 2>/dev/null
    $NFT delete table ip fwf_filter 2>/dev/null
    $NFT delete table inet fwf_nat 2>/dev/null
    $NFT delete table ip fwf_nat 2>/dev/null
}

block_action() {
    $NFT flush ruleset 2>/dev/null
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet fwf_filter
    $NFT add chain inet fwf_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet fwf_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet fwf_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    $NFT flush ruleset 2>/dev/null
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'fwf_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        configure_interfaces
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
        ;;

esac

exit "$RETVAL"
