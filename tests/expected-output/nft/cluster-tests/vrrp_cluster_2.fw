#!/bin/sh
#
#  This file is managed by FirewallFabrik - do not edit
#
#  FirewallFabrik fwf-nft VERSION
#
#  Generated TIMESTAMP
#
# files: * vrrp_cluster_2.fw /etc/fw/vrrp_cluster_2.fw
#

FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"

log() {
    echo "$1"
    command -v logger > /dev/null 2>&1 && logger -p info "$1"
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip linuxfabrik_filter {}
delete table ip linuxfabrik_filter
table ip linuxfabrik_nat {}
delete table ip linuxfabrik_nat

table ip linuxfabrik_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 1 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip saddr { 172.24.0.1, 192.168.1.1, 192.168.1.0/24 } ct state new log prefix "RULE 1 -- DENY " level info drop
        #
        # Rule 2 (lo)
        #
        iif "lo" ct state new accept
        #
        # Rule 3 (global)
        #
        # SSH Access to firewall is permitted
        # only from internal network
        ip saddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 6 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        log prefix "RULE 6 -- DENY " level info drop
        #
        # Rule 7 (global)
        #
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 8 (global)
        #
        ct state new log prefix "RULE 8 -- DENY " level info drop
        #
        # Rule 9 (global)
        #
        log prefix "RULE 9 -- DENY " level info drop
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        iifname "eth0" ip daddr 224.0.0.18 meta l4proto 112 ct state new accept
        oifname "eth0" ip daddr 224.0.0.18 meta l4proto 112 ct state new accept
        #
        # Rule 1 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip saddr { 172.24.0.1, 192.168.1.1, 192.168.1.0/24 } ct state new log prefix "RULE 1 -- DENY " level info drop
        #
        # Rule 4 (global)
        #
        # SSH Access to firewall is permitted
        # only from internal network
        ip saddr 192.168.1.0/24 ip daddr { 192.168.1.2, 192.168.1.3, 192.168.1.4 } tcp dport 22 ct state new accept
        #
        # Rule 7 (global)
        #
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 8 (global)
        #
        ct state new log prefix "RULE 8 -- DENY " level info drop
        #
        # Rule 9 (global)
        #
        log prefix "RULE 9 -- DENY " level info drop
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        oifname "eth0" ip daddr 224.0.0.18 meta l4proto 112 ct state new accept
        #
        # Rule 2 (lo)
        #
        oif "lo" ct state new accept
        #
        # Rule 4 (global)
        #
        # SSH Access to firewall is permitted
        # only from internal network
        ip saddr 192.168.1.0/24 ip daddr { 192.168.1.2, 192.168.1.3, 192.168.1.4 } tcp dport 22 ct state new accept
        #
        # Rule 5 (global)
        #
        # Firewall uses one of the machines
        # on internal network for DNS
        ip daddr 192.168.1.0/24 meta l4proto { tcp, udp } th dport 53 ct state new log prefix "RULE 5 -- ACCEPT " level info accept
        #
        # Rule 6 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        ip daddr { 172.24.0.1, 192.168.1.1 } log prefix "RULE 6 -- DENY " level info drop
        #
        # Rule 7 (global)
        #
        ip saddr 192.168.1.0/24 ct state new accept
        #
        # Rule 8 (global)
        #
        ct state new log prefix "RULE 8 -- DENY " level info drop
        #
        # Rule 9 (global)
        #
        log prefix "RULE 9 -- DENY " level info drop
    }
}

table ip linuxfabrik_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        #
        # Rule 0 (NAT)
        #
        oifname "eth0" ip saddr 192.168.1.0/24 snat to 172.24.0.1
    }
}

NFT_RULES
}

ip_forward() {
    :

}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet linuxfabrik_filter 2>/dev/null
    $NFT delete table ip linuxfabrik_filter 2>/dev/null
    $NFT delete table inet linuxfabrik_nat 2>/dev/null
    $NFT delete table ip linuxfabrik_nat 2>/dev/null
}

block_action() {
    flush_own_tables
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet linuxfabrik_filter
    $NFT add chain inet linuxfabrik_filter input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet linuxfabrik_filter forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet linuxfabrik_filter output '{ type filter hook output priority 0; policy drop; }'
}

stop_action() {
    flush_own_tables
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q 'linuxfabrik_filter'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated TIMESTAMP"
        check_nft
        prolog_commands
        stop_action
        script_body || run_epilog_and_exit 1
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        stop_action
        RETVAL=$?
        ;;

    status)
        status_action
        RETVAL=$?
        ;;

    block)
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;

    *)
        echo "Usage $0 [start|stop|status|block|reload]"
        ;;

esac

exit "$RETVAL"
