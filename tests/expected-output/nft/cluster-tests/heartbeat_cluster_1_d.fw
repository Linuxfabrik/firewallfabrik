FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="/usr/sbin/nft"

log() {
    echo "$1"
    command -v logger > /dev/null 2>&1 && logger -p info "$1"
}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}

prolog_commands() {
    echo "Running prolog script"

    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"

    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
table ip fwf_filter {}
delete table ip fwf_filter
table ip fwf_nat {}
delete table ip fwf_nat

table ip fwf_filter {
    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip saddr { 192.168.1.254, 192.168.1.0/24 } ct state new log prefix "RULE 0 -- DENY " level info drop
        #
        # Rule 1 (lo)
        #
        iif "lo" ct state new accept
        #
        # Rule 2 (global)
        #
        # SSH Access to firewall is permitted
        # only from internal network
        ip saddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 7 (global)
        #
        # # Rule 7 (global): Can not build rule using dynamic interface 'eth0' of object 'unknown'
# Rule 7 (global): Could not resolve any source addresses
# Rule 7 (global): Dynamic interface address not yet supported by nftables compiler (interface: eth0)
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 11 (global)
        #
        ip saddr { 192.168.1.1, 192.168.1.2 } ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 12 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        log prefix "RULE 12 -- DENY " level info drop
        #
        # Rule 13 (eth0)
        #
        iifname "eth0" ct state new accept
        #
        # Rule 14 (eth0,eth1)
        #
        iifname "eth1" ct state new accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 0 (eth0)
        #
        # anti spoofing rule
        iifname "eth0" ip saddr { 192.168.1.254, 192.168.1.0/24 } ct state new log prefix "RULE 0 -- DENY " level info drop
        #
        # Rule 7 (global)
        #
        # # Rule 7 (global): Can not build rule using dynamic interface 'eth0' of object 'unknown'
# Rule 7 (global): Could not resolve any source addresses
# Rule 7 (global): Dynamic interface address not yet supported by nftables compiler (interface: eth0)
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 11 (global)
        #
        ip saddr { 192.168.1.1, 192.168.1.2 } ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 13 (eth0)
        #
        iifname "eth0" ct state new accept
        oifname "eth0" ct state new accept
        #
        # Rule 14 (eth0,eth1)
        #
        iifname "eth1" ct state new accept
        oifname "eth1" ct state new accept
    }

    chain output {
        type filter hook output priority filter; policy drop;
        ct state established,related accept
        #
        # Rule 1 (lo)
        #
        oif "lo" ct state new accept
        #
        # Rule 3 (global)
        #
        # Firewall uses one of the machines
        # on internal network for DNS
        ip daddr 192.168.1.0/24 meta l4proto { tcp, udp } th dport 53 ct state new log prefix "RULE 3 -- ACCEPT " level info accept
        #
        # Rule 4 (global)
        #
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 5 (global)
        #
        # fw is part of any and networks
        # # Rule 5 (global): Could not resolve any source addresses
# Rule 5 (global): Interface "eth0" has no addresses
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 6 (global)
        #
        # fw is NOT part of any and networks
        # # Rule 6 (global): Could not resolve any source addresses
# Rule 6 (global): Interface "eth0" has no addresses
        ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 8 (global)
        #
        # fw is part of any
        ip saddr 192.168.1.254 ip daddr 192.168.1.0/24 tcp dport 22 ct state new accept
        #
        # Rule 12 (global)
        #
        # All other attempts to connect to
        # the firewall are denied and logged
        ip daddr 192.168.1.254 log prefix "RULE 12 -- DENY " level info drop
        #
        # Rule 13 (eth0)
        #
        oifname "eth0" ct state new accept
        #
        # Rule 14 (eth0,eth1)
        #
        oifname "eth1" ct state new accept
        #
        # Rule 21 (eth0)
        #
        oifname "eth0" ip daddr 192.168.1.254 ct state new accept
        #
        # Rule 22 (eth0,eth1)
        #
        oifname "eth1" ip daddr 192.168.1.254 ct state new accept
    }
}

table ip fwf_nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        #
        # Rule 3 (NAT)
        #
        dnat to 192.168.1.100
        #
        # Rule 4 (NAT)
