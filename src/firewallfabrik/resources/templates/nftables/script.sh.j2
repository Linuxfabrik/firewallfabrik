#!/bin/sh
#
#  This file is managed by FirewallFabrik - do not edit
#
#  FirewallFabrik fwf-nft v{{ version }}
#
#  Generated by {{ user }}
#
{% if manifest %}
{{ manifest }}
#
{% endif %}
{% if comment %}
{{ comment }}
#
{% endif %}
{% if errors_and_warnings %}
{{ errors_and_warnings }}
{% endif %}

{{ shell_debug }}
FWBDEBUG=""

PATH="/sbin:/usr/sbin:/bin:/usr/bin:${PATH}"
export PATH

NFT="{{ nft_path }}"
{% if shell_functions %}
IP="{{ ip_path }}"
LOGGER="logger"
{% endif %}

{% if shell_functions %}
{{ shell_functions }}
{% else %}
log() {
    echo "$1"
    command -v logger > /dev/null 2>&1 && logger -p info "$1"
}
{% endif %}

check_nft() {
    if [ ! -x "$NFT" ]; then
        echo "Error: nft not found at $NFT"
        exit 1
    fi
}
{% if verify_interfaces_code %}

verify_interfaces() {
    :
{{ verify_interfaces_code }}
}
{% endif %}

prolog_commands() {
    echo "Running prolog script"
    {{ prolog_script }}
    echo "Prolog script done"
}

epilog_commands() {
    echo "Running epilog script"
    {{ epilog_script }}
    echo "Epilog script done"
}

run_epilog_and_exit() {
    epilog_commands
    exit "$1"
}
{% if configure_interfaces_code %}

configure_interfaces() {
    :
{{ configure_interfaces_code }}
}
{% endif %}

script_body() {
    $NFT -f /dev/stdin <<'NFT_RULES'
{{ nft_rules_body }}
NFT_RULES
}

{% if routing_output %}
routing_script() {
    {{ routing_output }}
}

{% endif %}
ip_forward() {
    :
    {{ ip_forward_commands }}
}
{% if kernel_vars_commands %}

set_kernel_variables() {
{{ kernel_vars_commands }}
}
{% endif %}

flush_own_tables() {
    # remove only our own tables, leaving other tools' tables untouched
    $NFT delete table inet {{ filter_table }} 2>/dev/null
    $NFT delete table ip {{ filter_table }} 2>/dev/null
    $NFT delete table inet {{ nat_table }} 2>/dev/null
    $NFT delete table ip {{ nat_table }} 2>/dev/null
}
{% if flush_ruleset %}

flush_legacy_iptables() {
    # Remove stale legacy (xtables) iptables rules left over from a
    # previous iptables-based policy. "nft flush ruleset" only clears
    # the nft backend, so on systems still using the legacy backend the
    # old iptables rules would otherwise survive and shadow the nft
    # rules. All filtering is delegated to nftables, so the built-in
    # policies are reset to ACCEPT and every chain is flushed/deleted.
    for ipt in iptables ip6tables; do
        command -v "$ipt" >/dev/null 2>&1 || continue
        "$ipt" -P INPUT ACCEPT 2>/dev/null
        "$ipt" -P FORWARD ACCEPT 2>/dev/null
        "$ipt" -P OUTPUT ACCEPT 2>/dev/null
        for table in filter nat mangle raw; do
            "$ipt" -t "$table" -F 2>/dev/null
            "$ipt" -t "$table" -X 2>/dev/null
        done
    done
}
{% endif %}

block_action() {
{% if flush_ruleset %}
    $NFT flush ruleset 2>/dev/null
    flush_legacy_iptables
{% else %}
    flush_own_tables
{% endif %}
    # block all traffic by default (always use inet to block both IPv4 and IPv6)
    $NFT add table inet {{ filter_table }}
    $NFT add chain inet {{ filter_table }} input '{ type filter hook input priority 0; policy drop; }'
    $NFT add chain inet {{ filter_table }} forward '{ type filter hook forward priority 0; policy drop; }'
    $NFT add chain inet {{ filter_table }} output '{ type filter hook output priority 0; policy drop; }'
{% if mgmt_access %}
    # backup ssh access
    $NFT add rule inet {{ filter_table }} input tcp dport 22 ip saddr {{ ssh_management_address }} ct state new,established accept
    $NFT add rule inet {{ filter_table }} output tcp sport 22 ip daddr {{ ssh_management_address }} ct state established accept
{% endif %}
}

stop_action() {
{% if flush_ruleset %}
    $NFT flush ruleset 2>/dev/null
    flush_legacy_iptables
{% else %}
    flush_own_tables
{% endif %}
}

check_nft_status() {
    tables=$($NFT list tables 2>/dev/null)
    if echo "$tables" | grep -q '{{ filter_table }}'; then
        return 0
    fi
    return 3
}

status_action() {
    check_nft_status
    ret=$?
    if [ $ret -eq 0 ]; then
        echo "Firewall is active"
        return 0
    fi
    echo "Firewall is not configured"
    exit 3
}

# See how we were called.
# For backwards compatibility missing argument is equivalent to 'start'

cmd=$1
test -z "$cmd" && {
    cmd="start"
}

case "$cmd" in
    start)
        log "Activating firewall script generated by {{ user }}"
        check_nft
{% if prolog_place == 'top' %}
        prolog_commands
{% endif %}
{% if configure_interfaces_code %}
        configure_interfaces
{% endif %}
{% if verify_interfaces_code %}
        verify_interfaces
{% endif %}
{% if prolog_place == 'after_interfaces' %}
        prolog_commands
{% endif %}
        stop_action
{% if prolog_place == 'after_flush' %}
        prolog_commands
{% endif %}
{% if kernel_vars_commands %}
        set_kernel_variables
{% endif %}
        script_body || run_epilog_and_exit 1
{% if routing_output %}
        routing_script
{% endif %}
        ip_forward
        epilog_commands
        log "Firewall script is done"
        RETVAL=$?
        ;;

    stop)
        check_nft
        stop_action
        RETVAL=$?
        ;;

    status)
        check_nft
        status_action
        RETVAL=$?
        ;;

    block)
        check_nft
        block_action
        RETVAL=$?
        ;;

    reload)
        $0 stop
        $0 start
        RETVAL=$?
        ;;
{% if configure_interfaces_code %}

    interfaces)
        configure_interfaces
        RETVAL=$?
        ;;

    test_interfaces)
        FWBDEBUG="echo"
        configure_interfaces
        RETVAL=$?
        ;;
{% endif %}

    *)
{% if configure_interfaces_code %}
        echo "Usage $0 [start|stop|status|block|reload|interfaces|test_interfaces]"
{% else %}
        echo "Usage $0 [start|stop|status|block|reload]"
{% endif %}
        ;;

esac

exit "$RETVAL"
