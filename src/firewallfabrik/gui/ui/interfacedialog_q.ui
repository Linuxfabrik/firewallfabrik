         <item>
          <widget class="QCheckBox" name="management">
           <property name="text">
            <string>Management interface</string>
           </property>
           <property name="toolTip">
            <string>Mark this as the management interface used for remote administration (SSH, SNMP). The compiler uses this to identify where management access rules should be applied, and the installer connects to this address by default.</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QCheckBox" name="dedicated_failover">
           <property name="text">
            <string>Dedicated failover interface</string>
           </property>
           <property name="toolTip">
            <string>Mark this interface as dedicated to cluster failover traffic (VRRP, heartbeat, openais). The compiler automatically generates rules to permit the failover protocol on this interface and excludes it from normal policy processing.</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QRadioButton" name="regular">
           <property name="text">
            <string>Static IP address</string>
           </property>
           <property name="toolTip">
            <string>This interface has one or more static IP addresses configured in FirewallFabrik. The generated script will use "ip addr add/del" to manage these addresses if "Configure interfaces" is enabled in the platform settings.</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QRadioButton" name="dynamic">
           <property name="text">
            <string>Address is assigned dynamically</string>
           </property>
           <property name="toolTip">
            <string>This interface gets its IP address dynamically (DHCP, PPP, etc.). The generated script uses shell functions to discover the address at runtime. IP address configuration is skipped for this interface.</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QRadioButton" name="unnumbered">
           <property name="text">
            <string>Unnumbered interface</string>
           </property>
           <property name="toolTip">
            <string>This interface has no IP address (e.g. a bonding slave, a point-to-point tunnel endpoint). IP address configuration and verification are skipped for this interface.</string>
           </property>
          </widget>
