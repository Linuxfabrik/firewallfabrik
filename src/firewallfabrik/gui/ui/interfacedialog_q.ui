              <enum>QAbstractSpinBox::ButtonSymbols::PlusMinus</enum>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="toolTip">
              <string>Security level (0-100). Not used by the iptables/nftables compiler. Relevant only for Cisco PIX/ASA platforms where 0 = least secure (Internet) and 100 = most secure (inside).</string>
             </property>
